---
---
<footer class="bg-slate-900 text-white pt-16 pb-8 relative overflow-hidden">
    <!-- Subtle background texture (topographic lines) -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml;base64,'); background-size: 100px 100px;"></div>
    <!-- Ambient glow accents -->
    <div class="absolute -top-32 -right-32 w-64 h-64 bg-tech-blue/5 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-32 -left-32 w-64 h-64 bg-pine-green/5 rounded-full blur-3xl"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Top Row: Brand + Newsletter -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mb-14">
            <div>
                <a href="/" class="flex flex-col mb-4">
                    <span class="text-2xl font-bold tracking-tight text-white">TomorrowBeginsHere<span class="text-pine-green">.com</span></span>
                </a>
                <p class="text-slate-400 text-sm leading-relaxed max-w-md mb-6">
                    An independent educational resource dedicated to providing our community with accurate, fact-based information regarding data center development in rural areas.
                </p>
                <div class="flex flex-wrap gap-3 items-center">
                    <a 
                        href="https://www.facebook.com/TomorrowBeginsHere" 
                        target="_blank" 
                        rel="noopener noreferrer" 
                        class="no-external-icon inline-flex items-center gap-2 bg-slate-800 hover:bg-[#1877F2]/20 border border-slate-700 hover:border-[#1877F2]/50 text-slate-300 hover:text-white px-4 py-2.5 rounded-xl text-sm font-semibold transition-all duration-300 shadow-sm group"
                        id="footer-facebook-link"
                    >
                        <svg class="w-5 h-5 text-slate-400 group-hover:text-[#1877F2] transition-colors" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1V12h3v3h-3v6.8c4.56-.93 8-4.96 8-9.8z"/>
                        </svg>
                        Facebook
                    </a>
                    <a 
                        href="https://www.youtube.com/@TomorrowBeginsHere" 
                        target="_blank" 
                        rel="noopener noreferrer" 
                        class="no-external-icon inline-flex items-center gap-2 bg-slate-800 hover:bg-[#FF0000]/20 border border-slate-700 hover:border-[#FF0000]/50 text-slate-300 hover:text-white px-4 py-2.5 rounded-xl text-sm font-semibold transition-all duration-300 shadow-sm group"
                        id="footer-youtube-link"
                    >
                        <svg class="w-5 h-5 text-slate-400 group-hover:text-[#FF0000] transition-colors" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M23.498 6.163a3.003 3.003 0 0 0-2.11-2.11C19.517 3.545 12 3.545 12 3.545s-7.517 0-9.388.508a3.003 3.003 0 0 0-2.11 2.11C0 8.033 0 12 0 12s0 3.967.502 5.837a3.003 3.003 0 0 0 2.11 2.11c1.871.508 9.388.508 9.388.508s7.517 0 9.388-.508a3.003 3.003 0 0 0 2.11-2.11C24 15.967 24 12 24 12s0-3.967-.502-5.837zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                        </svg>
                        YouTube
                    </a>
                    <a 
                        href="https://x.com/tomorrowbh" 
                        target="_blank" 
                        rel="noopener noreferrer" 
                        class="no-external-icon inline-flex items-center gap-2 bg-slate-800 hover:bg-white/10 border border-slate-700 hover:border-white/30 text-slate-300 hover:text-white px-4 py-2.5 rounded-xl text-sm font-semibold transition-all duration-300 shadow-sm group"
                        id="footer-x-link"
                    >
                        <svg class="w-5 h-5 text-slate-400 group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                        </svg>
                        X
                    </a>
                    <a 
                        href="https://www.google.com/preferences/source?q=https://www.tomorrowbeginshere.com" 
                        target="_blank" 
                        rel="noopener noreferrer" 
                        class="no-external-icon inline-flex items-center gap-2 bg-slate-800 hover:bg-[#4285F4]/20 border border-slate-700 hover:border-[#4285F4]/50 text-slate-300 hover:text-white px-4 py-2.5 rounded-xl text-sm font-semibold transition-all duration-300 shadow-sm group"
                        id="footer-google-preferred-source"
                    >
                        <svg class="w-5 h-5 text-slate-400 group-hover:text-[#4285F4] transition-colors" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/>
                            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                        </svg>
                        Add as Preferred Source
                    </a>
                </div>
            </div>

            <!-- Newsletter / Stay Informed CTA -->
            <div class="flex flex-col justify-center">
                <div class="bg-slate-800/50 backdrop-blur-sm border border-slate-700/50 rounded-2xl p-6">
                    <h3 class="text-lg font-bold text-white mb-2">Stay Informed</h3>
                    <p class="text-sm text-slate-400 mb-4">Join our coalition for fact-based updates on data center development in your community.</p>
                    <a href="/join" class="inline-flex items-center justify-center w-full sm:w-auto gap-2 bg-tech-blue hover:bg-tech-blue/90 text-white px-6 py-3 rounded-xl text-sm font-bold transition-all duration-300 shadow-lg hover:shadow-tech-blue/20 hover:scale-[1.02]">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                        Join the Coalition
                    </a>
                </div>
            </div>
        </div>

        <!-- Link Columns (Streamlined) -->
        <div class="grid grid-cols-2 md:grid-cols-3 gap-8 mb-12">
            <div>
                <h3 class="text-sm font-semibold tracking-wider uppercase mb-4 text-slate-300">The Facts</h3>
                <ul class="space-y-2.5">
                    <li><a href="/what-is-a-data-center" class="text-slate-400 hover:text-white transition-colors text-sm">What Is a Data Center?</a></li>
                    <li><a href="/myth-vs-reality" class="text-slate-400 hover:text-white transition-colors text-sm">Myth vs. Reality</a></li>
                    <li><a href="/water-usage" class="text-slate-400 hover:text-white transition-colors text-sm">Water Usage Data</a></li>
                    <li><a href="/closed-loop-cooling" class="text-slate-400 hover:text-white transition-colors text-sm">Closed-Loop Cooling</a></li>
                    <li><a href="/energy-prices" class="text-slate-400 hover:text-white transition-colors text-sm">Energy Prices</a></li>
                    <li><a href="/economic-impact" class="text-slate-400 hover:text-white transition-colors text-sm">Economic Impact</a></li>
                </ul>
            </div>
            
            <div>
                <h3 class="text-sm font-semibold tracking-wider uppercase mb-4 text-slate-300">Explore</h3>
                <ul class="space-y-2.5">
                    <li><a href="/bastrop-county-story" class="text-slate-400 hover:text-white transition-colors text-sm">The Bastrop Story</a></li>
                    <li><a href="/success-stories" class="text-slate-400 hover:text-white transition-colors text-sm">Success Stories</a></li>
                    <li><a href="/careers" class="text-slate-400 hover:text-white transition-colors text-sm">Career Pathways</a></li>
                    <li><a href="/interactive" class="text-slate-400 hover:text-white transition-colors text-sm">Interactive Simulators</a></li>
                    <li><a href="/videos" class="text-slate-400 hover:text-white transition-colors text-sm">Video Library</a></li>
                    <li><a href="/updates" class="text-slate-400 hover:text-white transition-colors text-sm">Latest Updates</a></li>
                </ul>
            </div>
            
            <div>
                <h3 class="text-sm font-semibold tracking-wider uppercase mb-4 text-slate-300">Resources</h3>
                <ul class="space-y-2.5">
                    <li><a href="/faq" class="text-slate-400 hover:text-white transition-colors text-sm">FAQ</a></li>
                    <li><a href="/claim-tracker" class="text-slate-400 hover:text-white transition-colors text-sm">Claim Tracker</a></li>
                    <li><a href="/fact-sheet" class="text-slate-400 hover:text-white transition-colors text-sm">Printable Fact Sheet</a></li>
                    <li><a href="/sources" class="text-slate-400 hover:text-white transition-colors text-sm">Official Sources</a></li>
                    <li><a href="/pro-data-center-sites" class="text-slate-400 hover:text-white transition-colors text-sm">Pro-Data Center Sites</a></li>
                    <li><a href="/about" class="text-slate-400 hover:text-white transition-colors text-sm">About This Site</a></li>
                    <li><a href="mailto:contact@tomorrowbeginshere.com" class="text-tech-blue-light hover:text-white transition-colors text-sm font-medium">Contact Us</a></li>
                    <li><a href="/llm.txt" class="text-slate-400 hover:text-white transition-colors text-sm">llm.txt</a></li>
                </ul>
            </div>
        </div>
        
        <!-- Bottom Bar -->
        <div class="border-t border-slate-800 pt-8 flex flex-col md:flex-row justify-between items-center">
            <p class="text-slate-500 text-sm">
                &copy; {new Date().getFullYear()} TomorrowBeginsHere.com. All rights reserved.
            </p>
            <p class="text-slate-500 text-sm mt-4 md:mt-0 flex items-center space-x-2">
                <span>Empowering Rural Communities Through Education and Facts.</span>
            </p>
        </div>
    </div>
</footer>
