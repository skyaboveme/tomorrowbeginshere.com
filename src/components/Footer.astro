                <ul class="space-y-3">
                    <li><a href="/what-is-a-data-center" class="text-slate-400 hover:text-white transition-colors text-sm">What Is a Data Center?</a></li>
                    <li><a href="/advancing-mankind" class="text-slate-400 hover:text-white transition-colors text-sm">Advancing Humanity</a></li>
                    <li><a href="/the-global-race" class="text-slate-400 hover:text-white transition-colors text-sm">The Global Race</a></li>
                    <li><a href="/economic-impact" class="text-slate-400 hover:text-white transition-colors text-sm">Economic Impact</a></li>
                    <li><a href="/success-stories" class="text-slate-400 hover:text-white transition-colors text-sm">Success Stories</a></li>
