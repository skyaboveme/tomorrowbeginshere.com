    'region': ['area', 'community'], 'neighborhood': ['neighborhood', 'community'],
    'rural': ['rural', 'community'], 'resident': ['homeowner', 'resident'],
    'residents': ['homeowner', 'resident'], 'citizen': ['resident'],
    'citizens': ['residents'], 'taxpayer': ['homeowner', 'ratepayer'],
    'taxpayers': ['homeowner', 'ratepayer'],
    'benefit': ['benefits', 'advantage'], 'advantage': ['benefits', 'advantage'],
    'downside': ['cons', 'risk'], 'drawback': ['cons', 'risk'],
    'con': ['cons'], 'cons': ['cons', 'risk'],
    'negative': ['cons', 'bad'], 'negatives': ['cons', 'bad'],
    'problem': ['concern', 'risk'], 'problems': ['concerns', 'risk'],
    'issue': ['concern'], 'issues': ['concerns'],
    'worried': ['concern', 'worried'], 'scary': ['fear', 'scare'],
    'frightening': ['fear', 'scare'], 'terrifying': ['fear', 'scare'],
  };

  function normalizeText(text) {
    return text.toLowerCase().replace(/[^\w\s]/g, '').replace(/\s+/g, ' ').trim();
  }

  function tokenize(text) {
    return normalizeText(text).split(/\s+/).filter(w => w.length > 0);
  }

  // Remove stop words but preserve meaningful short words
  function removeStopWords(tokens) {
    const meaningful = tokens.filter(t => !STOP_WORDS.has(t));
    // If removing stop words leaves nothing, keep original tokens
    return meaningful.length > 0 ? meaningful : tokens;
  }

  // Expand tokens with synonyms
  function expandWithSynonyms(tokens) {
    const expanded = new Set(tokens);
    for (const token of tokens) {
      if (SYNONYM_MAP[token]) {
        for (const syn of SYNONYM_MAP[token]) {
          expanded.add(syn);
        }
      }
    }
    return Array.from(expanded);
  }

  // Simple Levenshtein distance for fuzzy matching
  function levenshtein(a, b) {
    if (a.length === 0) return b.length;
    if (b.length === 0) return a.length;
    const matrix = [];
    for (let i = 0; i <= b.length; i++) matrix[i] = [i];
    for (let j = 0; j <= a.length; j++) matrix[0][j] = j;
    for (let i = 1; i <= b.length; i++) {
      for (let j = 1; j <= a.length; j++) {
        const cost = b.charAt(i - 1) === a.charAt(j - 1) ? 0 : 1;
        matrix[i][j] = Math.min(
          matrix[i - 1][j] + 1,
          matrix[i][j - 1] + 1,
          matrix[i - 1][j - 1] + cost
        );
      }
    }
    return matrix[b.length][a.length];
  }

  // Check if two words are fuzzy-equal (allows 1-2 char typos depending on length)
  function fuzzyMatch(word, keyword) {
    if (word === keyword) return 3; // Exact
    if (word.length < 3 || keyword.length < 3) return 0; // Too short for fuzzy
    if (word.startsWith(keyword) || keyword.startsWith(word)) return 2.5; // Prefix
    const maxDist = word.length <= 4 ? 1 : 2;
    const dist = levenshtein(word, keyword);
    if (dist <= maxDist) return 2; // Fuzzy match
    if (word.includes(keyword) || keyword.includes(word)) return 1.5; // Substring
    return 0;
  }

  function findBestMatch(input) {
    const normalized = normalizeText(input);
    const rawTokens = tokenize(input);

    if (rawTokens.length === 0) return null;

    // Check greeting/thanks/goodbye first
    if (GREETING_PATTERNS.some(g => normalized.includes(g))) return { type: 'greeting' };
    if (THANKS_PATTERNS.some(t => normalized.includes(t))) return { type: 'thanks' };
    if (GOODBYE_PATTERNS.some(g => normalized.includes(g))) return { type: 'goodbye' };

    // Process tokens
    const cleanTokens = removeStopWords(rawTokens);
    const expandedTokens = expandWithSynonyms(cleanTokens);

    let bestScore = 0;
    let bestEntry = null;

    for (const entry of KNOWLEDGE_BASE) {
      let score = 0;
      const matchedKeywords = new Set();

      for (const keyword of entry.keywords) {
        const kwTokens = keyword.split(/\s+/);

        if (kwTokens.length > 1) {
          // Multi-word keyword — check if phrase appears in normalized input
          if (normalized.includes(keyword.toLowerCase())) {
            score += kwTokens.length * 4; // Phrase matches are very valuable
            matchedKeywords.add(keyword);
          }
        } else {
          // Single word keyword — check against expanded tokens
          const kw = keyword.toLowerCase();
          let bestWordScore = 0;

          for (const token of expandedTokens) {
            const wordScore = fuzzyMatch(token, kw);
            if (wordScore > bestWordScore) {
              bestWordScore = wordScore;
            }
          }

          if (bestWordScore > 0) {
            score += bestWordScore;
            matchedKeywords.add(keyword);
          }
        }
      }

      // Bonus: diversity of matched keywords (hitting multiple keywords is better)
      if (matchedKeywords.size >= 2) {
        score += matchedKeywords.size * 1.5;
      }

      // Bonus: if the user's input closely matches the canonical question
      const qTokens = removeStopWords(tokenize(entry.question));
      let qOverlap = 0;
      for (const qt of qTokens) {
        if (expandedTokens.some(t => fuzzyMatch(t, qt) >= 2)) {
          qOverlap++;
        }
      }
      if (qOverlap > 0) {
        score += qOverlap * 2;
      }

      if (score > bestScore) {
        bestScore = score;
        bestEntry = entry;
      }
    }

    // Adaptive threshold based on meaningful token count
    const meaningfulCount = cleanTokens.length;
    let threshold;
    if (meaningfulCount <= 1) {
      threshold = 2.5; // Single word: lower bar (e.g., "water", "jobs", "noise")
    } else if (meaningfulCount <= 3) {
      threshold = 3; // Short phrase
    } else {
      threshold = 4; // Full question
    }

    if (bestScore >= threshold && bestEntry) {
      return { type: 'answer', entry: bestEntry };
    }

    return null;
  }

  // ========================================
  // UI CONTROLLER
  // ========================================

  const triggerBtn = document.getElementById('chatbot-trigger');
  const panel = document.getElementById('chatbot-panel');
  const overlay = document.getElementById('chatbot-overlay');
  const closeBtn = document.getElementById('chatbot-close');
  const resetBtn = document.getElementById('chatbot-reset');
  const messagesEl = document.getElementById('chatbot-messages');
  const suggestionsEl = document.getElementById('chatbot-suggestions');
  const inputEl = document.getElementById('chatbot-input');
  const sendBtn = document.getElementById('chatbot-send');
  const typingEl = document.getElementById('chatbot-typing');
  const badgeEl = document.getElementById('chatbot-badge');

  let isOpen = false;
  let messages = []; // { sender: 'bot'|'user', html: string, time: string }
  let hasInteracted = false;

  // --- Session persistence ---
  function saveSession() {
    try {
      sessionStorage.setItem('chatbot-messages', JSON.stringify(messages));
      sessionStorage.setItem('chatbot-open', isOpen ? '1' : '0');
    } catch (e) { /* silently fail */ }
  }

  function loadSession() {
    try {
      const saved = sessionStorage.getItem('chatbot-messages');
      if (saved) {
        messages = JSON.parse(saved);
        return true;
      }
    } catch (e) { /* silently fail */ }
    return false;
  }

  // --- Time formatting ---
  function getTimeString() {
    const now = new Date();
    return now.toLocaleTimeString([], { hour: 'numeric', minute: '2-digit' });
  }

  // --- Render messages ---
  function renderMessages() {
    // Remove all messages except typing indicator
    const children = Array.from(messagesEl.children);
    children.forEach(child => {
      if (child.id !== 'chatbot-typing') child.remove();
    });

    messages.forEach(msg => {
      const div = document.createElement('div');
      div.className = `chatbot-msg chatbot-msg-${msg.sender}`;

      const bubble = document.createElement('div');
      bubble.className = `chatbot-bubble chatbot-bubble-${msg.sender}`;

      if (msg.sender === 'bot') {
        bubble.innerHTML = msg.html;
      } else {
        bubble.textContent = msg.html;
      }

      const wrapper = document.createElement('div');
      wrapper.appendChild(bubble);

      const time = document.createElement('div');
      time.className = 'chatbot-msg-time';
      time.textContent = msg.time;
      wrapper.appendChild(time);

      div.appendChild(wrapper);
      messagesEl.insertBefore(div, typingEl);
    });

    scrollToBottom();
  }

  function appendMessage(sender, html) {
    const msg = { sender, html, time: getTimeString() };
    messages.push(msg);
    saveSession();

    const div = document.createElement('div');
    div.className = `chatbot-msg chatbot-msg-${sender}`;

    const bubble = document.createElement('div');
    bubble.className = `chatbot-bubble chatbot-bubble-${sender}`;

    if (sender === 'bot') {
      bubble.innerHTML = html;
    } else {
      bubble.textContent = html;
    }

    const wrapper = document.createElement('div');
    wrapper.appendChild(bubble);

    const time = document.createElement('div');
    time.className = 'chatbot-msg-time';
    time.textContent = msg.time;
    wrapper.appendChild(time);

    div.appendChild(wrapper);
    messagesEl.insertBefore(div, typingEl);
    scrollToBottom();
  }

  function scrollToBottom() {
    requestAnimationFrame(() => {
      messagesEl.scrollTop = messagesEl.scrollHeight;
    });
  }

  // --- Learn more link HTML ---
  function learnMoreHTML(pageLink, pageName) {
    return `<a class="chatbot-learn-more" href="${pageLink}">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="14" height="14">
        <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
      </svg>
      📖 Learn more: ${pageName}
    </a>`;
  }

  // --- Show suggestions ---
  function showSuggestions(questions) {
    suggestionsEl.innerHTML = '';
    questions.forEach(q => {
      const btn = document.createElement('button');
      btn.className = 'chatbot-suggestion';
      btn.textContent = q;
      btn.addEventListener('click', () => handleUserInput(q));
      suggestionsEl.appendChild(btn);
    });
  }

  function showFollowUpSuggestions(entryIds) {
    const questions = entryIds
      .map(id => KNOWLEDGE_BASE.find(e => e.id === id))
      .filter(Boolean)
      .map(e => e.question);
    if (questions.length > 0) {
      showSuggestions(questions);
    } else {
      showSuggestions(getRandomSuggestions(3));
    }
  }

  function getRandomSuggestions(count) {
    const shuffled = [...INITIAL_SUGGESTIONS].sort(() => Math.random() - 0.5);
    return shuffled.slice(0, count);
  }

  // --- Typing indicator ---
  function showTyping() {
    typingEl.style.display = 'flex';
    scrollToBottom();
  }

  function hideTyping() {
    typingEl.style.display = 'none';
  }

  // --- Handle user input ---
  function handleUserInput(text) {
    const trimmed = text.trim();
    if (!trimmed) return;

    hasInteracted = true;
    appendMessage('user', trimmed);
    suggestionsEl.innerHTML = '';
    inputEl.value = '';

    // Show typing indicator
    showTyping();

    // Simulate thinking delay (200–500ms)
    const delay = 250 + Math.random() * 250;
    setTimeout(() => {
      hideTyping();
      const match = findBestMatch(trimmed);
      respondToMatch(match);
    }, delay);
  }

  function respondToMatch(match) {
    if (!match) {
      // Fallback
      appendMessage('bot', `That's a thoughtful question! While I don't have a specific answer for that topic, I encourage you to explore our resources or reach out to us directly at <strong><a href="mailto:contact@tomorrowbeginshere.com" style="color:#0A369D;">contact@tomorrowbeginshere.com</a></strong>. Is there something else I can help with?`);
      showSuggestions(getRandomSuggestions(4));
      return;
    }

    if (match.type === 'greeting') {
      appendMessage('bot', `Hello! 👋 Welcome to TomorrowBeginsHere.com. I'm here to answer your questions about data centers with <strong>verified facts and real data</strong>. What would you like to know?`);
      showSuggestions(getRandomSuggestions(4));
      return;
    }

    if (match.type === 'thanks') {
      appendMessage('bot', `You're welcome! 😊 I'm glad I could help. Remember, all the facts I share come from <strong>verified sources</strong> linked on our site. Is there anything else you'd like to know about data centers?`);
      showSuggestions(getRandomSuggestions(3));
      return;
    }

    if (match.type === 'goodbye') {
      appendMessage('bot', `Thanks for chatting! 👋 Remember, you can always come back with more questions. The facts are here whenever you need them. Have a great day!`);
      suggestionsEl.innerHTML = '';
      return;
    }

    if (match.type === 'answer') {
      const entry = match.entry;
      const answerHTML = entry.answer + learnMoreHTML(entry.pageLink, entry.pageName);
      appendMessage('bot', answerHTML);
      if (entry.followUp && entry.followUp.length > 0) {
        showFollowUpSuggestions(entry.followUp);
      } else {
        showSuggestions(getRandomSuggestions(3));
      }
    }
  }

  // --- Open / Close ---
  function openChat() {
    isOpen = true;
    panel.classList.add('chatbot-open');
    triggerBtn.classList.add('chatbot-hidden');
    badgeEl.style.display = 'none';

    if (window.innerWidth <= 640) {
      overlay.classList.add('chatbot-overlay-visible');
    }

    inputEl.focus();
    saveSession();
    scrollToBottom();
  }

  function closeChat() {
    isOpen = false;
    panel.classList.remove('chatbot-open');
    triggerBtn.classList.remove('chatbot-hidden');
    overlay.classList.remove('chatbot-overlay-visible');
    saveSession();
  }

  function resetChat() {
    messages = [];
    hasInteracted = false;
    renderMessages();
    sessionStorage.removeItem('chatbot-messages');
    showWelcome();
  }

  // --- Welcome message ---
  function showWelcome() {
    appendMessage('bot', `👋 Hi! I'm <strong>TomorrowBot</strong>, your guide to understanding data centers. Ask me anything about water usage, energy, jobs, taxes, noise, or what's happening in Bastrop County.<br><br>Tap a question below to get started, or type your own!`);
    showSuggestions(INITIAL_SUGGESTIONS.slice(0, 4));
  }

  // --- Initialize ---
  function init() {
    const hadSession = loadSession();

    if (hadSession && messages.length > 0) {
      renderMessages();
      showSuggestions(getRandomSuggestions(3));
      // Restore open state
      const wasOpen = sessionStorage.getItem('chatbot-open');
      if (wasOpen === '1') {
        openChat();
      }
    } else {
      showWelcome();
    }
  }

  // --- Event Listeners ---
  triggerBtn.addEventListener('click', openChat);
  closeBtn.addEventListener('click', closeChat);
  resetBtn.addEventListener('click', resetChat);
  overlay.addEventListener('click', closeChat);

  sendBtn.addEventListener('click', () => {
    handleUserInput(inputEl.value);
  });

  inputEl.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      handleUserInput(inputEl.value);
    }
  });

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isOpen) {
      closeChat();
    }
  });

  // Show attention badge after 8 seconds if user hasn't interacted
  setTimeout(() => {
    if (!hasInteracted && !isOpen) {
      badgeEl.style.display = 'block';
    }
  }, 8000);

  // Initialize
  init();
</script>
