---
// LeadCaptureForm.astro
---

<div class="bg-slate-900 rounded-3xl p-8 sm:p-12 lg:p-16 border-t-4 border-tech-blue shadow-2xl relative overflow-hidden" id="join-form">
    <!-- Background Accents -->
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-gradient-to-bl from-tech-blue/20 to-transparent rounded-full blur-3xl translate-x-1/3 -translate-y-1/3 pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-gradient-to-tr from-pine-green/20 to-transparent rounded-full blur-3xl -translate-x-1/3 translate-y-1/3 pointer-events-none"></div>
    
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center relative z-10">
        
        <!-- Text Content -->
        <div class="text-center lg:text-left">
            <span class="inline-block px-4 py-1.5 rounded-full bg-tech-blue/20 text-tech-blue font-bold tracking-widest uppercase text-xs mb-4 border border-tech-blue/30 backdrop-blur-sm">Take Action</span>
            <h2 class="text-3xl md:text-4xl lg:text-5xl font-black text-white tracking-tight mb-6">
                Stand for Rural Prosperity
            </h2>
            <p class="text-lg text-slate-300 leading-relaxed mb-8 max-w-xl mx-auto lg:mx-0">
                Don't let loud, out-of-state activists decide the future of our county. Join the coalition of local residents, business owners, and taxpayers supporting infrastructure, tax relief, and progress.
            </p>
            
            <ul class="space-y-4 text-left inline-block">
                <li class="flex items-center text-slate-300">
                    <svg class="w-5 h-5 text-pine-green mr-3 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    Get instant fact-checks on new opposition claims
                </li>
                <li class="flex items-center text-slate-300">
                    <svg class="w-5 h-5 text-pine-green mr-3 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    Receive urgent alerts before City Council votes
                </li>
                <li class="flex items-center text-slate-300">
                    <svg class="w-5 h-5 text-pine-green mr-3 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    Join a community demanding lower taxes through commercial growth
                </li>
            </ul>
        </div>
        
        <!-- Form -->
        <div class="bg-white rounded-2xl p-6 sm:p-8 shadow-xl">
            <form action="https://formsubmit.co/skyabove@gmail.com" method="POST" class="space-y-5">
                <!-- FormSubmit Configuration -->
                <input type="hidden" name="_subject" value="New Coalition Member - TomorrowBeginsHere">
                <input type="hidden" name="_captcha" value="false">
                <!-- Using the redirect to send them to a thank you or back to home -->
                <input type="hidden" name="_next" value="https://tomorrowbeginshere.com/join?success=true">
                
                <div>
                    <label for="name" class="block text-sm font-bold text-slate-700 mb-1">Full Name <span class="text-red-500">*</span></label>
                    <input type="text" id="name" name="name" required class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:ring-2 focus:ring-tech-blue focus:border-tech-blue outline-none transition-all text-slate-900 bg-slate-50 focus:bg-white" placeholder="John Doe">
                </div>
                
                <div>
                    <label for="email" class="block text-sm font-bold text-slate-700 mb-1">Email Address <span class="text-red-500">*</span></label>
                    <input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:ring-2 focus:ring-tech-blue focus:border-tech-blue outline-none transition-all text-slate-900 bg-slate-50 focus:bg-white" placeholder="john@example.com">
                </div>
                
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label for="zip" class="block text-sm font-bold text-slate-700 mb-1">Zip Code <span class="text-red-500">*</span></label>
                        <input type="text" id="zip" name="zip_code" required class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:ring-2 focus:ring-tech-blue focus:border-tech-blue outline-none transition-all text-slate-900 bg-slate-50 focus:bg-white" placeholder="78602">
                    </div>
                    <div>
                        <label for="role" class="block text-sm font-bold text-slate-700 mb-1">I am a...</label>
                        <select id="role" name="role" class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:ring-2 focus:ring-tech-blue focus:border-tech-blue outline-none transition-all text-slate-900 bg-slate-50 focus:bg-white cursor-pointer appearance-none">
                            <option value="Resident">Resident / Taxpayer</option>
                            <option value="Business Owner">Local Business Owner</option>
                            <option value="Community Leader">Community Leader</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                </div>
                
                <button type="submit" class="w-full bg-tech-blue hover:bg-tech-blue/90 text-white font-bold text-lg py-4 px-6 rounded-xl shadow-lg hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300 mt-2 flex items-center justify-center group">
                    Join the Coalition
                    <svg class="w-5 h-5 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                </button>
                
                <p class="text-xs text-center text-slate-500 mt-4">We respect your privacy. No spam. Unsubscribe at any time.</p>
            </form>
        </div>
        
    </div>
</div>
