---
// ComputeCompactor.astro
// Interactive slider comparing compute power, footprint, and cost through history.
---

<div class="my-16 bg-white border border-slate-200 rounded-[2rem] p-6 lg:p-10 shadow-lg relative overflow-hidden" id="compute-compactor">
    <div class="absolute top-0 left-0 w-64 h-64 bg-amber-500/5 rounded-full blur-3xl -translate-y-1/2 -translate-x-1/2 pointer-events-none"></div>
    <div class="absolute bottom-0 right-0 w-64 h-64 bg-tech-blue/5 rounded-full blur-3xl translate-y-1/2 translate-x-1/2 pointer-events-none"></div>
    
    <div class="relative z-10 max-w-5xl mx-auto">
        
        <!-- Header -->
        <div class="text-center mb-10">
            <span class="inline-block px-4 py-1.5 rounded-full bg-amber-500/10 text-amber-600 font-bold tracking-widest uppercase text-xs mb-4 border border-amber-500/20">Compute Compactor</span>
            <h3 class="text-2xl sm:text-3xl font-black text-slate-900 mb-2 tracking-tight">The Compaction of Compute Power</h3>
            <p class="text-slate-600 text-sm max-w-xl mx-auto">
                Drag the slider to see how data processing has shrunk in size and exploded in power over the decades.
            </p>
        </div>

        <!-- Slider Control -->
        <div class="max-w-3xl mx-auto mb-12 px-4">
            <div class="relative mb-6">
                <!-- Custom slider track ticks -->
                <div class="absolute left-0 right-0 top-1/2 -translate-y-1/2 h-1 bg-slate-100 rounded-full z-0 flex justify-between">
                    <span class="w-3 h-3 rounded-full bg-slate-300 -translate-y-1"></span>
                    <span class="w-3 h-3 rounded-full bg-slate-300 -translate-y-1"></span>
                    <span class="w-3 h-3 rounded-full bg-slate-300 -translate-y-1"></span>
                    <span class="w-3 h-3 rounded-full bg-slate-300 -translate-y-1"></span>
                    <span class="w-3 h-3 rounded-full bg-slate-300 -translate-y-1"></span>
                </div>
                <!-- Range Input -->
                <input 
                    type="range" 
                    min="0" 
                    max="4" 
                    value="4" 
                    step="1" 
                    id="compactor-slider" 
                    class="w-full h-2 rounded-lg bg-transparent appearance-none cursor-pointer relative z-10 accent-tech-blue focus:outline-none"
                    style="-webkit-appearance: none;"
                />
            </div>
            
            <!-- Timeline Labels -->
            <div class="flex justify-between text-xs font-black text-slate-400 tracking-wider uppercase px-1">
                <span class="text-center w-10">1945</span>
                <span class="text-center w-10">1965</span>
                <span class="text-center w-10">1985</span>
                <span class="text-center w-10">2006</span>
                <span class="text-center w-10 text-tech-blue font-bold">2026</span>
            </div>
        </div>

        <!-- Dashboard Display Area -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch bg-slate-50 border border-slate-200 p-6 sm:p-8 rounded-2xl">
            
            <!-- Left Info Pane (5 cols) -->
            <div class="lg:col-span-5 flex flex-col justify-between items-center text-center lg:text-left lg:items-start border-b lg:border-b-0 lg:border-r border-slate-200 pb-6 lg:pb-0 lg:pr-8">
                <div class="w-full">
                    <!-- Dynamic Image Container -->
                    <div class="aspect-video w-full rounded-2xl overflow-hidden mb-6 bg-white border border-slate-200/60 shadow-sm relative mx-auto lg:mx-0" id="compactor-img-container">
                        <img src="/images/history/ai-gpu.png" alt="Modern AI GPU Cluster" class="w-full h-full object-cover transition-opacity duration-300" id="compactor-img" />
                    </div>
                    <span class="inline-block px-3 py-1 rounded bg-tech-blue/10 text-tech-blue font-bold uppercase text-[9px] tracking-wider mb-2" id="compactor-era-label">2026+ (AI GPU Era)</span>
                    <h4 class="text-2xl font-black text-slate-800 tracking-tight mb-2" id="compactor-system-name">Modern AI GPU Cluster</h4>
                    <p class="text-slate-500 text-xs font-semibold leading-relaxed max-w-sm mx-auto lg:mx-0" id="compactor-system-desc">
                        A super-dense server chassis equipped with advanced accelerators (e.g. NVIDIA H100) running complex generative calculations.
                    </p>
                </div>
                
                <!-- Dynamic Quote -->
                <div class="mt-6 bg-amber-50 border border-amber-100 rounded-xl p-4 w-full">
                    <p class="text-[10px] font-bold text-amber-800 uppercase tracking-widest mb-1">Compression Fact</p>
                    <p class="text-slate-700 text-xs leading-relaxed font-medium" id="compactor-fact">
                        "A single modern AI GPU cluster performs more calculations in 1 microsecond than ENIAC could perform if it ran continuously for 6,000 years."
                    </p>
                </div>
            </div>

            <!-- Right Info Pane (7 cols) -->
            <div class="lg:col-span-7 flex flex-col justify-between pl-0 lg:pl-4 mt-6 lg:mt-0">
                <h4 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-4 text-center lg:text-left">System Specifications</h4>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 flex-grow">
                    <!-- Stat 1: Speed -->
                    <div class="bg-white border border-slate-200/60 p-4 rounded-xl shadow-sm flex items-start gap-3">
                        <span class="text-xl">⚡</span>
                        <div>
                            <p class="text-[9px] font-bold text-slate-400 uppercase tracking-wider mb-0.5">Calculations Speed</p>
                            <p class="text-lg font-black text-slate-800 leading-tight" id="spec-speed">1,000+ TFLOPs</p>
                            <p class="text-[10px] text-slate-500">Trillion float operations/sec</p>
                        </div>
                    </div>
                    
                    <!-- Stat 2: Footprint -->
                    <div class="bg-white border border-slate-200/60 p-4 rounded-xl shadow-sm flex items-start gap-3">
                        <span class="text-xl">📏</span>
                        <div>
                            <p class="text-[9px] font-bold text-slate-400 uppercase tracking-wider mb-0.5">Physical Footprint</p>
                            <p class="text-lg font-black text-slate-800 leading-tight" id="spec-size">3.5 sq. ft.</p>
                            <p class="text-[10px] text-slate-500">Fits in standard server slot</p>
                        </div>
                    </div>

                    <!-- Stat 3: Weight -->
                    <div class="bg-white border border-slate-200/60 p-4 rounded-xl shadow-sm flex items-start gap-3">
                        <span class="text-xl">⚖️</span>
                        <div>
                            <p class="text-[9px] font-bold text-slate-400 uppercase tracking-wider mb-0.5">System Weight</p>
                            <p class="text-lg font-black text-slate-800 leading-tight" id="spec-weight">80 lbs</p>
                            <p class="text-[10px] text-slate-500">Rack chassis mountable</p>
                        </div>
                    </div>

                    <!-- Stat 4: Cost -->
                    <div class="bg-white border border-slate-200/60 p-4 rounded-xl shadow-sm flex items-start gap-3">
                        <span class="text-xl">💰</span>
                        <div>
                            <p class="text-[9px] font-bold text-slate-400 uppercase tracking-wider mb-0.5">Unit Cost (Adjusted)</p>
                            <p class="text-lg font-black text-slate-800 leading-tight" id="spec-cost">$40,000</p>
                            <p class="text-[10px] text-slate-500">Cost per accelerator cluster unit</p>
                        </div>
                    </div>
                </div>

                <!-- Footnote -->
                <div class="mt-6 text-center lg:text-left">
                    <p class="text-[10px] text-slate-400 leading-relaxed">
                        *Specifications represent order-of-magnitude standard hardware metrics for each era. Cost adjusted for inflation to 2026 USD.
                    </p>
                </div>
            </div>

        </div>

    </div>
</div>

<style>
    /* Styling range input for Webkit browsers */
    #compactor-slider::-webkit-slider-thumb {
        -webkit-appearance: none;
        appearance: none;
        width: 22px;
        height: 22px;
        border-radius: 50%;
        background: var(--color-tech-blue);
        border: 2px solid white;
        box-shadow: 0 4px 6px rgba(10, 54, 157, 0.3);
        cursor: pointer;
        transition: transform 0.15s ease;
    }
    
    #compactor-slider::-webkit-slider-thumb:hover {
        transform: scale(1.15);
    }

    #compactor-slider::-moz-range-thumb {
        width: 20px;
        height: 20px;
        border-radius: 50%;
        background: var(--color-tech-blue);
        border: 2px solid white;
        box-shadow: 0 4px 6px rgba(10, 54, 157, 0.3);
        cursor: pointer;
        transition: transform 0.15s ease;
    }

    #compactor-slider::-moz-range-thumb:hover {
        transform: scale(1.15);
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const sliderData = [
            {
                img: "/images/history/eniac.png",
                era: "1940s – 1950s (First Computer)",
                system: "ENIAC (1945)",
                desc: "The world's first electronic general-purpose computer. It filled a large room, used vacuum tubes, and required manual cable rewiring.",
                fact: "\"A single modern AI GPU cluster performs more calculations in 1 microsecond than ENIAC could perform if it ran continuously for 6,000 years.\"",
                speed: "5,000 Operations/sec",
                speedDetail: "5 KFLOPs (Addition speed)",
                size: "1,800 sq. ft.",
                sizeDetail: "Fills a building or large room",
                weight: "30 Tons",
                weightDetail: "60,000 lbs (Vacuum tubes & frames)",
                cost: "$500,000",
                costDetail: "Custom government research project"
            },
            {
                img: "/images/history/mainframe.png",
                era: "1960s – 1970s (Mainframe Era)",
                system: "IBM System/360 (1965)",
                desc: "Centralized business mainframe. Introduced transistors, standardized computer lines, magnetic core memory, and raised-floor rooms.",
                fact: "\"The physical size shrank by 94% while computing capacity multiplied by 20x, paving the way for the first automated banking systems.\"",
                speed: "100,000 Operations/sec",
                speedDetail: "100 KFLOPs",
                size: "100 sq. ft.",
                sizeDetail: "Size of multiple large wardrobes",
                weight: "1 Ton",
                weightDetail: "2,000 lbs (Heavy steel chassis)",
                cost: "$100,000",
                costDetail: "A corporate asset rented by banks"
            },
            {
                img: "/images/history/pc.png",
                era: "1980s – 1990s (Desktop Era)",
                system: "Personal Computer (1985)",
                desc: "Computing moves out of central rooms onto desks. Microprocessors enable affordable computing for individuals and businesses.",
                fact: "\"Computing decentralized. A desktop computer could fit under a desk and run spreadsheets, briefly making central server rooms look obsolete.\"",
                speed: "1 Million Operations/sec",
                speedDetail: "1 MFLOP (Intel 386 level)",
                size: "4 sq. ft.",
                sizeDetail: "Fits on a standard home desk",
                weight: "30 lbs",
                weightDetail: "Easy for a single person to lift",
                cost: "$3,000",
                costDetail: "Affordable for family or business"
            },
            {
                img: "/images/history/cloud.png",
                era: "2006 – 2020s (Cloud Era)",
                system: "Standard Cloud Rack Server (2006)",
                desc: "Computing centralizes again. Companies rent processing power from scale providers instead of buying their own hardware.",
                fact: "\"Rack servers are modular and dense. A single server drawer computes 10,000x faster than a desktop, allowing hosting of websites and early web apps.\"",
                speed: "10 Billion Operations/sec",
                speedDetail: "10 GFLOPs (Intel Xeon rack server)",
                size: "1.7 sq. ft.",
                sizeDetail: "Standard 19-inch server rack tray",
                weight: "25 lbs",
                weightDetail: "Mountable inside server cabinets",
                cost: "$2,000",
                costDetail: "Mass-produced commodity hardware"
            },
            {
                img: "/images/history/ai-gpu.png",
                era: "2026+ (AI GPU Era)",
                system: "Modern AI GPU Cluster (2026)",
                desc: "Super-dense server chassis packed with specialized accelerators designed for neural network processing at scale.",
                fact: "\"Training modern AI requires extreme computational density, compressing massive supercomputers into modular server racks.\"",
                speed: "1,000+ TFLOPs",
                speedDetail: "Trillion float operations/sec",
                size: "3.5 sq. ft.",
                sizeDetail: "Dense rack-mounted GPU chassis",
                weight: "80 lbs",
                weightDetail: "High-density heavy copper sinks",
                cost: "$40,000",
                costDetail: "Cost per accelerator unit card/tray"
            }
        ];

        const slider = document.getElementById('compactor-slider') as HTMLInputElement;
        const imgEl = document.getElementById('compactor-img') as HTMLImageElement;
        const eraEl = document.getElementById('compactor-era-label');
        const nameEl = document.getElementById('compactor-system-name');
        const descEl = document.getElementById('compactor-system-desc');
        const factEl = document.getElementById('compactor-fact');
        
        const speedEl = document.getElementById('spec-speed');
        const speedDetailEl = speedEl?.nextElementSibling;
        const sizeEl = document.getElementById('spec-size');
        const sizeDetailEl = sizeEl?.nextElementSibling;
        const weightEl = document.getElementById('spec-weight');
        const weightDetailEl = weightEl?.nextElementSibling;
        const costEl = document.getElementById('spec-cost');
        const costDetailEl = costEl?.nextElementSibling;

        function updateSlider(index) {
            const data = sliderData[index];
            if (!data) return;

            // Fade animation trigger by toggling opacity class
            const panels = [imgEl, eraEl, nameEl, descEl, factEl, speedEl, sizeEl, weightEl, costEl];
            panels.forEach(p => {
                if (p) {
                    p.classList.add('transition-opacity', 'duration-150', 'opacity-0');
                }
            });

            setTimeout(() => {
                if (imgEl) {
                    imgEl.src = data.img;
                    imgEl.alt = data.system;
                }
                if (eraEl) {
                    eraEl.textContent = data.era;
                    if (index === 4) {
                        eraEl.className = "inline-block px-3 py-1 rounded bg-tech-blue/10 text-tech-blue font-bold uppercase text-[9px] tracking-wider mb-2";
                    } else {
                        eraEl.className = "inline-block px-3 py-1 rounded bg-slate-200 text-slate-700 font-bold uppercase text-[9px] tracking-wider mb-2";
                    }
                }
                if (nameEl) nameEl.textContent = data.system;
                if (descEl) descEl.textContent = data.desc;
                if (factEl) factEl.textContent = data.fact;
                
                if (speedEl) speedEl.textContent = data.speed;
                if (speedDetailEl) speedDetailEl.textContent = data.speedDetail;
                
                if (sizeEl) sizeEl.textContent = data.size;
                if (sizeDetailEl) sizeDetailEl.textContent = data.sizeDetail;
                
                if (weightEl) weightEl.textContent = data.weight;
                if (weightDetailEl) weightDetailEl.textContent = data.weightDetail;
                
                if (costEl) costEl.textContent = data.cost;
                if (costDetailEl) costDetailEl.textContent = data.costDetail;

                panels.forEach(p => {
                    if (p) {
                        p.classList.remove('opacity-0');
                        p.classList.add('opacity-100');
                    }
                });
            }, 150);
        }

        slider?.addEventListener('input', (e) => {
            const val = parseInt((e.target as HTMLInputElement).value);
            updateSlider(val);
        });

        // Initialize with default (index 4)
        updateSlider(4);
    });
</script>
