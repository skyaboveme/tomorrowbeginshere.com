---

<section class="py-24 bg-slate-950 text-white relative overflow-hidden">
  <!-- Glowing Background Accents -->
  <div class="absolute top-1/4 left-1/4 w-[500px] h-[500px] bg-tech-blue/10 rounded-full blur-[120px] pointer-events-none"></div>
  <div class="absolute bottom-1/4 right-1/4 w-[500px] h-[500px] bg-pine-green/10 rounded-full blur-[120px] pointer-events-none"></div>
  
  <!-- Tech Grid Overlay -->
  <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iNDAiIGhlaWdodD0iNDAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+CjxwYXRoIGQ9Ik0wIDBINDBWMHoiIGZpbGw9Im5vbmUiLz4KPHBhdGggZD0iTTAgNDBMMCAwTDQwIDBMMCAwIiBzdHJva2U9InJnYmEoMjU1LDI1NSwyNTUsMC4wMykiIHN0cm9rZS13aWR0aD0iMSIvPgo8L3N2Zz4=')] opacity-30 z-0"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <!-- Header Section -->
    <div class="text-center max-w-3xl mx-auto mb-16 reveal">
      <span class="inline-flex items-center gap-1.5 bg-amber-500/10 text-amber-400 text-xs font-bold uppercase tracking-widest px-4 py-1.5 rounded-full border border-amber-500/20 mb-6">
        <span class="w-1.5 h-1.5 rounded-full bg-amber-400 animate-pulse"></span>
        100 Everyday Moments
      </span>
      <h2 class="heading-display text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-white mb-6">
        100 things you did today<br/>that needed a <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-400 to-rose-400">data center</span>
      </h2>
      <p class="text-lg sm:text-xl text-slate-300 font-light leading-relaxed">
        None of it announces itself. It is just your phone, your card, your everyday life. But every single moment below runs through a building full of servers somewhere. The only question is whether Bastrop County helps build that future, or watches it happen somewhere else.
      </p>
    </div>

    <!-- Carousel Container Wrapper -->
    <div class="relative group/scroll px-4">
      <!-- Navigation Buttons (Hidden on mobile) -->
      <button 
        id="things-prev-btn" 
        class="hidden md:flex absolute -left-4 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-slate-900/90 hover:bg-slate-800 border border-slate-800 text-white items-center justify-center z-20 cursor-pointer shadow-xl transition-all duration-300 hover:scale-105 active:scale-95 disabled:opacity-30 disabled:pointer-events-none" 
        aria-label="Scroll left"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
      </button>
      
      <button 
        id="things-next-btn" 
        class="hidden md:flex absolute -right-4 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-slate-900/90 hover:bg-slate-800 border border-slate-800 text-white items-center justify-center z-20 cursor-pointer shadow-xl transition-all duration-300 hover:scale-105 active:scale-95 disabled:opacity-30 disabled:pointer-events-none" 
        aria-label="Scroll right"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </button>

      <!-- Scrollable Container -->
      <div 
        id="things-container" 
        class="flex gap-6 overflow-x-auto pb-10 scroll-smooth snap-x snap-mandatory cursor-grab active:cursor-grabbing select-none"
        style="scrollbar-width: none; -ms-overflow-style: none;"
      >
        {categories.map((category) => (
          <div class="flex-shrink-0 w-[290px] sm:w-[330px] bg-slate-900/60 backdrop-blur-md rounded-2xl p-6 border border-slate-800/80 hover:border-slate-700/80 transition-all duration-300 snap-start flex flex-col justify-between group/card shadow-xl">
            <div>
              <!-- Card Header -->
              <div class="flex justify-between items-start mb-6">
                <div>
                  <span class="text-xs font-mono font-bold tracking-widest text-slate-500 uppercase">{category.id}</span>
                  <h3 class="text-lg sm:text-xl font-bold text-white mt-1 group-hover/card:text-amber-400 transition-colors">
                    {category.title}
                  </h3>
                </div>
                <div class={`w-10 h-10 rounded-xl border flex items-center justify-center ${category.badgeColor}`} set:html={category.icon}>
                </div>
              </div>
              
              <!-- Card Bullet Items -->
              <ul class="space-y-3">
                {category.items.map((item) => (
                  <li class="flex items-start text-sm text-slate-300 font-light leading-snug">
                    <span class={`w-1.5 h-1.5 rounded-full mt-1.5 mr-3 flex-shrink-0 ${category.bulletColor}`}></span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Scroll Indicator Progress Line -->
    <div class="w-48 h-1 bg-slate-800 rounded-full mx-auto mt-2 relative overflow-hidden">
      <div id="things-progress-bar" class="absolute left-0 top-0 h-full w-0 bg-gradient-to-r from-amber-400 to-tech-blue transition-all duration-100"></div>
    </div>

    <!-- Outro Box -->
    <div class="relative bg-slate-900/40 border border-slate-800/60 rounded-3xl p-8 max-w-4xl mx-auto mt-20 text-center shadow-2xl overflow-hidden reveal">
      <div class="absolute -inset-px bg-gradient-to-r from-amber-500/10 to-tech-blue/10 rounded-3xl blur opacity-30 -z-10"></div>
      <h3 class="text-xl sm:text-2xl font-bold text-white mb-4">We already live on data centers.</h3>
      <p class="text-slate-300 font-light leading-relaxed mb-6 max-w-2xl mx-auto">
        The question was never whether we use them. We do, constantly. The question is where they get built, and who gets the jobs, the tax base, and the future they bring.
      </p>
      <div class="flex justify-center gap-4">
        <a href="/myth-vs-reality" class="inline-flex justify-center items-center px-6 py-3 text-sm font-bold rounded-xl text-slate-950 bg-amber-400 hover:bg-amber-300 transition-colors">
          Learn the Facts
        </a>
        <a href="/bastrop-county-story" class="inline-flex justify-center items-center px-6 py-3 text-sm font-bold rounded-xl text-white bg-slate-800 hover:bg-slate-700 border border-slate-700 transition-colors">
          Bastrop County's Story
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('astro:page-load', () => {
    const container = document.getElementById('things-container');
    const prevBtn = document.getElementById('things-prev-btn') as HTMLButtonElement | null;
    const nextBtn = document.getElementById('things-next-btn') as HTMLButtonElement | null;
    const progressBar = document.getElementById('things-progress-bar');

    if (!container) return;

    // Scroll Progress Handler
    const updateProgress = () => {
      const scrollLeft = container.scrollLeft;
      const maxScroll = container.scrollWidth - container.clientWidth;
      const percent = maxScroll > 0 ? (scrollLeft / maxScroll) * 100 : 0;
      if (progressBar) {
        progressBar.style.width = `${percent}%`;
      }
      
      // Update Buttons
      if (prevBtn) prevBtn.disabled = scrollLeft <= 5;
      if (nextBtn) nextBtn.disabled = scrollLeft >= maxScroll - 5;
    };

    container.addEventListener('scroll', updateProgress, { passive: true });
    window.addEventListener('resize', updateProgress, { passive: true });
    
    // Initial run
    setTimeout(updateProgress, 100);

    // Arrow Button Handlers
    if (prevBtn) {
      prevBtn.addEventListener('click', () => {
        const cardWidth = container.firstElementChild?.clientWidth || 320;
        container.scrollBy({ left: -(cardWidth + 24), behavior: 'smooth' });
      });
    }

    if (nextBtn) {
      nextBtn.addEventListener('click', () => {
        const cardWidth = container.firstElementChild?.clientWidth || 320;
        container.scrollBy({ left: cardWidth + 24, behavior: 'smooth' });
      });
    }

    // Drag-to-scroll implementation (mouse users)
    let isDown = false;
    let startX: number;
    let scrollLeft: number;

    container.addEventListener('mousedown', (e: MouseEvent) => {
      isDown = true;
      container.classList.remove('scroll-smooth'); // Disable smooth scroll while dragging
      startX = e.pageX - container.offsetLeft;
      scrollLeft = container.scrollLeft;
    });

    container.addEventListener('mouseleave', () => {
      isDown = false;
    });

    container.addEventListener('mouseup', () => {
      isDown = false;
      container.classList.add('scroll-smooth'); // Re-enable smooth scroll
    });

    container.addEventListener('mousemove', (e: MouseEvent) => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX - container.offsetLeft;
      const walk = (x - startX) * 1.5; // Scroll speed modifier
      container.scrollLeft = scrollLeft - walk;
    });
  });
</script>
