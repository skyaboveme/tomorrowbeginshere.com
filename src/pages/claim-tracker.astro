<style>
    .filter-pill {
        background: white;
        color: #64748b;
        border-color: #e2e8f0;
    }
    .filter-pill:hover, .filter-pill.active {
        background: #0f172a;
        color: white;
        border-color: #0f172a;
    }
    .status-pill {
        background: white;
        color: #64748b;
        border-color: #e2e8f0;
    }
    .status-pill:hover, .status-pill.active {
        background: #0f172a;
        color: white;
        border-color: #0f172a;
    }
    .claim-card.hidden-by-filter {
        display: none;
    }
    .claim-card .claim-chevron.rotated {
        transform: rotate(180deg);
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const cards = document.querySelectorAll('.claim-card') as NodeListOf<HTMLElement>;
        const categoryBtns = document.querySelectorAll('.filter-pill') as NodeListOf<HTMLElement>;
        const statusBtns = document.querySelectorAll('.status-pill') as NodeListOf<HTMLElement>;
        const noResults = document.getElementById('no-results');

        let activeCategory = 'all';
        let activeStatus = 'all';

        // Accordion toggle
        cards.forEach(card => {
            const toggle = card.querySelector('.claim-toggle');
            const content = card.querySelector('.claim-content');
            const chevron = card.querySelector('.claim-chevron');
            if (toggle && content && chevron) {
                toggle.addEventListener('click', () => {
                    content.classList.toggle('hidden');
                    chevron.classList.toggle('rotated');
                });
            }
        });

        function applyFilters() {
            let visibleCount = 0;
            cards.forEach(card => {
                const cat = card.dataset.category || '';
                const status = card.dataset.status || '';

                const catMatch = activeCategory === 'all' || cat === activeCategory;
                const statusMatch = activeStatus === 'all' || status === activeStatus;

                if (catMatch && statusMatch) {
                    card.classList.remove('hidden-by-filter');
                    visibleCount++;
                } else {
                    card.classList.add('hidden-by-filter');
                }
            });

            if (noResults) {
                noResults.classList.toggle('hidden', visibleCount > 0);
            }
        }

        categoryBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                categoryBtns.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                activeCategory = btn.dataset.category || 'all';
                applyFilters();
            });
        });

        statusBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                statusBtns.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                activeStatus = btn.dataset.status || 'all';
                applyFilters();
            });
        });
    });
</script>
