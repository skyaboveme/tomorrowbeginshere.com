---
import { getCollection } from 'astro:content';
import BaseLayout from '../../components/BaseLayout.astro';
import LeadCaptureForm from '../../components/LeadCaptureForm.astro';

const updates = await getCollection('updates');
// Sort by date descending
updates.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout 
    title="Updates & Fact-Checks | TomorrowBeginsHere.com"
    description="Stay informed with the latest news, updates, and fact-checks regarding data center development and rural prosperity."
>
    <!-- Page Header -->
    <div class="bg-slate-900 border-b border-tech-blue/20 relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-pine-green/80 to-tech-blue/80 z-0 mix-blend-multiply"></div>
        <div class="absolute inset-0 bg-[url('/images/hero-bg.png')] bg-cover bg-center z-0 opacity-20 mix-blend-overlay"></div>
        <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-24 text-center">
            <span class="inline-block px-4 py-1.5 rounded-full bg-tech-blue/20 text-tech-blue font-bold tracking-widest uppercase text-sm mb-6 border border-tech-blue/30 backdrop-blur-sm">Latest News</span>
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 tracking-tight">Updates & Fact-Checks</h1>
            <p class="text-xl text-slate-200 max-w-3xl mx-auto leading-relaxed font-light">
                The latest information, rapid responses to opposition claims, and updates on our community's path forward.
            </p>
        </div>
    </div>

    <!-- Main Content -->
    <section class="py-20 bg-slate-50 relative">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            
            <div class="space-y-10 mb-20">
                {updates.map((post) => (
                    <article class="bg-white rounded-3xl shadow-sm border border-slate-200 overflow-hidden hover:shadow-xl transition-all duration-300 group">
                        <div class="p-8 sm:p-10">
                            <div class="flex items-center gap-3 mb-4">
                                {post.data.tags.map(tag => (
                                    <span class={`text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full ${
                                        tag.toLowerCase().includes('fact check') 
                                        ? 'bg-red-100 text-red-700' 
                                        : 'bg-tech-blue/10 text-tech-blue'
                                    }`}>
                                        {tag}
                                    </span>
                                ))}
                                <span class="text-sm font-medium text-slate-400">
                                    {post.data.pubDate.toLocaleDateString('en-US', {
                                        year: 'numeric',
                                        month: 'short',
                                        day: 'numeric',
                                    })}
                                </span>
                            </div>
                            
                            <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 mb-4 group-hover:text-tech-blue transition-colors">
                                <a href={post.data.externalUrl || `/updates/${post.id}`}>
                                    {post.data.title}
                                </a>
                            </h2>
                            
                            <p class="text-slate-600 text-lg leading-relaxed mb-6">
                                {post.data.description}
                            </p>
                            
                            <a href={post.data.externalUrl || `/updates/${post.id}`} class="inline-flex items-center text-tech-blue font-bold group/link">
                                Read Full Article
                                <svg class="w-5 h-5 ml-2 transform group-hover/link:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                            </a>
                        </div>
                    </article>
                ))}
            </div>

            <!-- Join Form -->
            <LeadCaptureForm />

        </div>
    </section>
</BaseLayout>
