---
import BaseLayout from '../components/BaseLayout.astro';

const sources = [
    {
        title: "Where Is Energy Getting the Most Expensive?",
        organization: "Just Solutions Collective",
        description: "A comprehensive analysis of residential electricity and methane gas price increases across the United States from 2019 to 2024, highlighting regional disparities and infrastructure costs.",
        url: "https://justsolutionscollective.org/where-is-energy-getting-the-most-expensive-electricity-price-increases-hit-some-regions-harder-than-others-but-methane-gas-has-gone-up-nearly-everywhere/",
        category: "Energy Cost Analysis"
    },
    {
        title: "Electricity Data Browser",
        organization: "U.S. Energy Information Administration (EIA)",
        description: "The official federal database tracking retail electricity price and cost trends, generation statistics, and comprehensive energy consumption metrics nationwide.",
        url: "https://www.eia.gov/electricity/data/browser/",
        category: "Federal Data"
    },
    {
        title: "Yearly Peak Demand Records",
        organization: "ERCOT",
        description: "The Electric Reliability Council of Texas' official historical archive documenting the state's rapidly growing grid capacity requirements and record-setting summer peak demands.",
        url: "https://www.ercot.com/static-assets/data/news/content/a-peak-demand/records-yearly-archive.htm",
        category: "Grid Infrastructure"
    }
];
---

<BaseLayout
    title="Sources & References | TomorrowBeginsHere.com"
    description="Explore the authoritative data sources, federal reports, and independent analyses that form the factual foundation of TomorrowBeginsHere.com."
>
    <!-- Hero Section -->
    <header class="relative pt-32 pb-20 lg:pt-40 lg:pb-28 overflow-hidden bg-slate-900 border-b border-tech-blue/20">
        <!-- Abstract gradient background -->
        <div class="absolute inset-0 bg-gradient-to-br from-texas-pine/20 via-slate-900 to-tech-blue/20 z-0"></div>
        <div class="absolute top-0 right-0 w-full h-full bg-[radial-gradient(circle_at_top_right,_var(--tw-gradient-stops))] from-texas-pine/10 via-transparent to-transparent z-0"></div>
        
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
            <div class="max-w-3xl">
                <span class="inline-block px-4 py-1.5 rounded-full bg-slate-800 text-slate-300 font-bold tracking-widest uppercase text-sm mb-6 border border-slate-700 backdrop-blur-sm">Transparency</span>
                <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-white mb-6">
                    Data & References
                </h1>
                <p class="text-xl text-slate-300 leading-relaxed font-light mb-8 max-w-2xl">
                    We are committed to providing our community with accurate, fact-based information. Below is a growing index of the independent analyses, federal databases, and official reports referenced throughout our educational materials.
                </p>
            </div>
        </div>
    </header>

    <!-- Sources Directory -->
    <section class="py-20 bg-slate-50 relative min-h-[50vh]">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {sources.map((source) => (
                    <a href={source.url} target="_blank" rel="noopener noreferrer" class="bg-white rounded-3xl p-8 shadow-sm border border-slate-200 hover:shadow-lg hover:border-tech-blue/30 transition-all duration-300 group flex flex-col h-full relative overflow-hidden">
                        <!-- Top accent line -->
                        <div class="absolute top-0 left-0 w-full h-1 bg-tech-blue scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"></div>
                        
                        <div class="mb-4">
                            <span class="inline-block px-3 py-1 bg-slate-100 text-slate-600 rounded-full text-xs font-bold uppercase tracking-wider mb-4 border border-slate-200">
                                {source.category}
                            </span>
                        </div>
                        
                        <h2 class="text-xl font-bold text-slate-900 mb-2 group-hover:text-tech-blue transition-colors">
                            {source.title}
                        </h2>
                        
                        <h3 class="text-sm font-semibold text-texas-pine uppercase tracking-wider mb-4">
                            {source.organization}
                        </h3>
                        
                        <p class="text-slate-600 leading-relaxed mb-8 flex-grow">
                            {source.description}
                        </p>
                        
                        <div class="mt-auto pt-6 border-t border-slate-100 flex items-center text-tech-blue font-bold text-sm">
                            <span class="group-hover:-translate-y-0.5 transition-transform duration-300">View Source Documentation</span>
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 ml-2 group-hover:translate-x-1 group-hover:-translate-y-1 transition-all">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                            </svg>
                        </div>
                    </a>
                ))}
            </div>
            
            <div class="mt-16 p-8 bg-blue-50 rounded-2xl border border-blue-100 text-center max-w-3xl mx-auto">
                <h3 class="text-lg font-bold text-slate-900 mb-2">Commitment to Accuracy</h3>
                <p class="text-slate-600">
                    This platform relies strictly on peer-reviewed research, official state operator data, and federal reporting. This library will continue to expand as new educational sections are launched.
                </p>
            </div>
        </div>
    </section>
</BaseLayout>
