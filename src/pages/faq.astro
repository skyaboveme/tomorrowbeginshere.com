---
import BaseLayout from '../components/BaseLayout.astro';

const faqs = [
  {
    question: "Will the data center use our town's water supply?",
    answer: "No, these modern facilities are designed to minimize local water impact. They utilize their own advanced water management systems, including closed-loop cooling and the potential use of reclaimed wastewater. To provide context, the total water use of all U.S. data centers combined accounts for less than 0.5% of national freshwater consumption."
  },
  {
    question: "Will the data center raise my electricity bill?",
    answer: "No. In fact, modern data centers are increasingly self-powered through behind-the-meter generation and large-scale battery storage. Furthermore, many states utilize rate structures ensuring that industrial energy users pay for their own infrastructure costs, and these highly advanced facilities can actually contribute stored power back to the local grid during times of peak community demand."
  },
  {
    question: "How many jobs will this create for local residents?",
    answer: "While direct facility employment offers highly specialized, high-paying tech roles, the real impact lies in the economic multiplier. Studies show a 6x multiplier of indirect and induced jobs, meaning the facility actively supports a vast ecosystem of local construction workers, maintenance technicians, local vendors, and associated small businesses throughout the community."
  },
  {
    question: "Will the data center affect my property values?",
    answer: "Data centers are carefully planned and typically built in designated industrial or commercial zones to be quiet, unobtrusive neighbors. Over time, the massive economic growth and highly funded local services (like schools and infrastructure) that these facilities bring to a community tend to strongly support and increase residential property values."
  },
  {
    question: "What happens to the data center if the company leaves?",
    answer: "Data centers are billion-dollar infrastructure commitments designed for 20- to 30-year operational lifespans; they are not short-term investments. In the highly unlikely event of a transition, the incredible physical infrastructure, robust power and fiber connections, and massive property tax base remain firmly rooted in the local community."
  },
  {
    question: "How does this benefit our schools?",
    answer: "A billion-dollar data center campus generates an incredible amount of property tax revenue that flows directly into the local school district. This provides massive, stable funding that can be used for hiring teachers, upgrading facilities, and expanding educational programs, all without requiring painful tax increases on local homeowners."
  }
];

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};
---

<BaseLayout 
    title="Data Center FAQ | Your Questions Answered"
    description="Honest answers to the most common questions about data centers in rural communities, from water use to property values."
    schema={schema}
>
    <!-- Page Header -->
    <div class="bg-slate-900 border-b border-tech-blue/20 relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-tech-blue/90 to-slate-900/90 z-0 mix-blend-multiply"></div>
        <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-24 text-center">
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 tracking-tight">Frequently Asked <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-300 to-teal-200">Questions</span></h1>
            <p class="text-xl text-slate-200 leading-relaxed font-light">
                Honest answers to the most common questions about data center development in our community.
            </p>
        </div>
    </div>

    <!-- Search Bar Section -->
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 -mt-8 relative z-30">
        <div class="bg-white rounded-2xl shadow-lg border border-slate-200/80 p-4">
            <div class="relative">
                <input 
                    type="text" 
                    id="faq-search-input" 
                    placeholder="Search FAQs or ask a question (e.g., 'Will they drain our water?' or 'What is SB 6?')..." 
                    class="w-full pl-12 pr-12 py-4 bg-slate-50 hover:bg-slate-100/50 focus:bg-white rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-tech-blue focus:border-transparent text-slate-800 transition-all text-base sm:text-lg"
                    autocomplete="off"
                />
                <!-- Search Glass SVG Icon on left -->
                <div class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                </div>
                <!-- Clear Button on right -->
                <button 
                    id="faq-clear-btn" 
                    class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600 hidden cursor-pointer focus:outline-none"
                    aria-label="Clear search"
                >
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <section class="py-16 lg:py-24 bg-slate-50 relative">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            
            <!-- AI Answer Engine Output -->
            <div 
                id="ai-response-box" 
                class="hidden bg-slate-900 border border-tech-blue/30 rounded-3xl p-6 sm:p-8 shadow-xl text-white relative overflow-hidden mb-10 transition-all duration-300 transform scale-95 opacity-0"
            >
                <div class="absolute -top-24 -right-24 w-48 h-48 bg-tech-blue/10 rounded-full blur-3xl pointer-events-none"></div>
                <div class="absolute -bottom-24 -left-24 w-48 h-48 bg-pine-green/10 rounded-full blur-3xl pointer-events-none"></div>
                
                <div class="relative z-10">
                    <div class="flex items-center justify-between mb-4">
                        <span class="inline-flex items-center gap-1.5 bg-amber-500/10 text-amber-400 text-[10px] sm:text-xs font-bold uppercase tracking-widest px-3 py-1.5 rounded-full border border-amber-500/20">
                            <span class="w-1.5 h-1.5 rounded-full bg-amber-400 animate-pulse"></span>
                            AI Answer Engine
                        </span>
                    </div>

                    <h3 id="ai-response-question" class="text-lg sm:text-xl font-bold text-white mb-3"></h3>
                    <p id="ai-response-answer" class="text-slate-300 font-light leading-relaxed text-sm sm:text-base mb-6"></p>

                    <div id="ai-response-citation" class="flex items-center gap-2 text-xs sm:text-sm text-slate-400 border-t border-slate-800/80 pt-4">
                        <span>Source:</span>
                        <a id="ai-response-link" href="#" class="text-amber-400 hover:underline font-bold inline-flex items-center gap-1">
                            <span id="ai-response-link-text"></span>
                            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                            </svg>
                        </a>
                    </div>
                </div>
            </div>

            <!-- No Results Panel -->
            <div id="no-results-box" class="hidden text-center py-12 bg-white border border-slate-200 shadow-sm rounded-2xl p-8 mb-10">
                <svg class="w-12 h-12 text-slate-400 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <h4 class="text-lg font-bold text-slate-900 mb-2">No matching questions found</h4>
                <p class="text-sm text-slate-500">Try searching for keywords like "water", "electricity", "taxes", or "jobs".</p>
            </div>

            <!-- Accordion List -->
            <div class="space-y-6" id="faq-accordion-list">
                {faqs.map((faq, index) => (
                    <details class="faq-details-item group bg-white border border-slate-200 shadow-sm rounded-2xl [&_summary::-webkit-details-marker]:hidden open:shadow-md transition-all duration-300">
                        <summary class="flex cursor-pointer items-center justify-between gap-1.5 p-6 lg:p-8 text-slate-900 select-none">
                            <h2 class="faq-question-text font-bold text-xl lg:text-2xl pr-8">{faq.question}</h2>

                            <span class="relative size-6 shrink-0 bg-tech-blue/5 rounded-full flex items-center justify-center text-tech-blue">
                                <svg xmlns="http://www.w3.org/2000/svg" class="absolute inset-0 m-auto size-5 opacity-100 group-open:opacity-0 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                                </svg>
                                <svg xmlns="http://www.w3.org/2000/svg" class="absolute inset-0 m-auto size-5 opacity-0 group-open:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M20 12H4" />
                                </svg>
                            </span>
                        </summary>

                        <div class="faq-answer-container px-6 pb-8 lg:px-8 bg-slate-50/50 rounded-b-2xl border-t border-slate-100">
                            <p class="faq-answer-text mt-4 leading-relaxed text-slate-600 text-lg">
                                {faq.answer}
                            </p>
                        </div>
                    </details>
                ))}
            </div>

            <div class="mt-20 pt-16 border-t border-slate-200 text-center bg-white rounded-3xl p-10 border shadow-sm">
                <div class="w-16 h-16 bg-pine-green/10 rounded-full flex items-center justify-center mx-auto mb-6 text-pine-green">
                    <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                    </svg>
                </div>
                <h3 class="text-2xl font-bold mb-4 text-slate-900">Still have a question?</h3>
                <p class="text-slate-600 mb-8 max-w-xl mx-auto">We are committed to honest engagement and transparent conversations. If you have a question not covered here, we'd love to hear from you.</p>
                <a href="mailto:contact@tomorrowbeginshere.com" class="inline-flex items-center justify-center px-8 py-4 text-white bg-pine-green hover:bg-slate-900 font-bold rounded-xl shadow-md transition-all duration-300 hover:shadow-xl text-lg">
                    Contact Us Direct
                </a>
            </div>
            
        </div>
    </section>
</BaseLayout>

<style>
    /* Smooth accordion animation */
    details > div {
        animation: slideDown 0.3s ease-out;
    }
    
    @keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<script>
  // Complete local Q&A knowledge base aligned with TomorrowBot
  const KNOWLEDGE_BASE = [
    {
      id: 'water-usage',
      keywords: ['water', 'drain', 'supply', 'aquifer', 'groundwater', 'drinking water', 'water usage', 'thirsty', 'water table', 'depletion', 'dry up', 'well water', 'use water', 'consume water', 'water consumption', 'gallons', 'waste water', 'water resources', 'freshwater', 'reservoir', 'lake', 'river', 'creek', 'wells', 'well', 'springs', 'drought'],
      question: 'Will the data center drain our water?',
      answer: `<strong>No — data centers do not drain local water supplies.</strong> All U.S. data centers combined use <strong>less than 0.5%</strong> of national freshwater. Modern facilities use closed-loop cooling systems that continuously recycle water with near-zero evaporation. A single 18-hole golf course uses about <strong>114 million gallons/year</strong> — more than 20x what a modern data center uses (~5 million gal/year).`,
      pageLink: '/water-usage',
      pageName: 'Water Usage Data'
    },
    {
      id: 'closed-loop-cooling',
      keywords: ['cooling', 'closed loop', 'evaporation', 'coolant', 'heat', 'cooling tower', 'evaporative', 'air cooling', 'liquid cooling', 'immersion', 'temperature', 'hot', 'cold', 'thermal', 'hvac', 'chiller', 'refrigerant', 'heat exchange', 'radiator'],
      question: 'How does data center cooling work?',
      answer: `Modern data centers use <strong>closed-loop cooling</strong> — a sealed system where water is continuously recycled, not consumed. Heat generated by servers is absorbed by coolant, run through heat exchangers, and recirculated. Modern closed-loop architectures reduce water consumption by <strong>95%+</strong> compared to old-style evaporative towers.`,
      pageLink: '/closed-loop-cooling',
      pageName: 'Closed-Loop Cooling'
    },
    {
      id: 'water-comparison',
      keywords: ['golf course', 'subdivision', 'agriculture', 'irrigation', 'compared', 'comparison', 'more water', 'less water', 'how much water', 'versus', 'vs', 'farm', 'farming', 'housing development', 'swimming pool'],
      question: 'How does water use compare to other things?',
      answer: `Data centers are among the <strong>lowest</strong> industrial water users. Compare annual usage:<br>• Modern data center: <strong>~5 million gal</strong><br>• 18-hole golf course: <strong>~114 million gal</strong><br>• 1,000-home subdivision: <strong>~110 million gal</strong><br>• U.S. agricultural irrigation: <strong>50% of all freshwater</strong> (100x data centers).`,
      pageLink: '/water-usage',
      pageName: 'Water Usage Data'
    },
    {
      id: 'energy-bills',
      keywords: ['electric', 'electricity', 'bill', 'bills', 'rates', 'utility', 'power bill', 'energy cost', 'expensive', 'rate increase', 'electric bill', 'energy prices', 'energy bill', 'utility bill', 'utility rates', 'price', 'prices', 'cost', 'costs', 'my bill', 'higher rates', 'rate hike', 'higher bill', 'electricity cost', 'power cost', 'electric rate', 'kilowatt', 'kwh', 'monthly bill', 'go up'],
      question: 'Will my electric bill go up?',
      answer: `<strong>No — your electric bill won't increase because of a data center.</strong> Modern facilities increasingly generate their own power "behind the meter" using solar, wind, and battery storage. In Texas, <strong>SB 6</strong> gives ERCOT authority to curtail large industrial loads during grid stress. Major operators also signed a <strong>Ratepayer Protection Pledge</strong> (March 2026) committing to protect residential rates.`,
      pageLink: '/energy-prices',
      pageName: 'Energy Prices by State'
    },
    {
      id: 'energy-grid',
      keywords: ['grid', 'power grid', 'ercot', 'blackout', 'brownout', 'behind the meter', 'solar', 'wind', 'battery', 'renewable', 'generation', 'grid stress', 'overload', 'power outage', 'outage', 'strain', 'demand', 'power demand', 'megawatt', 'gigawatt', 'capacity', 'power supply', 'energy demand', 'nuclear', 'natural gas', 'generator', 'generators'],
      question: 'Will it strain the power grid?',
      answer: `Modern data centers are designed to <strong>help</strong> the grid, not strain it. Many build their own power generation "behind the meter" — solar farms, wind, battery storage. Their <strong>bidirectional power systems</strong> can actually supply electricity BACK to the grid during emergencies. Data centers provide stable, predictable baseload demand, which helps utilities plan and invest in infrastructure more efficiently.`,
      pageLink: '/energy-prices',
      pageName: 'Energy Prices by State'
    },
    {
      id: 'energy-sb6',
      keywords: ['sb 6', 'senate bill', 'legislation', 'regulation', 'kill switch', 'curtail', 'texas law', 'sb6', 'law', 'laws', 'rule', 'rules', 'ordinance', 'permit', 'permits', 'government protection', 'consumer protection'],
      question: 'What protections does Texas SB 6 provide?',
      answer: `Texas <strong>Senate Bill 6</strong> is a powerful consumer protection law. It gives ERCOT — the state's grid operator — explicit authority to curtail electricity to large industrial facilities (including data centers) during grid stress events. Think of it as a "kill switch" that ensures <strong>homes and hospitals always come first</strong>.`,
      pageLink: '/energy-prices',
      pageName: 'Energy Prices by State'
    },
    {
      id: 'ratepayer-pledge',
      keywords: ['ratepayer', 'pledge', 'promise', 'commitment', 'protect', 'residential rates', 'guarantee', 'assured', 'assurance'],
      question: 'What is the Ratepayer Protection Pledge?',
      answer: `In <strong>March 2026</strong>, major data center operators signed the <strong>Ratepayer Protection Pledge</strong> — a formal industry commitment that data center development will not increase residential electricity rates. This supplements government protections like Texas SB 6 with a private-sector accountability mechanism.`,
      pageLink: '/energy-prices',
      pageName: 'Energy Prices by State'
    },
    {
      id: 'jobs-overview',
      keywords: ['jobs', 'employment', 'hiring', 'work', 'careers', 'job creation', 'how many jobs', 'employ', 'workforce', 'job', 'hire', 'workers', 'employees', 'staff', 'staffing', 'labor', 'occupation', 'positions', 'openings', 'opportunity', 'opportunities', 'working', 'livelihood', 'local jobs', 'create jobs'],
      question: 'How many jobs will it create?',
      answer: `Data centers create far more jobs than most people expect. A typical large facility brings:<br>• <strong>1,000–3,000+ construction jobs</strong> over 2–4 years ($60K–$120K+)<br>• <strong>30–150 permanent operations</strong> positions ($75K–$130K)<br>• <strong>200–500+ indirect/ecosystem jobs</strong> (contractors, fiber, catering, security)<br>The <strong>6x multiplier effect</strong> means every direct job creates ~6 additional jobs in the local economy.`,
      pageLink: '/careers',
      pageName: 'Career Pathways'
    },
    {
      id: 'jobs-salaries',
      keywords: ['salary', 'salaries', 'pay', 'wages', 'income', 'how much', 'compensation', 'earnings', 'career', 'earn', 'earning', 'make money', 'paid', 'paycheck', 'benefits', 'hourly', 'annual', 'per year', 'degree', 'college', 'training', 'qualified', 'skills', 'experience'],
      question: 'What do data center jobs pay?',
      answer: `Data center jobs are <strong>high-paying careers</strong> that don't always require a 4-year degree:<br>• Construction phase: <strong>$60K–$120K+</strong> per year<br>• Permanent operations: <strong>$75K–$130K</strong> per year<br>In Prineville, Oregon, Meta's data center transformed wages from the lowest to the highest in the state. These are stable, well-compensated jobs offering training programs for local residents.`,
      pageLink: '/careers',
      pageName: 'Career Pathways'
    },
    {
      id: 'jobs-indirect',
      keywords: ['indirect', 'multiplier', 'ecosystem', 'spinoff', 'supply chain', 'contractors', 'service', 'local business', 'small business', 'vendor', 'vendors', 'subcontractor', 'ripple effect', 'economic multiplier', 'local economy'],
      question: 'What about indirect and ecosystem jobs?',
      answer: `The <strong>6x job multiplier</strong> is one of the most powerful economic benefits. For every direct data center position, approximately 6 additional jobs are created in the surrounding economy: electrical contractors, fiber optic crews, HVAC specialists, local vendors, and more. In Northern Virginia, data centers support over 50,000 ecosystem jobs.`,
      pageLink: '/economic-impact',
      pageName: 'Economic Impact'
    },
    {
      id: 'tax-revenue',
      keywords: ['tax', 'taxes', 'property tax', 'revenue', 'money', 'county budget', 'fiscal', 'tax base', 'assessment', 'tax rate', 'tax bill', 'taxable', 'assessed value', 'appraisal', 'property taxes', 'tax revenue', 'tax break', 'abatement', 'incentive', 'incentives', 'financial', 'economics', 'economic', 'fund', 'funds'],
      question: 'How will it affect my property taxes?',
      answer: `Data centers are a <strong>fiscal goldmine</strong> for communities. A $1 billion facility generates roughly <strong>$40 million annually</strong> in property taxes while requiring almost zero county services — no new students, no new roads, minimal utility demand. In a county of 25,000 households, that equals about <strong>$1,600 per household</strong> in property tax relief.`,
      pageLink: '/your-tax-bill',
      pageName: 'Your Tax Bill'
    },
    {
      id: 'tax-schools',
      keywords: ['school', 'schools', 'education', 'students', 'teachers', 'school district', 'school funding', 'children', 'kids', 'classroom', 'isd', 'curriculum', 'enrollment', 'overcrowded', 'overcrowding', 'bus', 'buses', 'schoolchildren', 'academic'],
      question: 'How does it impact schools?',
      answer: `This is one of the strongest benefits: data centers fund schools without adding a single student. A data center's property tax revenue can send <strong>$20 million annually</strong> to public schools — funding roughly 200 teacher salaries — while adding <strong>zero new students</strong> to the district. Compare that to a residential subdivision that adds hundreds of kids and requires new schools, buses, and staff.`,
      pageLink: '/your-tax-bill',
      pageName: 'Your Tax Bill'
    },
    {
      id: 'tax-services',
      keywords: ['fire', 'police', 'roads', 'infrastructure', 'parks', 'services', 'emergency', 'county services', 'spending', 'budget allocation', 'sheriff', 'ems', 'ambulance', 'first responders', 'library', 'recreation', 'sidewalks', 'maintenance', 'paving', 'repair'],
      question: 'What does the tax revenue pay for?',
      answer: `A $40M annual tax revenue model breaks down as:<br>• <strong>Schools: $20M</strong> (50%) — ~200 teacher salaries<br>• <strong>Roads: $6M</strong> — ~40 miles of repaving/year<br>• <strong>Fire & Emergency: $4M</strong> — 1–2 new fire stations<br>• <strong>Law Enforcement: $4M</strong><br>• <strong>Parks & Recreation: $2M</strong><br>• <strong>Water & Utilities: $2M</strong><br>• <strong>Admin & Reserves: $2M</strong><br>All of this while requiring <strong>almost zero county services</strong> in return.`,
      pageLink: '/your-tax-bill',
      pageName: 'Your Tax Bill'
    },
    {
      id: 'noise',
      keywords: ['noise', 'loud', 'sound', 'decibel', 'db', 'noisy', 'quiet', 'hear', 'volume', 'hum', 'buzz', 'rumble', 'vibration', 'annoying', 'sleep', 'night', 'nighttime', 'ear', 'ears', 'noise level', 'noise pollution', 'sound level', 'nuisance', 'disturb', 'peaceful', 'peace'],
      question: 'How loud are data centers?',
      answer: `Data centers are <strong>remarkably quiet</strong>. At the property line — typically 100–300 feet from the building — noise measures just <strong>45–55 decibels</strong>, comparable to a quiet conversation or a home HVAC system. Modern facilities use sound-dampening enclosures and directional cooling to minimize noise. You'd barely know it was there.`,
      pageLink: '/inside-a-modern-facility',
      pageName: 'Inside a Modern Facility'
    },
    {
      id: 'appearance',
      keywords: ['look', 'looks', 'ugly', 'eyesore', 'appearance', 'design', 'building', 'architecture', 'what does it look like', 'factory', 'industrial', 'aesthetic', 'beautiful', 'attractive', 'visual', 'see', 'visible', 'sight', 'view', 'scenic', 'scenery', 'curb appeal', 'warehouse', 'massive', 'huge', 'enormous'],
      question: 'What does a data center look like?',
      answer: `Modern data centers look like <strong>upscale corporate office parks</strong> — not factories. They're typically <strong>1–2 story buildings</strong> with earth-tone exteriors, manicured landscaping, and extensive buffer zones. Sited in commercial or industrial zones, they are designed to blend into the surrounding landscape.`,
      pageLink: '/inside-a-modern-facility',
      pageName: 'Inside a Modern Facility'
    },
    {
      id: 'buffers',
      keywords: ['buffer', 'setback', 'landscaping', 'trees', 'berm', 'distance', 'property line', 'neighbor', 'close', 'next to', 'near my house', 'nearby', 'adjacent', 'proximity', 'feet away', 'yards', 'far', 'how close', 'near me', 'my property', 'my land', 'my home', 'backyard', 'fence', 'border', 'boundary'],
      question: 'How close will it be to homes?',
      answer: `Data centers maintain <strong>100–300 foot landscaped buffer zones</strong> between their facilities and property lines. These buffers include mature trees, berms (earth mounds), and natural vegetation that provide both visual screening and additional sound dampening.`,
      pageLink: '/inside-a-modern-facility',
      pageName: 'Inside a Modern Facility'
    },
    {
      id: 'traffic',
      keywords: ['traffic', 'cars', 'trucks', 'road', 'congestion', 'commute', 'driving', 'transportation', 'vehicles', 'highway', 'roads', 'intersection', 'rush hour', 'semi', 'diesel', '18 wheeler', 'tractor trailer', 'delivery', 'deliveries', 'shipping', 'driveway', 'street', 'lane'],
      question: 'Will there be more traffic?',
      answer: `Data centers generate <strong>very little traffic</strong> once operational. A typical facility with ~50 employees produces about <strong>15–20 houses worth of traffic</strong> — far less than a shopping center, school, or residential development of comparable land area. During the construction phase (2–4 years), there will be temporary construction traffic, but operators typically work with the county to minimize impact on residential roads.`,
      pageLink: '/inside-a-modern-facility',
      pageName: 'Inside a Modern Facility'
    },
    {
      id: 'property-values',
      keywords: ['property value', 'property values', 'home value', 'house value', 'real estate', 'resale', 'depreciation', 'property worth', 'home price', 'house price', 'market value', 'appraisal', 'sell my house', 'sell my home', 'housing market', 'home values', 'hurt property', 'lower value', 'decrease value', 'neighborhood'],
      question: 'Will it hurt my property values?',
