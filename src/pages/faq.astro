  function normalizeText(text: string) {
    return text.toLowerCase().replace(/[^\w\s]/g, '').replace(/\s+/g, ' ').trim();
  }

  function tokenize(text: string) {
    return normalizeText(text).split(/\s+/).filter(w => w.length > 0);
  }

  function removeStopWords(tokens: string[]) {
    const meaningful = tokens.filter(t => !STOP_WORDS.has(t));
    return meaningful.length > 0 ? meaningful : tokens;
  }

  function expandWithSynonyms(tokens: string[]) {
    const expanded = new Set(tokens);
    for (const token of tokens) {
      if (SYNONYM_MAP[token]) {
        for (const syn of SYNONYM_MAP[token]) {
          expanded.add(syn);
        }
      }
    }
    return Array.from(expanded);
  }

  function levenshtein(a: string, b: string) {
    if (a.length === 0) return b.length;
    if (b.length === 0) return a.length;
    const matrix = [];
    for (let i = 0; i <= b.length; i++) matrix[i] = [i];
    for (let j = 0; j <= a.length; j++) matrix[0][j] = j;
    for (let i = 1; i <= b.length; i++) {
      for (let j = 1; j <= a.length; j++) {
        const cost = b.charAt(i - 1) === a.charAt(j - 1) ? 0 : 1;
        matrix[i][j] = Math.min(
          matrix[i - 1][j] + 1,
          matrix[i][j - 1] + 1,
          matrix[i - 1][j - 1] + cost
        );
      }
    }
    return matrix[b.length][a.length];
  }

  function fuzzyMatch(word: string, keyword: string) {
    if (word === keyword) return 3; // Exact
    if (word.length < 3 || keyword.length < 3) return 0;
    if (word.startsWith(keyword) || keyword.startsWith(word)) return 2.5; // Prefix
    const maxDist = word.length <= 4 ? 1 : 2;
    const dist = levenshtein(word, keyword);
    if (dist <= maxDist) return 2; // Fuzzy
    if (word.includes(keyword) || keyword.includes(word)) return 1.5; // Substring
    return 0;
  }

  function findBestMatch(input: string) {
    const normalized = normalizeText(input);
    const rawTokens = tokenize(input);

    if (rawTokens.length === 0) return null;

    const cleanTokens = removeStopWords(rawTokens);
    const expandedTokens = expandWithSynonyms(cleanTokens);

    let bestScore = 0;
    let bestEntry = null;

    for (const entry of KNOWLEDGE_BASE) {
      let score = 0;
      const matchedKeywords = new Set<string>();

      for (const keyword of entry.keywords) {
        const kwTokens = keyword.split(/\s+/);

        if (kwTokens.length > 1) {
          if (normalized.includes(keyword.toLowerCase())) {
            score += kwTokens.length * 4; // Phrase match bonus
            matchedKeywords.add(keyword);
          }
        } else {
          const kw = keyword.toLowerCase();
          let bestWordScore = 0;

          for (const token of expandedTokens) {
            const wordScore = fuzzyMatch(token, kw);
            if (wordScore > bestWordScore) {
              bestWordScore = wordScore;
            }
          }

          if (bestWordScore > 0) {
            score += bestWordScore;
            matchedKeywords.add(keyword);
          }
        }
      }

      if (matchedKeywords.size >= 2) {
        score += matchedKeywords.size * 1.5;
      }

      // Overlap with canonical question
      const qTokens = removeStopWords(tokenize(entry.question));
      let qOverlap = 0;
      for (const qt of qTokens) {
        if (expandedTokens.some(t => fuzzyMatch(t, qt) >= 2)) {
          qOverlap++;
        }
      }
      if (qOverlap > 0) {
        score += qOverlap * 2;
      }

      if (score > bestScore) {
        bestScore = score;
        bestEntry = entry;
      }
    }

    const meaningfulCount = cleanTokens.length;
    let threshold = 3.0;
    if (meaningfulCount <= 1) {
      threshold = 2.5;
    } else if (meaningfulCount <= 3) {
      threshold = 3.0;
    } else {
      threshold = 4.0;
    }

    if (bestScore >= threshold && bestEntry) {
      return bestEntry;
    }

    return null;
  }

  // UI Event Binding
  document.addEventListener('astro:page-load', () => {
    const searchInput = document.getElementById('faq-search-input') as HTMLInputElement | null;
    const clearBtn = document.getElementById('faq-clear-btn');
    const aiBox = document.getElementById('ai-response-box');
    const aiQuestion = document.getElementById('ai-response-question');
    const aiAnswer = document.getElementById('ai-response-answer');
    const aiCitationText = document.getElementById('ai-response-link-text');
    const aiCitationLink = document.getElementById('ai-response-link') as HTMLAnchorElement | null;
    const noResultsBox = document.getElementById('no-results-box');
    
    // Select accordion elements
    const accordionItems = document.querySelectorAll('.faq-details-item');

    if (!searchInput) return;

    // Handle Input Events
    searchInput.addEventListener('input', () => {
      const query = searchInput.value;
      
      if (!query.trim()) {
        resetSearch();
        return;
      }

      // Show clear button
      if (clearBtn) clearBtn.classList.remove('hidden');

      // 1. Run AI Q&A Match
      const matchedAI = findBestMatch(query);
      
      if (matchedAI) {
        if (aiQuestion) aiQuestion.textContent = matchedAI.question;
        if (aiAnswer) aiAnswer.innerHTML = matchedAI.answer;
        if (aiCitationText) aiCitationText.textContent = matchedAI.pageName;
        if (aiCitationLink) aiCitationLink.href = matchedAI.pageLink;
        
        // Show AI Box with slide-in
        if (aiBox) {
          aiBox.classList.remove('hidden');
          setTimeout(() => {
            aiBox.classList.remove('scale-95', 'opacity-0');
            aiBox.classList.add('scale-100', 'opacity-100');
          }, 10);
        }
      } else {
        hideAIBox();
      }

      // 2. Filter Accordion List
      const queryTokens = tokenize(query);
      let visibleCount = 0;

      accordionItems.forEach(item => {
        const questionText = item.querySelector('.faq-question-text')?.textContent || "";
        const answerText = item.querySelector('.faq-answer-text')?.textContent || "";
        const combinedText = (questionText + " " + answerText).toLowerCase();

        // Check if any query token matches the text
        const isMatch = queryTokens.some(token => combinedText.includes(token));

        if (isMatch) {
          item.classList.remove('hidden');
          (item as HTMLDetailsElement).open = true; // Auto-expand matching questions!
          visibleCount++;
        } else {
          item.classList.add('hidden');
          (item as HTMLDetailsElement).open = false;
        }
      });

      // 3. Handle No Results Fallback
      if (visibleCount === 0 && !matchedAI) {
        if (noResultsBox) noResultsBox.classList.remove('hidden');
      } else {
        if (noResultsBox) noResultsBox.classList.add('hidden');
      }
    });

    // Handle Clear Action
    if (clearBtn) {
      clearBtn.addEventListener('click', () => {
        searchInput.value = '';
        resetSearch();
      });
    }

    function resetSearch() {
      if (clearBtn) clearBtn.classList.add('hidden');
      hideAIBox();
      if (noResultsBox) noResultsBox.classList.add('hidden');

      // Reset all accordions to visible and closed
      accordionItems.forEach(item => {
        item.classList.remove('hidden');
        (item as HTMLDetailsElement).open = false;
      });
    }

    function hideAIBox() {
      if (!aiBox) return;
      aiBox.classList.remove('scale-100', 'opacity-100');
      aiBox.classList.add('scale-95', 'opacity-0');
      setTimeout(() => {
        if (aiBox.classList.contains('opacity-0')) {
          aiBox.classList.add('hidden');
        }
      }, 300);
    }
  });
