        url: "https://www.coresite.com",
        category: "Colocation Infrastructure",
        bgGradient: "from-cyan-700 to-slate-900",
        logoSvg: `<svg class="w-8 h-8 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="3" width="20" height="6" rx="1" />
            <rect x="2" y="15" width="20" height="6" rx="1" />
            <path d="M6 6h.01M6 18h.01M18 6h.01M18 18h.01" />
