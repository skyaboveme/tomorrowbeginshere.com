---

<BaseLayout 
    title="Pro-Data Center Sites & Community Resources | TomorrowBeginsHere.com"
    description="Explore curated resources, industry sustainability frameworks, independent economic policy studies, and community benefit guidelines from leading data center organizations."
>
    <!-- Page Header -->
    <header class="relative pt-32 pb-20 lg:pt-40 lg:pb-28 overflow-hidden bg-slate-900 border-b border-tech-blue/20">
        <!-- Abstract gradient background -->
        <div class="absolute inset-0 bg-gradient-to-br from-texas-pine/30 via-slate-900 to-tech-blue/30 z-0"></div>
        <div class="absolute top-0 right-0 w-full h-full bg-[radial-gradient(circle_at_top_right,_var(--tw-gradient-stops))] from-texas-pine/10 via-transparent to-transparent z-0"></div>
        
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
            <div class="max-w-3xl">
                <span class="inline-block px-4 py-1.5 rounded-full bg-slate-800 text-slate-300 font-bold tracking-widest uppercase text-sm mb-6 border border-slate-700 backdrop-blur-sm">Directory</span>
                <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-white mb-6">
                    Pro-Data Center <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-teal-300">Resources</span> & Sites
                </h1>
                <p class="text-xl text-slate-300 leading-relaxed font-light mb-8 max-w-2xl">
                    Discover reports, policy guides, and official commitment portals from leading technology companies, independent economic institutes, and industry associations advocating for digital growth.
                </p>
            </div>
        </div>
    </header>

    <!-- Resources Directory Grid -->
    <section class="py-20 bg-slate-50 relative min-h-[50vh]">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {resources.map((resource) => (
                    <a 
                        href={resource.url} 
                        target="_blank" 
                        rel="noopener noreferrer" 
                        class="bg-white rounded-3xl overflow-hidden shadow-sm border border-slate-200 hover:shadow-xl hover:border-tech-blue/30 transition-all duration-300 group flex flex-col h-full relative"
                        id={`resource-card-${resource.domain.replace(/\./g, '-')}`}
                    >
                        <!-- OpenGraph Card Styled Header -->
                        <div class={`h-36 bg-gradient-to-br ${resource.bgGradient} relative flex items-center justify-center p-6 overflow-hidden`}>
                            <!-- Background overlay design grid -->
                            <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 16px 16px;"></div>
                            
                            <!-- Large Centered Icon representing brand -->
                            <div class="relative z-10 bg-black/20 p-4 rounded-2xl backdrop-blur-sm border border-white/10 group-hover:scale-110 transition-transform duration-300">
                                <Fragment set:html={resource.logoSvg} />
                            </div>
                            
                            <!-- Category Badge -->
                            <span class="absolute top-4 left-4 inline-block px-3 py-1 bg-black/40 text-white rounded-full text-[10px] font-bold uppercase tracking-wider backdrop-blur-sm border border-white/10">
                                {resource.category}
                            </span>
                        </div>

                        <!-- Card Body -->
                        <div class="p-6 flex flex-col flex-grow">
                            <!-- Publisher Domain -->
                            <div class="text-xs font-semibold text-slate-400 mb-2 flex items-center gap-1.5 uppercase tracking-wider">
                                <svg class="w-3.5 h-3.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9s2.015-9 4.5-9m0 0a9.003 9.003 0 018.716 6.747M12 3a9.003 9.003 0 00-8.716 6.747M3 12h18" />
                                </svg>
                                {resource.domain}
                            </div>

                            <!-- Page Title -->
                            <h2 class="text-lg font-bold text-slate-900 mb-3 group-hover:text-tech-blue transition-colors line-clamp-2 leading-snug">
                                {resource.title}
                            </h2>

                            <!-- snippet / description -->
                            <p class="text-slate-600 leading-relaxed text-sm mb-6 flex-grow line-clamp-4">
                                {resource.description}
                            </p>

                            <!-- Resource Link -->
                            <div class="pt-4 border-t border-slate-100 flex items-center text-tech-blue font-bold text-sm mt-auto">
                                <span class="group-hover:-translate-y-0.5 transition-transform duration-300">Open Resource</span>
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4 ml-2 group-hover:translate-x-1 group-hover:-translate-y-1 transition-all">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                                </svg>
                            </div>
                        </div>
                    </a>
                ))}
            </div>

            <!-- Transparency / Mission Banner -->
            <div class="mt-20 p-8 bg-blue-50 rounded-3xl border border-blue-100 text-center max-w-3xl mx-auto shadow-sm">
                <h3 class="text-lg font-bold text-slate-900 mb-2">Independent Research</h3>
                <p class="text-slate-600 text-sm leading-relaxed">
                    This directory indexes publicly available commitments, research papers, and technical platforms published by respected tech companies, infrastructure providers, and policy institutes. We encourage local leaders to review these primary sources.
                </p>
            </div>
        </div>
    </section>
</BaseLayout>
