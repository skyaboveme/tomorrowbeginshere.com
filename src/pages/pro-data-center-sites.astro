        category: "Texas Coalition",
        bgGradient: "from-red-600 via-white/20 to-blue-700",
        logoSvg: `<svg class="w-8 h-8 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
