---
import BaseLayout from '../components/BaseLayout.astro';
---

<BaseLayout 
    title="About This Site | TomorrowBeginsHere.com"
    description="Learn about our mission to provide accurate, fact-based educational resources regarding data center development in rural communities."
>
    <!-- Page Header -->
    <div class="bg-slate-900 border-b border-tech-blue/20 relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-pine-green/80 to-tech-blue/80 z-0 mix-blend-multiply"></div>
        <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1544085311-11a028465b03?q=80&w=2669&auto=format&fit=crop')] bg-cover bg-center z-0 opacity-20 mix-blend-overlay"></div>
        <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-24 text-center">
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 tracking-tight">About This Site</h1>
            <p class="text-xl text-slate-200 max-w-3xl mx-auto leading-relaxed font-light">
                Committed to honest engagement and transparent conversations.
            </p>
        </div>
    </div>

    <!-- Main Content -->
    <section class="py-16 lg:py-24 bg-white relative">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="bg-slate-50 border border-slate-200 rounded-[2rem] p-10 lg:p-16 shadow-lg relative overflow-hidden">
                <div class="absolute top-0 right-0 w-64 h-64 bg-tech-blue/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
                <div class="absolute bottom-0 left-0 w-64 h-64 bg-pine-green/5 rounded-full blur-3xl translate-y-1/2 -translate-x-1/2"></div>
                
                <div class="relative z-10 text-center mb-12">
                    <div class="w-24 h-24 bg-white shadow-md rounded-2xl flex items-center justify-center mx-auto mb-8 border border-slate-100 p-2">
                        <svg class="w-12 h-12 text-tech-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
                        </svg>
                    </div>
                    <h2 class="text-3xl font-bold mb-4 text-slate-900 tracking-tight">Our Core Mission</h2>
                </div>

                <div class="prose prose-lg prose-slate max-w-none relative z-10">
                    <p class="text-xl leading-relaxed mb-6 text-slate-700 font-medium text-center">
                        <strong>TomorrowBeginsHere.com</strong> is an independent educational resource dedicated to providing our community with accurate, fact-based information regarding data center development in rural areas.
                    </p>
                    
                    <hr class="border-slate-200 my-10 max-w-md mx-auto">
                    
                    <p class="leading-relaxed text-slate-600 mb-6">
                        We believe that community engagement is vital, and we are heavily committed to having honest conversations about both the incredible benefits and the legitimate considerations of integrating next-generation technology infrastructure into our region.
                    </p>
                    <p class="leading-relaxed text-slate-600">
                        When a new facility is proposed for our community, residents deserve complete information free from misleading comparisons or out-of-context rhetoric. We invite all residents to examine the facts, ask thoughtful questions, and actively participate in shaping a prosperous, technologically advanced future for Bastrop County.
                    </p>
                </div>
                
                <div class="mt-16 text-center relative z-10">
                    <p class="text-slate-500 mb-6 uppercase tracking-widest text-sm font-bold">Have Questions? Get in touch</p>
                    <a href="mailto:contact@tomorrowbeginshere.com" class="inline-flex items-center justify-center px-8 py-4 text-tech-blue border-2 border-tech-blue/20 hover:border-tech-blue hover:bg-tech-blue/5 font-bold rounded-xl transition-all duration-300 text-lg group">
                        <svg class="mr-3 w-5 h-5 text-tech-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                        </svg>
                        contact@tomorrowbeginshere.com
                    </a>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>
