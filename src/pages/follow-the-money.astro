                </ul>
            </div>

            <div class="mt-16 pt-10 border-t border-slate-200 flex flex-col sm:flex-row justify-between items-center gap-4">
                <a href="/data-center-backlash" class="inline-flex items-center text-tech-blue font-semibold hover:underline group">
                    <svg class="w-5 h-5 mr-2 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
                    Inside the Backlash
                </a>
                <a href="/data-is-the-new-oil" class="inline-flex items-center justify-center px-8 py-4 text-white bg-pine-green hover:bg-slate-900 font-bold rounded-xl shadow-md transition-all duration-300 hover:shadow-xl text-lg group">
                    Data Is the New Oil
                    <svg class="ml-3 w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
                </a>
            </div>

        </div>
    </section>
</BaseLayout>
