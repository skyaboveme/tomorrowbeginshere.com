---
import BaseLayout from '../components/BaseLayout.astro';
import LeadCaptureForm from '../components/LeadCaptureForm.astro';
import DataCenter100Things from '../components/100ThingsSlideshow.astro';
---

<BaseLayout 
    title="Tomorrow Begins Here | Data Centers & Rural Prosperity"
    description="Discover how data centers are transforming rural communities like Bastrop County, Texas, with jobs, tax revenue, and next-generation infrastructure."
>
    <!-- Hero Section -->
    <section class="relative bg-slate-900 overflow-hidden">
        <!-- Animated background (Ken Burns zoom) -->
        <div class="absolute inset-0 bg-gradient-to-br from-pine-green/90 to-tech-blue/90 z-10 mix-blend-multiply hero-overlay-animated"></div>
        <div class="absolute inset-0 bg-[url('/images/hero-bg.png')] bg-cover bg-center z-0 opacity-60 hero-bg-animated"></div>
        
        <!-- Tech grid overlay -->
        <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iNDAiIGhlaWdodD0iNDAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+CjxwYXRoIGQ9Ik0wIDBINDBWMHoiIGZpbGw9Im5vbmUiLz4KPHBhdGggZD0iTTAgNDBMMCAwTDQwIDBMMCAwIiBzdHJva2U9InJnYmEoMjU1LDI1NSwyNTUsMC4wNSkiIHN0cm9rZS13aWR0aD0iMSIvPgo8L3N2Zz4=')] z-10 opacity-40"></div>
        
        <!-- Floating particles -->
        <div class="absolute inset-0 z-10 overflow-hidden pointer-events-none">
            <div class="particle"></div>
            <div class="particle"></div>
            <div class="particle"></div>
            <div class="particle"></div>
            <div class="particle"></div>
            <div class="particle"></div>
            <div class="particle"></div>
            <div class="particle"></div>
            <div class="particle"></div>
            <div class="particle"></div>
        </div>
        
        <div class="relative z-20 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-32 pb-40 lg:pt-48 lg:pb-56">
            <div class="max-w-3xl">
                <h1 class="heading-display text-4xl sm:text-5xl lg:text-7xl font-bold text-white mb-6 leading-tight">
                    Tomorrow <span class="text-transparent bg-clip-text bg-gradient-to-r from-green-300 to-blue-300">Begins Here</span>
                </h1>
                <p class="text-lg sm:text-xl text-slate-100 mb-10 leading-relaxed font-light max-w-2xl">
                    When built thoughtfully in rural areas, data centers represent one of the most significant economic and technological opportunities a community can receive. We know that questions and concerns about new development are natural. That is why this site exists: to answer them honestly, and to empower you with the facts about what this historic investment means for our future.
                </p>
                
                <div class="flex flex-col sm:flex-row space-y-4 sm:space-y-0 sm:space-x-6">
                    <a href="/advancing-mankind" class="inline-flex justify-center items-center px-8 py-4 border border-transparent text-base font-bold rounded-md shadow-lg text-tech-blue bg-white hover:bg-slate-50 transition-all duration-300 hover:scale-105">
                        Discover the Future
                    </a>
                    <a href="/myth-vs-reality" class="inline-flex justify-center items-center px-8 py-4 border border-white/30 text-base font-bold rounded-md shadow-sm text-white bg-white/10 hover:bg-white/20 backdrop-blur-sm transition-all duration-300">
                        Read the Facts
                    </a>
                </div>
            </div>
        </div>
        
        <div class="absolute bottom-0 w-full z-20">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 120" class="w-full h-auto text-slate-50">
                <path fill="currentColor" fill-opacity="1" d="M0,64L80,69.3C160,75,320,85,480,74.7C640,64,800,32,960,26.7C1120,21,1280,43,1360,53.3L1440,64L1440,120L1360,120C1280,120,1120,120,960,120C800,120,640,120,480,120C320,120,160,120,80,120L0,120Z"></path>
            </svg>
        </div>
    </section>
    
    <!-- Quick Intro -->
    <section class="py-20 bg-slate-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center max-w-3xl mx-auto mb-16 reveal">
                <h2 class="heading-display text-3xl font-bold text-slate-900 sm:text-4xl mb-4">Empowering the Modern World</h2>
                <p class="text-lg text-slate-600">The infrastructure of tomorrow is taking root today. Explore how data centers are transforming our lives and driving unprecedented progress.</p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 reveal-stagger">
                <div class="bg-white rounded-2xl p-8 border border-slate-100 shadow-sm card-glow hover:-translate-y-1 transition-all duration-300">
                    <div class="w-14 h-14 bg-tech-blue/10 rounded-xl flex items-center justify-center mb-6 text-tech-blue">
                        <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" />
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-3">The Engine of Progress</h3>
                    <p class="text-slate-600 mb-6">Data centers are the essential foundation of the 21st century, powering everything from healthcare to artificial intelligence.</p>
                    <a href="/what-is-a-data-center" class="text-tech-blue font-semibold flex items-center group">
                        Learn the Basics
                        <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                        </svg>
                    </a>
                </div>
                
                <div class="bg-white rounded-2xl p-8 border border-slate-100 shadow-sm card-glow hover:-translate-y-1 transition-all duration-300">
                    <div class="w-14 h-14 bg-pine-green/10 rounded-xl flex items-center justify-center mb-6 text-pine-green">
                        <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-3">Myth vs. Reality</h3>
                    <p class="text-slate-600 mb-6">Get the honest, verifiable facts about water usage and power grid impacts. The truth might surprise you.</p>
                    <a href="/myth-vs-reality" class="text-pine-green font-semibold flex items-center group">
                        See the Facts
                        <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                        </svg>
                    </a>
                </div>
                
                <div class="bg-white rounded-2xl p-8 border border-slate-100 shadow-sm card-glow hover:-translate-y-1 transition-all duration-300">
                    <div class="w-14 h-14 bg-amber-500/10 rounded-xl flex items-center justify-center mb-6 text-amber-600">
                        <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-3">Local Opportunity</h3>
                    <p class="text-slate-600 mb-6">Discover how the Bastrop County boom is creating generational wealth, fully funded schools, and vast new careers.</p>
                    <a href="/bastrop-county-story" class="text-amber-600 font-semibold flex items-center group">
                        Explore Our Future
                        <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                        </svg>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- 100 Everyday Moments Section -->
    <DataCenter100Things />

    <!-- Featured Articles -->
    <section class="py-20 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-12 reveal">
                <span class="inline-block bg-red-500/10 text-red-600 text-xs font-bold uppercase tracking-widest px-4 py-1.5 rounded-full border border-red-200 mb-4">Latest Research & Fact-Checks</span>
                <h2 class="heading-display text-3xl font-bold text-slate-900 sm:text-4xl">Featured Analysis</h2>
            </div>
            
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 max-w-7xl mx-auto reveal-stagger">
                <!-- Card 1: OpenAI PRC-Linked Influence Operations -->
                <a href="https://openai.com/index/prc-linked-influence-operations-ai-debates/" target="_blank" rel="noopener noreferrer" class="no-external-icon group block bg-slate-900 rounded-[2rem] overflow-hidden shadow-xl hover:shadow-2xl card-glow transition-all duration-500 hover:-translate-y-1 relative h-full flex flex-col justify-between">
                    <div class="absolute inset-0 bg-gradient-to-br from-amber-950/70 to-slate-950/90 z-10"></div>
                    <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1526374965328-7f61d4dc18c5?q=80&w=2670&auto=format&fit=crop')] bg-cover bg-center opacity-20 group-hover:scale-105 transition-transform duration-700"></div>
                    
                    <div class="relative z-20 p-8 sm:p-10 flex flex-col justify-between h-full flex-grow">
                        <div>
                            <div class="flex items-center gap-3 mb-4">
                                <span class="inline-block bg-amber-500/20 text-amber-300 text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full border border-amber-400/30">National Security</span>
                                <span class="inline-block bg-red-500/20 text-red-300 text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full border border-red-400/30">NEW</span>
                            </div>
                            <h3 class="text-xl sm:text-2xl font-bold text-white mb-4 tracking-tight group-hover:text-amber-200 transition-colors">OpenAI: PRC-Linked Influence Operations Are Targeting AI Debates in the U.S.</h3>
                            <p class="text-slate-300 leading-relaxed mb-6 font-light text-sm">OpenAI's own threat report reveals two Chinese-linked operations — "Data Center Bandwagon" and "Tech and Tariffs" — that used ChatGPT to generate anti–data center propaganda and manufacture domestic outrage against American AI infrastructure.</p>
                        </div>
                        <div>
                            <div class="flex items-center gap-4 text-xs text-slate-400 mb-4">
                                <span>Jun 2026</span>
                                <span class="w-1 h-1 bg-slate-600 rounded-full"></span>
                                <span>OpenAI Threat Report</span>
                                <span class="w-1 h-1 bg-slate-600 rounded-full"></span>
                                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                                <span>openai.com</span>
                            </div>
                            <span class="inline-flex items-center text-white text-sm font-semibold group-hover:translate-x-1 transition-transform">
                                Read Full Report
                                <svg class="w-4 h-4 ml-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
                            </span>
                        </div>
                    </div>
                </a>

                <!-- Card 2: Inside the Data Center Backlash -->
                <a href="/data-center-backlash" class="group block bg-slate-900 rounded-[2rem] overflow-hidden shadow-xl hover:shadow-2xl card-glow transition-all duration-500 hover:-translate-y-1 relative h-full flex flex-col justify-between">
                    <div class="absolute inset-0 bg-gradient-to-br from-red-950/70 to-slate-950/90 z-10"></div>
                    <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1544085311-11a028465b03?q=80&w=2669&auto=format&fit=crop')] bg-cover bg-center opacity-25 group-hover:scale-105 transition-transform duration-700"></div>
                    
                    <div class="relative z-20 p-8 sm:p-10 flex flex-col justify-between h-full flex-grow">
                        <div>
                            <span class="inline-block bg-red-500/20 text-red-300 text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full border border-red-400/30 mb-4">Deep Analysis</span>
                            <h3 class="text-xl sm:text-2xl font-bold text-white mb-4 tracking-tight group-hover:text-red-200 transition-colors">Inside the Data Center Backlash: Anatomy of an Organized Opposition</h3>
                            <p class="text-slate-300 leading-relaxed mb-6 font-light text-sm">A movement that went from background noise to national flashpoint. $85 billion in canceled projects, a 30-point polling collapse, and the funding architecture behind it all.</p>
                        </div>
                        <div>
                            <div class="flex items-center gap-4 text-xs text-slate-400 mb-4">
                                <span>May 7, 2026</span>
                                <span class="w-1 h-1 bg-slate-600 rounded-full"></span>
                                <span>25 min read</span>
                            </div>
                            <span class="inline-flex items-center text-white text-sm font-semibold group-hover:translate-x-1 transition-transform">
                                Read Article
                                <svg class="w-4 h-4 ml-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
                            </span>
                        </div>
                    </div>
                </a>

                <!-- Card 3: Refuting EHP "The Dangers of Data Centers" -->
                <a href="/refuting-ehp-dangers-of-data-centers" class="group block bg-slate-900 rounded-[2rem] overflow-hidden shadow-xl hover:shadow-2xl card-glow transition-all duration-500 hover:-translate-y-1 relative h-full flex flex-col justify-between">
                    <div class="absolute inset-0 bg-gradient-to-br from-emerald-950/70 to-slate-950/90 z-10"></div>
                    <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1451187580459-43490279c0fa?q=80&w=2672&auto=format&fit=crop')] bg-cover bg-center opacity-25 group-hover:scale-105 transition-transform duration-700"></div>
                    
                    <div class="relative z-20 p-8 sm:p-10 flex flex-col justify-between h-full flex-grow">
                        <div>
                            <span class="inline-block bg-emerald-500/20 text-emerald-300 text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full border border-emerald-400/30 mb-4">Point-by-Point Fact-Check</span>
                            <h3 class="text-xl sm:text-2xl font-bold text-white mb-4 tracking-tight group-hover:text-emerald-200 transition-colors">Refuting EHP's "The Dangers of Data Centers"</h3>
                            <p class="text-slate-300 leading-relaxed mb-6 font-light text-sm">Separating Pennsylvania-centric rate projections and old evaporative water figures from the modern realities of Texas Senate Bill 6 and air-cooled closed-loop infrastructure.</p>
                        </div>
                        <div>
                            <div class="flex items-center gap-4 text-xs text-slate-400 mb-4">
                                <span>May 21, 2026</span>
                                <span class="w-1 h-1 bg-slate-600 rounded-full"></span>
                                <span>12 min read</span>
                            </div>
                            <span class="inline-flex items-center text-white text-sm font-semibold group-hover:translate-x-1 transition-transform">
                                Read Article
                                <svg class="w-4 h-4 ml-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
                            </span>
                        </div>
                    </div>
                </a>

                <!-- Card 4: West Texas Data Center Project Horizon -->
                <a href="https://www.forbes.com/sites/davidblackmon/2026/06/02/west-texas-data-center-project-addresses-activist-concerns-head-on/" target="_blank" rel="noopener noreferrer" class="no-external-icon group block bg-slate-900 rounded-[2rem] overflow-hidden shadow-xl hover:shadow-2xl card-glow transition-all duration-500 hover:-translate-y-1 relative h-full flex flex-col justify-between">
                    <div class="absolute inset-0 bg-gradient-to-br from-blue-950/70 to-slate-950/90 z-10"></div>
                    <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1470071459604-3b5ec3a7fe05?q=80&w=2672&auto=format&fit=crop')] bg-cover bg-center opacity-25 group-hover:scale-105 transition-transform duration-700"></div>
                    
                    <div class="relative z-20 p-8 sm:p-10 flex flex-col justify-between h-full flex-grow">
                        <div>
                            <span class="inline-block bg-tech-blue/20 text-blue-300 text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full border border-tech-blue/40 mb-4">Case Study Spotlight</span>
                            <h3 class="text-xl sm:text-2xl font-bold text-white mb-4 tracking-tight group-hover:text-blue-200 transition-colors">West Texas Data Center Project Horizon</h3>
                            <p class="text-slate-300 leading-relaxed mb-6 font-light text-sm">How Poolside Infrastructure's 1.2 GW Project Horizon near Fort Stockton solves grid and water constraints through behind-the-meter generation and closed-loop liquid-to-chip cooling.</p>
                        </div>
                        <div>
                            <div class="flex items-center gap-4 text-xs text-slate-400 mb-4">
                                <span>Jun 2, 2026</span>
                                <span class="w-1 h-1 bg-slate-600 rounded-full"></span>
                                <span>8 min read</span>
                            </div>
                            <span class="inline-flex items-center text-white text-sm font-semibold group-hover:translate-x-1 transition-transform">
                                Read Article
                                <svg class="w-4 h-4 ml-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
                            </span>
                        </div>
                    </div>
                </a>
            </div>
        </div>
    </section>

    <!-- YouTube Shorts / Reels Section -->
    <section class="py-20 bg-slate-950 text-white relative overflow-hidden">
        <!-- Ambient grid and background accents -->
        <div class="absolute inset-0 bg-gradient-to-b from-slate-900 to-slate-950 z-0"></div>
        <div class="absolute -top-40 -right-40 w-96 h-96 bg-red-600/10 rounded-full blur-3xl z-0"></div>
        <div class="absolute -bottom-40 -left-40 w-96 h-96 bg-tech-blue/10 rounded-full blur-3xl z-0"></div>

        <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 reveal">
                <div>
                    <span class="inline-flex items-center gap-1.5 bg-red-500/15 text-red-400 text-xs font-bold uppercase tracking-widest px-4 py-1.5 rounded-full border border-red-500/30 mb-4">
                        <span class="w-2 h-2 rounded-full bg-red-500 animate-pulse"></span>
                        YouTube Stories
                    </span>
                    <h2 class="text-3xl font-bold tracking-tight sm:text-4xl text-white">Watch Our Reels</h2>
                    <p class="text-slate-400 mt-2 text-lg font-light max-w-xl">
                        Rapid-fire facts, local community stories, and debunked myths straight from our YouTube channel.
                    </p>
                </div>
                <a 
                    href="https://www.youtube.com/@TomorrowBeginsHere" 
                    target="_blank" 
                    rel="noopener noreferrer" 
                    class="no-external-icon mt-4 md:mt-0 inline-flex items-center gap-2 px-5 py-2.5 bg-red-600 hover:bg-red-700 text-white font-bold rounded-xl text-sm transition-all duration-300 shadow-lg hover:shadow-red-600/20 hover:scale-105"
                >
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M23.498 6.163a3.003 3.003 0 0 0-2.11-2.11C19.517 3.545 12 3.545 12 3.545s-7.517 0-9.388.508a3.003 3.003 0 0 0-2.11 2.11C0 8.033 0 12 0 12s0 3.967.502 5.837a3.003 3.003 0 0 0 2.11 2.11c1.871.508 9.388.508 9.388.508s7.517 0 9.388-.508a3.003 3.003 0 0 0 2.11-2.11C24 15.967 24 12 24 12s0-3.967-.502-5.837zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                    </svg>
                    Subscribe on YouTube
                </a>
            </div>

            <!-- Reels Horizontal Scroll -->
            <div class="relative group/scroll">
                <!-- Navigation buttons (hidden on mobile) -->
                <button id="scroll-prev-btn" class="hidden md:flex absolute -left-6 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-slate-800/80 hover:bg-slate-700 border border-slate-700 text-white items-center justify-center z-20 cursor-pointer shadow-lg transition-all hover:scale-110 active:scale-95" aria-label="Scroll left">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7" /></svg>
                </button>
                <button id="scroll-next-btn" class="hidden md:flex absolute -right-6 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-slate-800/80 hover:bg-slate-700 border border-slate-700 text-white items-center justify-center z-20 cursor-pointer shadow-lg transition-all hover:scale-110 active:scale-95" aria-label="Scroll right">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" /></svg>
                </button>

                <!-- Scroll Wrapper -->
                <div 
                    id="reels-container" 
                    class="flex gap-6 overflow-x-auto pb-6 scroll-smooth scroll-snap-x snap-mandatory"
                    style="scrollbar-width: none; -ms-overflow-style: none;"
                >
                    <!-- Loading Skeletons (Shimmer) -->
                    {Array.from({ length: 5 }).map(() => (
                        <div class="flex-shrink-0 w-[240px] sm:w-[260px] aspect-[9/16] rounded-3xl border border-slate-800 flex flex-col justify-end p-6 skeleton-shimmer">
                            <div class="w-12 h-12 rounded-full bg-slate-700/50 mb-4 mx-auto"></div>
                            <div class="h-4 bg-slate-700/50 rounded w-3/4 mb-2 mx-auto"></div>
                            <div class="h-3 bg-slate-700/50 rounded w-1/2 mx-auto"></div>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <!-- Lightbox Modal -->
    <div 
        id="reels-lightbox" 
        class="fixed inset-0 z-[9999] bg-slate-950/90 backdrop-blur-md opacity-0 pointer-events-none flex items-center justify-center p-4 transition-all duration-300"
        role="dialog" 
        aria-modal="true"
    >
        <button id="lightbox-close-btn" class="absolute top-6 right-6 w-12 h-12 rounded-full bg-slate-800/80 hover:bg-slate-700 text-white flex items-center justify-center cursor-pointer transition-transform hover:scale-110" aria-label="Close video">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>

        <div class="relative w-full max-w-[390px] aspect-[9/16] rounded-[2rem] overflow-hidden shadow-2xl border border-slate-800 bg-black">
            <iframe 
                id="lightbox-iframe" 
                class="absolute inset-0 w-full h-full"
                src="" 
                title="YouTube Video Player"
                frameborder="0" 
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
                allowfullscreen
            ></iframe>
        </div>
    </div>

    <script>
        document.addEventListener('astro:page-load', () => {
            const reelsContainer = document.getElementById('reels-container');
            const prevBtn = document.getElementById('scroll-prev-btn');
            const nextBtn = document.getElementById('scroll-next-btn');
            const lightbox = document.getElementById('reels-lightbox');
            const lightboxIframe = document.getElementById('lightbox-iframe') as HTMLIFrameElement;
            const closeBtn = document.getElementById('lightbox-close-btn');

            if (!reelsContainer) return;

            // Fetch dynamic YouTube stories from the custom hybrid endpoint
            fetch('/api/shorts.json')
                .then(res => res.json())
                .then(data => {
                    if (data.success && data.videos && data.videos.length > 0) {
                        reelsContainer.innerHTML = '';
                        
                        // Sort so Shorts are prioritized at the front
                        const videos = data.videos;
                        
                        videos.forEach((video: any) => {
                            const isShort = video.isShort;
                            
                            // Create button-card element
                            const card = document.createElement('button');
                            card.className = "flex-shrink-0 w-[240px] sm:w-[260px] aspect-[9/16] rounded-3xl overflow-hidden relative group/card cursor-pointer border border-slate-900 hover:border-red-500/50 shadow-lg hover:shadow-red-500/10 hover:scale-[1.02] transition-all duration-300 snap-start text-left";
                            
                            const embedUrl = `https://www.youtube.com/embed/${video.id}?autoplay=1&rel=0`;
                            card.setAttribute('data-embed-url', embedUrl);

                            const thumbUrl = video.thumbnail || `https://img.youtube.com/vi/${video.id}/hqdefault.jpg`;

                            card.innerHTML = `
                                <!-- Thumbnail -->
                                <img src="${thumbUrl}" alt="${video.title.replace(/"/g, '&quot;')}" class="absolute inset-0 w-full h-full object-cover group-hover/card:scale-105 transition-transform duration-500" loading="lazy" />
                                
                                <!-- Vignette Overlay -->
                                <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/20 to-transparent z-10 opacity-90 group-hover/card:opacity-95 transition-opacity"></div>
                                
                                <!-- Red Play button for Reels -->
                                <div class="absolute inset-0 flex items-center justify-center z-20">
                                    <div class="w-12 h-12 rounded-full bg-red-600/90 group-hover/card:bg-red-600 flex items-center justify-center shadow-lg transform transition-transform duration-300 group-hover/card:scale-110 group-hover/card:rotate-6">
                                        <svg class="w-5 h-5 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                                    </div>
                                </div>
                                
                                <!-- Title Overlay -->
                                <div class="absolute bottom-0 left-0 right-0 p-5 z-20">
                                    <div class="flex items-center gap-1.5 mb-2">
                                        <span class="inline-block w-1.5 h-1.5 rounded-full bg-red-500 animate-pulse"></span>
                                        <span class="text-[0.6rem] font-bold uppercase tracking-widest text-red-400">
                                            ${isShort ? 'YouTube Short' : 'Video Story'}
                                        </span>
                                    </div>
                                    <h3 class="text-xs sm:text-sm font-bold text-white leading-snug line-clamp-3 group-hover/card:text-red-200 transition-colors">
                                        ${video.title}
                                    </h3>
                                </div>
                            `;
                            
                            // Lightbox trigger click handler
                            card.addEventListener('click', () => {
                                if (lightboxIframe && lightbox) {
                                    lightboxIframe.src = embedUrl;
                                    lightbox.classList.remove('opacity-0', 'pointer-events-none');
                                    document.body.style.overflow = 'hidden';
                                }
                            });

                            reelsContainer.appendChild(card);
                        });

                        // Button scroll actions
                        if (prevBtn && nextBtn) {
                            prevBtn.addEventListener('click', () => {
                                reelsContainer.scrollBy({ left: -280, behavior: 'smooth' });
                            });
                            nextBtn.addEventListener('click', () => {
                                reelsContainer.scrollBy({ left: 280, behavior: 'smooth' });
                            });
                        }
                    } else {
                        renderFallback();
                    }
                })
                .catch(err => {
                    console.error("Error loading Shorts:", err);
                    renderFallback();
                });

            function renderFallback() {
                if (reelsContainer) {
                    reelsContainer.innerHTML = `
                        <div class="col-span-full w-full py-12 text-center text-slate-400">
                            <p>Unable to load stories directly. Visit our <a href="https://www.youtube.com/@TomorrowBeginsHere" target="_blank" class="text-red-400 underline font-semibold">YouTube Channel</a> to view them.</p>
                        </div>
                    `;
                }
            }

            const closeLightbox = () => {
                if (lightbox && lightboxIframe) {
                    lightbox.classList.add('opacity-0', 'pointer-events-none');
                    lightboxIframe.src = '';
                    document.body.style.overflow = '';
                }
            };

            if (closeBtn) closeBtn.addEventListener('click', closeLightbox);
            if (lightbox) {
                lightbox.addEventListener('click', (e) => {
                    if (e.target === lightbox) closeLightbox();
                });
            }

            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape') closeLightbox();
            });
        });
    </script>

    <!-- Join The Coalition Section -->
    <section class="py-20 bg-white relative">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 reveal">
            <LeadCaptureForm />
        </div>
    </section>
</BaseLayout>
