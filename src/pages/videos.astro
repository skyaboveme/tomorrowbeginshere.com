---
import BaseLayout from '../components/BaseLayout.astro';

const videos = [
  {
    id: "8l764NbzpAk",
    title: "Marc Andreessen: Controversy Around Kevin O'Leary's Data Center Plans",
    description: "Marc Andreessen joins Joe Rogan to discuss the friction between data center development and local communities, focusing on Kevin O'Leary's Utah project. They analyze the immense energy demands of AI, the case for nuclear power as a clean energy source, and how regulatory bottlenecks delay critical infrastructure.",
    tag: "Energy & Regulation"
  },
  {
    id: "riz-ILPrsVo",
    start: 14,
    title: "Data Centers: Depleting Water & Electricity? The Truth Revealed",
    description: "Robby Soave of Rising examines the facts behind the panic over data center development. Contrary to populist narratives from both the left and right, he breaks down why concerns about energy grids and water usage are heavily overstated—and explains how these facilities actually benefit local economies and help lower utility rates.",
    tag: "Grid & Water Reality"
  },
  {
    id: "rUgooIHuDC8",
    title: "Watt's the Problem with Data Centers?",
    description: "Activists are angry about data centers. They call them \"uniquely evil.\" This video breaks down the truth about energy use, costs, and the panic over progress.",
    tag: "Energy & Infrastructure"
  },
  {
    id: "Hnd8vGhuyOc",
    start: 4181,
    end: 4376,
    title: "The Real Cost of Fleeing Progress",
    description: "A candid look at the financial reality behind reactionary decisions. This clip from Financial Audit (1:09:41–1:12:56) puts the \"flee\" mentality under the microscope to questions why your against data centers.",
    tag: "Financial Reality",
    poster: "/images/caleb-hammer-data-centers.png"
  },
  {
    id: "SFdqX7IY7RY",
    start: 2033,
    end: 3277,
    title: "Datacenter Wars: What's Behind the Disaster?",
    description: "The All-In Podcast breaks down the forces driving the datacenter boom — and the backlash. From Allbirds pivoting to AI to the real infrastructure bottlenecks, this segment (33:53–54:37) covers what's actually happening behind the headlines.",
    tag: "Industry Analysis"
  }
];
---

<BaseLayout 
    title="Videos | TomorrowBeginsHere.com"
    description="Watch in-depth videos exploring the facts about data center development, energy infrastructure, economic impact, and community growth."
>
    <!-- Page Header -->
    <div class="bg-slate-900 border-b border-tech-blue/20 relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-pine-green/80 to-tech-blue/80 z-0 mix-blend-multiply"></div>
        <div class="absolute inset-0 z-0 opacity-10" style="background-image: radial-gradient(circle at 25% 40%, rgba(59,130,246,0.5), transparent 40%), radial-gradient(circle at 75% 60%, rgba(16,185,129,0.5), transparent 40%);"></div>
        <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-24 text-center">
            <span class="inline-flex items-center gap-2 text-tech-blue bg-tech-blue/10 border border-tech-blue/20 px-4 py-1.5 rounded-full font-bold uppercase tracking-widest text-xs mb-6">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                Video Library
            </span>
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 tracking-tight">Videos</h1>
            <p class="text-xl text-slate-200 max-w-3xl mx-auto leading-relaxed font-light">
                In-depth video content exploring the facts about data centers, energy infrastructure, and the future of rural prosperity.
            </p>
        </div>
    </div>

    <!-- Videos Grid -->
    <section class="py-16 lg:py-24 bg-slate-50 relative">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
            
            <div class="space-y-16">
                {videos.map((video, index) => (
                    <article class="group" id={`video-${index}`}>
                        <!-- Video Container -->
                        <div class="bg-white rounded-2xl shadow-lg border border-slate-200 overflow-hidden transition-all duration-300 hover:shadow-xl">
                            <!-- Video Embed -->
                            <div class="relative bg-slate-900 group/video">
                                <div class="relative w-full" style="padding-bottom: 56.25%;">
                                    {video.poster ? (
                                        <div 
                                            class="absolute inset-0 w-full h-full cursor-pointer overflow-hidden" 
                                            onclick={`this.innerHTML='<iframe class="absolute inset-0 w-full h-full" src="https://www.youtube.com/embed/${video.id}?autoplay=1${video.start !== undefined ? `&amp;start=${video.start}` : ''}${video.end !== undefined ? `&amp;end=${video.end}` : ''}" title="${video.title.replace(/'/g, "\\'")}" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe>'`}
                                        >
                                            <img src={video.poster} alt={video.title} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover/video:scale-105" />
                                            <div class="absolute inset-0 bg-black/20 group-hover/video:bg-black/10 transition-colors duration-300"></div>
                                            <div class="absolute inset-0 flex items-center justify-center">
                                                <div class="w-16 h-16 md:w-20 md:h-20 bg-red-600 rounded-full flex items-center justify-center shadow-lg transform transition-transform duration-300 group-hover/video:scale-110">
                                                    <svg class="w-8 h-8 md:w-10 md:h-10 text-white ml-1 md:ml-2" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                                                </div>
                                            </div>
                                        </div>
                                    ) : (
                                        <iframe 
                                            class="absolute inset-0 w-full h-full"
                                            src={`https://www.youtube.com/embed/${video.id}${video.start !== undefined ? `?start=${video.start}` : ''}${video.end !== undefined ? `&end=${video.end}` : ''}`}
                                            title={video.title}
                                            frameborder="0" 
                                            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
                                            allowfullscreen
                                            loading="lazy"
                                        ></iframe>
                                    )}
                                </div>
                            </div>
                            
                            <!-- Video Info -->
                            <div class="p-8 lg:p-10">
                                <div class="flex flex-wrap items-center gap-3 mb-4">
                                    <span class="inline-flex items-center gap-1.5 text-xs font-bold uppercase tracking-widest text-tech-blue bg-tech-blue/10 px-3 py-1 rounded-full">
                                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 4v16M17 4v16M3 8h4m10 0h4M3 12h18M3 16h4m10 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z" />
                                        </svg>
                                        {video.tag}
                                    </span>
                                </div>
                                <h2 class="text-2xl lg:text-3xl font-bold text-slate-900 tracking-tight mb-3 group-hover:text-tech-blue transition-colors">{video.title}</h2>
                                <p class="text-lg text-slate-600 leading-relaxed max-w-4xl">{video.description}</p>
                                <div class="mt-6 pt-6 border-t border-slate-100 flex items-center gap-4">
                                    <a 
                                        href={`https://www.youtube.com/watch?v=${video.id}`}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class="inline-flex items-center gap-2 text-sm font-semibold text-slate-500 hover:text-red-600 transition-colors"
                                    >
                                        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                                            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814z"/>
                                            <path d="M9.545 15.568V8.432L15.818 12l-6.273 3.568z" fill="white"/>
                                        </svg>
                                        Watch on YouTube
                                    </a>
                                </div>
                            </div>
                        </div>
                    </article>
                ))}
            </div>

            <!-- More Coming Soon -->
            <div class="mt-20 text-center">
                <div class="bg-white rounded-2xl border-2 border-dashed border-slate-300 p-12 lg:p-16">
                    <div class="w-16 h-16 rounded-full bg-slate-100 flex items-center justify-center mx-auto mb-6">
                        <svg class="w-8 h-8 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold text-slate-700 mb-2">More Videos Coming Soon</h3>
                    <p class="text-slate-500 max-w-md mx-auto">We're curating a library of fact-based, in-depth videos on data center development, energy infrastructure, and community impact.</p>
                </div>
            </div>

            <!-- CTA -->
            <div class="mt-16 text-center bg-slate-900 rounded-[2rem] p-10 lg:p-16 border shadow-xl relative overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-tr from-tech-blue/20 to-transparent z-0"></div>
                <div class="relative z-10">
                    <h3 class="text-3xl font-bold mb-4 text-white tracking-tight">Want the Full Picture?</h3>
                    <p class="text-slate-300 mb-8 max-w-2xl mx-auto text-lg">
                        Explore our fact-checked articles, data visualizations, and community resources for a complete understanding.
                    </p>
                    <div class="flex flex-col sm:flex-row gap-4 justify-center">
                        <a href="/myth-vs-reality" class="inline-flex items-center justify-center px-8 py-3.5 text-tech-blue bg-white font-bold rounded-xl shadow-md transition-colors duration-300 hover:bg-slate-50 text-lg">
                            Read the Facts
                        </a>
                        <a href="/data-center-answers" class="inline-flex items-center justify-center px-8 py-3.5 text-white bg-white/10 border border-white/20 font-bold rounded-xl transition-colors duration-300 hover:bg-white/20 text-lg">
                            Data Center Answers
                        </a>
                    </div>
                </div>
            </div>

        </div>
    </section>
</BaseLayout>
