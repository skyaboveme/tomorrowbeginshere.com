---
import BaseLayout from '../components/BaseLayout.astro';
---

<BaseLayout 
    title="Interactive Simulators | TomorrowBeginsHere.com"
    description="Explore our interactive, fact-based simulators to understand the physics, finances, and daily operations of modern rural data centers."
>
    <!-- Page Header -->
    <div class="bg-slate-900 border-b border-tech-blue/20 relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-pine-green/80 to-tech-blue/80 z-0 mix-blend-multiply"></div>
        <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1551288049-bebda4e38f71?q=80&w=2670&auto=format&fit=crop')] bg-cover bg-center z-0 opacity-15 mix-blend-overlay"></div>
        <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-24 text-center">
            <span class="inline-block px-4 py-1.5 rounded-full bg-white/10 text-white font-bold tracking-widest uppercase text-xs mb-4 backdrop-blur-sm">Simulators & Math</span>
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 tracking-tight">Interactive Fact-Check Hub</h1>
            <p class="text-xl text-slate-200 max-w-3xl mx-auto leading-relaxed font-light">
                Interact directly with real physical formulas, economic budget equations, and low-latency packet paths. Discover the truth for yourself.
            </p>
        </div>
    </div>

    <!-- Dashboard Grid -->
    <section class="py-16 lg:py-24 bg-slate-50 relative">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
                
                <!-- Card 1: Noise & Distance -->
                <div class="bg-white rounded-[2rem] border border-slate-200 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 overflow-hidden flex flex-col group">
                    <div class="h-4 bg-gradient-to-r from-amber-400 to-orange-500"></div>
                    <div class="p-8 sm:p-10 flex-grow flex flex-col justify-between">
                        <div>
                            <div class="w-16 h-16 rounded-2xl bg-amber-50 flex items-center justify-center border border-amber-100/60 mb-6 text-amber-500 group-hover:scale-110 transition-transform duration-300">
                                <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z" />
                                </svg>
                            </div>
                            <h3 class="text-2xl font-bold text-slate-900 mb-3 tracking-tight">Noise & Distance Simulator</h3>
                            <p class="text-slate-600 mb-6 leading-relaxed">
                                Worried about loud humming or fan noise? Test the inverse square law of decibels over distance. Add sound shrouds, landscaping, and earthen berms to calculate property-line noise levels compared to natural ambient sounds.
                            </p>
                        </div>
                        <a href="/interactive/noise-simulator/" class="inline-flex items-center justify-center w-full px-6 py-4 text-white bg-slate-900 hover:bg-slate-800 font-bold rounded-xl transition-all duration-200 text-base group/btn">
                            Enter Noise Simulator
                            <svg class="ml-2 w-5 h-5 text-amber-400 group-hover/btn:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                            </svg>
                        </a>
                    </div>
                </div>

                <!-- Card 2: Tax & School Budget -->
                <div class="bg-white rounded-[2rem] border border-slate-200 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 overflow-hidden flex flex-col group">
                    <div class="h-4 bg-gradient-to-r from-emerald-400 to-teal-500"></div>
                    <div class="p-8 sm:p-10 flex-grow flex flex-col justify-between">
                        <div>
                            <div class="w-16 h-16 rounded-2xl bg-emerald-50 flex items-center justify-center border border-emerald-100/60 mb-6 text-emerald-500 group-hover:scale-110 transition-transform duration-300">
                                <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                                </svg>
                            </div>
                            <h3 class="text-2xl font-bold text-slate-900 mb-3 tracking-tight">Tax & School Budget Simulator</h3>
                            <p class="text-slate-600 mb-6 leading-relaxed">
                                See how hundreds of millions in commercial capital valuation translate directly into local community funding. Toggle investments to calculate county revenue, teacher hiring budgets, classroom technology, and road paving.
                            </p>
                        </div>
                        <a href="/interactive/tax-simulator/" class="inline-flex items-center justify-center w-full px-6 py-4 text-white bg-slate-900 hover:bg-slate-800 font-bold rounded-xl transition-all duration-200 text-base group/btn">
                            Enter Tax Simulator
                            <svg class="ml-2 w-5 h-5 text-emerald-400 group-hover/btn:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                            </svg>
                        </a>
                    </div>
                </div>

                <!-- Card 4: Where Does Your Click Go? -->
                <div class="bg-white rounded-[2rem] border border-slate-200 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 overflow-hidden flex flex-col group">
                    <div class="h-4 bg-gradient-to-r from-violet-400 to-fuchsia-500"></div>
                    <div class="p-8 sm:p-10 flex-grow flex flex-col justify-between">
                        <div>
                            <div class="w-16 h-16 rounded-2xl bg-violet-50 flex items-center justify-center border border-violet-100/60 mb-6 text-violet-500 group-hover:scale-110 transition-transform duration-300">
                                <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
                                </svg>
                            </div>
                            <h3 class="text-2xl font-bold text-slate-900 mb-3 tracking-tight">"Where Does Your Click Go?" Interactive Journey</h3>
                            <p class="text-slate-600 mb-6 leading-relaxed">
                                Trace the physical journey of a single tap from your smartphone to a hyper-scale server. Pulse data packets down fiber highways under rural roads, watch cooling fluid circulation absorb heat, and see server CPUs compute at lightspeed.
                            </p>
                        </div>
                        <a href="/interactive/click-journey/" class="inline-flex items-center justify-center w-full px-6 py-4 text-white bg-slate-900 hover:bg-slate-800 font-bold rounded-xl transition-all duration-200 text-base group/btn">
                            Enter Click Journey
                            <svg class="ml-2 w-5 h-5 text-violet-400 group-hover/btn:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                            </svg>
                        </a>
                    </div>
                </div>

                <!-- Card 5: Aquifer & Zero-Water Cooling -->
                <div class="bg-white rounded-[2rem] border border-slate-200 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 overflow-hidden flex flex-col group">
                    <div class="h-4 bg-gradient-to-r from-cyan-400 to-emerald-500"></div>
                    <div class="p-8 sm:p-10 flex-grow flex flex-col justify-between">
                        <div>
                            <div class="w-16 h-16 rounded-2xl bg-cyan-50 flex items-center justify-center border border-cyan-100/60 mb-6 text-cyan-500 group-hover:scale-110 transition-transform duration-300">
                                <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                                </svg>
                            </div>
                            <h3 class="text-2xl font-bold text-slate-900 mb-3 tracking-tight">Aquifer & Zero-Water Cooling</h3>
                            <p class="text-slate-600 mb-6 leading-relaxed">
                                Worried about data centers draining local aquifers? Compare legacy evaporative towers against zero-water closed-loop air cooling. Toggle workloads and outdoor heat index to see groundwater conservation in action.
                            </p>
                        </div>
                        <a href="/interactive/water-simulator/" class="inline-flex items-center justify-center w-full px-6 py-4 text-white bg-slate-900 hover:bg-slate-800 font-bold rounded-xl transition-all duration-200 text-base group/btn">
                            Enter Cooling Simulator
                            <svg class="ml-2 w-5 h-5 text-cyan-400 group-hover/btn:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                            </svg>
                        </a>
                    </div>
                </div>

                <!-- Card 6: ERCOT Grid Load-Balancing -->
                <div class="bg-white rounded-[2rem] border border-slate-200 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 overflow-hidden flex flex-col group">
                    <div class="h-4 bg-gradient-to-r from-blue-400 to-indigo-500"></div>
                    <div class="p-8 sm:p-10 flex-grow flex flex-col justify-between">
                        <div>
                            <div class="w-16 h-16 rounded-2xl bg-blue-50 flex items-center justify-center border border-blue-100/60 mb-6 text-blue-500 group-hover:scale-110 transition-transform duration-300">
                                <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                                </svg>
                            </div>
                            <h3 class="text-2xl font-bold text-slate-900 mb-3 tracking-tight">ERCOT Grid Load-Balancing</h3>
                            <p class="text-slate-600 mb-6 leading-relaxed">
                                See how data centers act as demand-response partners. Simulate peak summer power spikes and trigger automated curtailments to watch how data centers shut down servers within seconds to protect residential power grids.
                            </p>
                        </div>
                        <a href="/interactive/grid-simulator/" class="inline-flex items-center justify-center w-full px-6 py-4 text-white bg-slate-900 hover:bg-slate-800 font-bold rounded-xl transition-all duration-200 text-base group/btn">
                            Enter Grid Simulator
                            <svg class="ml-2 w-5 h-5 text-blue-400 group-hover/btn:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                            </svg>
                        </a>
                    </div>
                </div>

                <!-- Card 7: Personal Property Tax Offset -->
                <div class="bg-white rounded-[2rem] border border-slate-200 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 overflow-hidden flex flex-col group">
                    <div class="h-4 bg-gradient-to-r from-teal-400 to-emerald-500"></div>
                    <div class="p-8 sm:p-10 flex-grow flex flex-col justify-between">
                        <div>
                            <div class="w-16 h-16 rounded-2xl bg-teal-50 flex items-center justify-center border border-teal-100/60 mb-6 text-teal-500 group-hover:scale-110 transition-transform duration-300">
                                <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                                </svg>
                            </div>
                            <h3 class="text-2xl font-bold text-slate-900 mb-3 tracking-tight">Personal Tax Offset Calculator</h3>
                            <p class="text-slate-600 mb-6 leading-relaxed">
                                Enter your home's valuation and current property taxes to see how massive commercial capital investments compress local tax rates and lower your individual bill, while funding school expansions and municipal upgrades.
                            </p>
                        </div>
                        <a href="/interactive/tax-offset/" class="inline-flex items-center justify-center w-full px-6 py-4 text-white bg-slate-900 hover:bg-slate-800 font-bold rounded-xl transition-all duration-200 text-base group/btn">
                            Enter Savings Calculator
                            <svg class="ml-2 w-5 h-5 text-teal-400 group-hover/btn:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                            </svg>
                        </a>
                    </div>
                </div>

                <!-- Card 8: Bastrop ISD Tax Calculator -->
                <div class="bg-white rounded-[2rem] border border-slate-200 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 overflow-hidden flex flex-col group">
                    <div class="h-4 bg-gradient-to-r from-indigo-500 to-emerald-500"></div>
                    <div class="p-8 sm:p-10 flex-grow flex flex-col justify-between">
                        <div>
                            <div class="w-16 h-16 rounded-2xl bg-indigo-50 flex items-center justify-center border border-indigo-100/60 mb-6 text-indigo-500 group-hover:scale-110 transition-transform duration-300">
                                <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                                </svg>
                            </div>
                            <h3 class="text-2xl font-bold text-slate-900 mb-3 tracking-tight">Bastrop ISD Tax Calculator</h3>
                            <p class="text-slate-600 mb-6 leading-relaxed">
                                See how commercial capital valuations translate directly into Bastrop ISD funding. Simulate hiring averages for teachers, new school bus purchases, and student technology bundles.
                            </p>
                        </div>
                        <a href="/interactive/bastrop-isd-calculator/" class="inline-flex items-center justify-center w-full px-6 py-4 text-white bg-slate-900 hover:bg-slate-800 font-bold rounded-xl transition-all duration-200 text-base group/btn">
                            Enter ISD Calculator
                            <svg class="ml-2 w-5 h-5 text-indigo-400 group-hover/btn:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                            </svg>
                        </a>
                    </div>
                </div>

                <!-- Card 9: 24-Hour Operations Timeline -->
                <div class="bg-white rounded-[2rem] border border-slate-200 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 overflow-hidden flex flex-col group">
                    <div class="h-4 bg-gradient-to-r from-blue-500 to-slate-900"></div>
                    <div class="p-8 sm:p-10 flex-grow flex flex-col justify-between">
                        <div>
                            <div class="w-16 h-16 rounded-2xl bg-slate-100 flex items-center justify-center border border-slate-200 mb-6 text-slate-700 group-hover:scale-110 transition-transform duration-300">
                                <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                            </div>
                            <h3 class="text-2xl font-bold text-slate-900 mb-3 tracking-tight">24-Hour Operations Timeline</h3>
                            <p class="text-slate-600 mb-6 leading-relaxed">
                                Slide through a full 24-hour cycle to see the environmental and community footprint of a local facility. Monitor traffic volume, fence-line noise, and on-site emissions hour-by-hour.
                            </p>
                        </div>
                        <a href="/interactive/operations-timeline/" class="inline-flex items-center justify-center w-full px-6 py-4 text-white bg-slate-900 hover:bg-slate-800 font-bold rounded-xl transition-all duration-200 text-base group/btn">
                            Enter Operations Timeline
                            <svg class="ml-2 w-5 h-5 text-blue-400 group-hover/btn:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                            </svg>
                        </a>
                    </div>
                </div>

            </div>
        </div>
    </section>
</BaseLayout>
