---
import BaseLayout from '../../components/BaseLayout.astro';
---

<BaseLayout 
    title="'Inside the Substation' Power Grid Simulator | TomorrowBeginsHere.com"
    description="Simulate electrical grid loads, substation interconnections, and emergency curtailment agreements. Watch the data center switch to backup power during winter storms."
>
    <!-- Navigation Back Link -->
    <div class="bg-slate-900 pt-8 pb-4">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <a href="/interactive" class="inline-flex items-center text-sm font-semibold text-slate-400 hover:text-white transition-colors">
                <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                </svg>
                Back to Simulators Hub
            </a>
        </div>
    </div>

    <!-- Page Header -->
    <div class="bg-slate-900 border-b border-tech-blue/20 relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-blue-600/50 to-slate-900 z-0"></div>
        <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16 text-center">
            <span class="inline-block px-4 py-1 rounded-full bg-blue-500/20 text-blue-300 font-bold tracking-widest uppercase text-xs mb-3 border border-blue-500/30">Utility Grid Simulator</span>
            <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-4 tracking-tight">"Inside the Substation" Power Grid Simulator</h1>
            <p class="text-lg text-slate-300 max-w-2xl mx-auto font-light leading-relaxed">
                Experience grid operations during high-stress peaks. Toggle weather events and load parameters, and see how emergency curtailment automatically switches the facility offline to support residential capacity.
            </p>
        </div>
    </div>

    <!-- Simulator Body -->
    <section class="py-12 bg-slate-50 relative">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
                
                <!-- Controls Column (4 cols) -->
                <div class="lg:col-span-4 space-y-6">
                    <div class="bg-white rounded-3xl p-6 sm:p-8 border border-slate-200 shadow-sm space-y-8">
                        
                        <!-- Grid Scenario Selector -->
                        <div class="space-y-4">
                            <label class="block text-sm font-bold text-slate-700 uppercase tracking-wider">Grid Load Scenario</label>
                            <div class="grid grid-cols-1 gap-2">
                                <button type="button" class="scenario-btn flex items-center justify-between p-3.5 rounded-xl border-2 border-slate-200 hover:border-blue-400 bg-slate-50 transition-all text-left active-scenario" data-scenario="normal" data-temp="72°F" data-house="120">
                                    <div>
                                        <div class="font-bold text-slate-800 text-sm">Normal Spring/Autumn</div>
                                        <div class="text-[10px] text-slate-500">Grid is balanced, optimal renewable output</div>
                                    </div>
                                    <span class="text-xs font-semibold px-2 py-0.5 rounded bg-green-100 text-green-700">Balanced</span>
                                </button>

                                <button type="button" class="scenario-btn flex items-center justify-between p-3.5 rounded-xl border-2 border-slate-200 hover:border-blue-400 bg-slate-50 transition-all text-left" data-scenario="summer" data-temp="106°F" data-house="240">
                                    <div>
                                        <div class="font-bold text-slate-800 text-sm">Peak Summer Heat</div>
                                        <div class="text-[10px] text-slate-500">Air-conditioning surges grid demand</div>
                                    </div>
                                    <span class="text-xs font-semibold px-2 py-0.5 rounded bg-orange-100 text-orange-700">High Load</span>
                                </button>

                                <button type="button" class="scenario-btn flex items-center justify-between p-3.5 rounded-xl border-2 border-slate-200 hover:border-blue-400 bg-slate-50 transition-all text-left" data-scenario="winter" data-temp="12°F" data-house="280">
                                    <div>
                                        <div class="font-bold text-slate-800 text-sm">Severe Winter Freeze</div>
                                        <div class="text-[10px] text-slate-500">Auxiliary electrical heating spikes demand</div>
                                    </div>
                                    <span class="text-xs font-semibold px-2 py-0.5 rounded bg-red-100 text-red-700">Extreme Load</span>
                                </button>
                            </div>
                        </div>

                        <!-- Data Center MW Load Slider -->
                        <div class="space-y-4 pt-4 border-t border-slate-100">
                            <div class="flex justify-between items-end">
                                <label for="load-slider" class="block text-xs font-bold text-slate-500 uppercase tracking-wider">Facility Draw</label>
                                <span class="text-lg font-black text-blue-600 animate-pulse-subtle" id="load-display">120 MW</span>
                            </div>
                            <input 
                                type="range" 
                                id="load-slider" 
                                min="0" 
                                max="250" 
                                step="10" 
                                value="120" 
                                class="w-full h-2 bg-slate-200 rounded-lg appearance-none cursor-pointer accent-blue-500 hover:accent-blue-500/80 transition-all"
                            >
                            <div class="flex justify-between text-[10px] font-bold text-slate-400">
                                <span>0 MW</span>
                                <span>120 MW</span>
                                <span>250 MW</span>
                            </div>
                        </div>

                        <!-- Curtailment / Load-Shedding Toggle -->
                        <div class="space-y-4 pt-4 border-t border-slate-100">
                            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider">Load Shedding & Curtailment</label>
                            
                            <div class="flex items-center justify-between bg-slate-50 p-4 rounded-xl border border-slate-200">
                                <div>
                                    <div class="font-bold text-slate-800 text-sm">Active Emergency Mode</div>
                                    <div class="text-[9px] text-slate-500 leading-snug">Switches data center intake to offline backup arrays</div>
                                </div>
                                <label class="relative inline-flex items-center cursor-pointer">
                                    <input type="checkbox" id="curtailment-toggle" class="sr-only peer">
                                    <div class="w-11 h-6 bg-slate-300 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-slate-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600"></div>
                                </label>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- Visualizations Column (8 cols) -->
                <div class="lg:col-span-8 space-y-6">
                    
                    <!-- SVG Schematic Map -->
                    <div class="bg-white rounded-3xl p-6 border border-slate-200 shadow-sm relative overflow-hidden">
                        <div class="flex justify-between items-center mb-4">
                            <h4 class="text-xs font-bold text-slate-500 uppercase tracking-widest">Local Substation Interconnection Diagram</h4>
                            <div class="flex gap-4 text-[10px] font-bold uppercase tracking-wider text-slate-400">
                                <span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-blue-500 animate-pulse"></span>Grid Power</span>
                                <span class="flex items-center gap-1.5" id="backup-legend"><span class="w-2.5 h-2.5 rounded-full bg-slate-300"></span>Backup Power</span>
                            </div>
                        </div>
                        
                        <div class="h-80 bg-slate-950 rounded-2xl relative border border-slate-800 overflow-hidden flex items-center justify-center p-4">
                            <div class="absolute inset-0 opacity-[0.03] bg-[linear-gradient(to_right,#808080_1px,transparent_1px),linear-gradient(to_bottom,#808080_1px,transparent_1px)] bg-[size:16px_16px]"></div>
                            
                            <!-- Generator / Substation SVG Schematic -->
                            <svg class="w-full h-full text-slate-700" viewBox="0 0 800 300" fill="none">
                                <!-- Power Station (Left) -->
                                <g id="power-source">
                                    <rect x="20" y="100" width="80" height="80" rx="8" fill="#1e293b" stroke="#475569" stroke-width="2"/>
                                    <!-- Generator Icon -->
                                    <circle cx="60" cy="140" r="18" fill="#0f172a" stroke="#64748b" stroke-width="2" />
                                    <path d="M50 140 H70 M60 130 V150" stroke="#94a3b8" stroke-width="2" />
                                    <text x="60" y="200" text-anchor="middle" fill="#94a3b8" font-size="9" font-weight="bold">UTILITY GRID</text>
                                </g>

                                <!-- Substation (Center-Left) -->
                                <g id="substation">
                                    <rect x="240" y="90" width="100" height="100" rx="12" fill="#1e293b" stroke="#3b82f6" stroke-width="2"/>
                                    <circle cx="290" cy="140" r="22" fill="#0f172a" stroke="#3b82f6" stroke-width="2"/>
                                    <!-- Lightning Icon -->
                                    <path d="M290 125 L280 142 H293 L287 155 L300 137 H287 L290 125 Z" fill="#60a5fa"/>
                                    <text x="290" y="210" text-anchor="middle" fill="#94a3b8" font-size="9" font-weight="bold">SUBSTATION</text>
                                </g>

                                <!-- Residential Houses (Bottom-Right) -->
                                <g id="houses">
                                    <rect x="520" y="160" width="120" height="90" rx="12" fill="#1e293b" stroke="#475569" stroke-width="2" id="houses-box"/>
                                    <path d="M540 215 H560 M550 205 V225 M590 215 H610 M600 205 V225" stroke="#94a3b8" stroke-width="2" />
                                    <text x="580" y="270" text-anchor="middle" fill="#94a3b8" font-size="9" font-weight="bold">COMMUNITY HOMES</text>
                                </g>

                                <!-- Data Center (Top-Right) -->
                                <g id="datacenter">
                                    <rect x="520" y="30" width="220" height="100" rx="12" fill="#1e293b" stroke="#475569" stroke-width="2" id="dc-box"/>
                                    <text x="630" y="150" text-anchor="middle" fill="#94a3b8" font-size="9" font-weight="bold">DATA CENTER & BACKUP PAD</text>
                                    
                                    <!-- Generators (Inside DC) -->
                                    <rect x="650" y="45" width="75" height="45" rx="6" fill="#0f172a" stroke="#475569" stroke-width="1.5" id="backup-pad"/>
                                    <text x="687" y="72" text-anchor="middle" fill="#64748b" font-size="7" font-weight="bold" id="backup-pad-text">BACKUPS</text>
                                </g>

                                <!-- Grid cables & arrows (animated connections) -->
                                <!-- Cable 1: Power Source to Substation -->
                                <path id="cable-grid-sub" d="M100 140 H240" stroke="#3b82f6" stroke-width="3" stroke-dasharray="8 6" class="grid-flow-animate" />
                                
                                <!-- Cable 2: Substation to Houses -->
                                <path id="cable-sub-houses" d="M290 190 V210 H520" stroke="#3b82f6" stroke-width="3" stroke-dasharray="8 6" class="grid-flow-animate" />
                                
                                <!-- Cable 3: Substation to Data Center -->
                                <path id="cable-sub-dc" d="M340 140 H450 V80 H520" stroke="#3b82f6" stroke-width="3" stroke-dasharray="8 6" class="grid-flow-animate" />
                                
                                <!-- Cable 4: Generators to Data Center Core (internal loop) -->
                                <path id="cable-backup-dc" d="M650 68 H610" stroke="#64748b" stroke-width="3" stroke-dasharray="8 6" class="backup-flow-animate opacity-0" />
                            </svg>
                        </div>
                    </div>

                    <!-- Metrics Output Display -->
                    <div class="bg-gradient-to-br from-slate-900 to-slate-800 rounded-3xl p-8 text-white shadow-2xl relative overflow-hidden">
                        <div class="absolute -top-24 -right-24 w-48 h-48 bg-blue-500/10 rounded-full blur-3xl pointer-events-none"></div>
                        <div class="absolute -bottom-24 -left-24 w-48 h-48 bg-red-500/10 rounded-full blur-3xl pointer-events-none" id="alert-bg-glow"></div>
                        
                        <div class="relative z-10 grid grid-cols-1 md:grid-cols-12 gap-8 items-center">
                            
                            <!-- Grid Load Warning -->
                            <div class="md:col-span-7 space-y-4">
                                <div class="flex justify-between items-baseline">
                                    <span class="text-xs font-bold text-slate-400 uppercase tracking-widest opacity-80">Grid Capacity Stress</span>
                                    <span class="text-2xl font-black text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-indigo-300" id="stress-percentage">48%</span>
                                </div>
                                <div class="h-2.5 w-full bg-white/10 rounded-full overflow-hidden">
                                    <div class="h-full bg-gradient-to-r from-green-400 via-yellow-400 to-red-500 transition-all duration-500" id="stress-bar" style="width: 48%;"></div>
                                </div>
                                
                                <div class="flex items-center gap-3 p-3 bg-white/5 rounded-xl border border-white/10 shadow-inner">
                                    <span class="text-xs font-bold text-slate-400">Current Grid Temperature:</span>
                                    <span class="text-sm font-black text-white" id="temp-display">72°F</span>
                                </div>
                            </div>

                            <!-- Emergency Curtailment Status Alert Box -->
                            <div class="md:col-span-5 bg-white/5 rounded-2xl p-6 border border-white/10 flex flex-col justify-center">
                                <h5 class="text-xs font-bold text-slate-300 uppercase tracking-widest opacity-80 mb-2">Curtailment Status</h5>
                                <div class="text-lg font-black text-green-400 leading-snug" id="status-title">Inactive</div>
                                <div class="text-xs text-slate-400 leading-relaxed mt-2" id="status-desc">
                                    Grid load is balanced. The facility is drawing standard electricity from the utility network.
                                </div>
                            </div>

                        </div>
                    </div>

                    <!-- Informational Box -->
                    <div class="bg-white rounded-3xl p-6 sm:p-8 border border-slate-200 shadow-sm prose prose-slate max-w-none">
                        <h4 class="text-slate-900 font-bold mb-2">What are Curtailment Agreements?</h4>
                        <p class="text-sm text-slate-600 leading-relaxed mb-4">
                            Unlike traditional factories or heavy industrial plants, modern data centers are highly flexible electric loads. Under **demand-response or curtailment agreements** signed with local utility providers, the facility operator contractually agrees to shed 100% of their grid intake during regional power peak emergencies (such as extreme weather freezes).
                        </p>
                        <p class="text-sm text-slate-600 leading-relaxed">
                            When an emergency is declared, the facility automatically activates its state-of-the-art backup batteries or generator enclosures to maintain operations locally, immediately freeing up massive megawatt reserves (e.g. 100+ MW, enough to power over 50,000 community homes) to protect residential grid stability and prevent blackouts.
                        </p>
                    </div>

                </div>

            </div>

        </div>
    </section>
</BaseLayout>

<style>
    /* Animated dashed power lines in SVG */
    .grid-flow-animate {
        stroke-dasharray: 10, 6;
        animation: dash-flow 1.5s linear infinite;
    }
    
    .backup-flow-animate {
        stroke-dasharray: 10, 6;
        animation: dash-flow 1s linear infinite;
    }

    @keyframes dash-flow {
        to {
            stroke-dashoffset: -32;
        }
    }

    .scenario-btn.active-scenario {
        border-color: #3b82f6; /* bg-blue-500 equivalent */
        background-color: #eff6ff; /* bg-blue-50 equivalent */
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const loadSlider = document.getElementById('load-slider') as HTMLInputElement;
        const loadDisplay = document.getElementById('load-display');
        const stressPercentage = document.getElementById('stress-percentage');
        const stressBar = document.getElementById('stress-bar');
        const tempDisplay = document.getElementById('temp-display');
        const statusTitle = document.getElementById('status-title');
        const statusDesc = document.getElementById('status-desc');
        const alertBgGlow = document.getElementById('alert-bg-glow');
        const curtailmentToggle = document.getElementById('curtailment-toggle') as HTMLInputElement;
        
        // SVG elements
        const housesBox = document.getElementById('houses-box');
        const dcBox = document.getElementById('dc-box');
        const cableSubDc = document.getElementById('cable-sub-dc');
        const cableBackupDc = document.getElementById('cable-backup-dc');
        const backupPad = document.getElementById('backup-pad');
        const backupPadText = document.getElementById('backup-pad-text');
        const backupLegend = document.getElementById('backup-legend');

        let currentScenario = 'normal';
        let tempVal = '72°F';
        let baseHouseLoad = 120; // MW residential baseline
        let activeCurtailment = false;

        // Scenario selection
        const scenButtons = document.querySelectorAll('.scenario-btn');
        scenButtons.forEach(btn => {
            btn.addEventListener('click', () => {
                scenButtons.forEach(b => b.classList.remove('active-scenario'));
                btn.classList.add('active-scenario');
                
                currentScenario = btn.getAttribute('data-scenario') || 'normal';
                tempVal = btn.getAttribute('data-temp') || '72°F';
                baseHouseLoad = parseInt(btn.getAttribute('data-house') || '120');
                
                // Auto toggle curtailment during extreme scenarios to guide users
                if ((currentScenario === 'summer' || currentScenario === 'winter') && !activeCurtailment) {
                    // Let user toggle manually but raise alerts
                }
                
                calculate();
            });
        });

        // Curtailment Toggle Listener
        if (curtailmentToggle) {
            curtailmentToggle.addEventListener('change', () => {
                activeCurtailment = curtailmentToggle.checked;
                calculate();
            });
        }

        // Slider Listener
        if (loadSlider) {
            loadSlider.addEventListener('input', () => {
                calculate();
            });
        }

        function calculate() {
            if (!loadSlider || !loadDisplay || !stressPercentage || !stressBar || !tempDisplay || !statusTitle || !statusDesc || !alertBgGlow) return;

            let dcLoadVal = parseInt(loadSlider.value);
            
            // If curtailment is active, data center grid draw immediately drops to 0
            if (activeCurtailment) {
                dcLoadVal = 0;
                loadSlider.disabled = true;
                loadSlider.style.opacity = '0.5';
            } else {
                loadSlider.disabled = false;
                loadSlider.style.opacity = '1.0';
            }

            // Slider Display text
            loadDisplay.textContent = activeCurtailment ? "0 MW (Curtailment)" : dcLoadVal + " MW";
            tempDisplay.textContent = tempVal;

            // Total Grid Load = Residential + Data Center Grid Draw
            // Max grid capacity = 500 MW
            const totalLoad = baseHouseLoad + dcLoadVal;
            const stressPercent = Math.round((totalLoad / 500) * 100);

            stressPercentage.textContent = stressPercent + "%";
            stressBar.style.width = stressPercent + "%";

            // Update warning bar color depending on stress
            stressBar.className = "h-full transition-all duration-500";
            if (stressPercent < 60) {
                stressBar.classList.add('bg-green-400');
            } else if (stressPercent < 85) {
                stressBar.classList.add('bg-yellow-400');
            } else {
                stressBar.classList.add('bg-red-500');
            }

            // Update Alert Box Glogs & Visual status
            if (alertBgGlow) {
                alertBgGlow.className = "absolute -bottom-24 -left-24 w-48 h-48 rounded-full blur-3xl pointer-events-none transition-all duration-500";
                if (stressPercent > 85 && !activeCurtailment) {
                    alertBgGlow.classList.add('bg-red-500/20');
                } else if (activeCurtailment) {
                    alertBgGlow.classList.add('bg-green-500/20');
                } else {
                    alertBgGlow.classList.add('bg-blue-500/10');
                }
            }

            // Houses color warning inside SVG
            if (housesBox) {
                housesBox.setAttribute('stroke', '#475569');
                housesBox.setAttribute('fill', '#1e293b');
                if (stressPercent > 85) {
                    housesBox.setAttribute('stroke', '#ef4444'); // red-500
                    housesBox.setAttribute('fill', '#450a0a'); // red-950
                }
            }

            // Data center color warning inside SVG
            if (dcBox) {
                dcBox.setAttribute('stroke', '#475569');
                dcBox.setAttribute('fill', '#1e293b');
            }

            // Animate grid flows
            if (cableSubDc) {
                if (activeCurtailment) {
                    cableSubDc.setAttribute('stroke', '#64748b'); // gray-500
                    cableSubDc.classList.remove('grid-flow-animate');
                } else {
                    cableSubDc.setAttribute('stroke', '#3b82f6'); // blue-500
                    cableSubDc.classList.add('grid-flow-animate');
                }
            }

            // Animate backup flow loop
            if (cableBackupDc && backupPad && backupPadText && backupLegend) {
                const legendDot = backupLegend.querySelector('span');
                if (activeCurtailment) {
                    cableBackupDc.classList.remove('opacity-0');
                    cableBackupDc.classList.add('opacity-100', 'backup-flow-animate');
                    cableBackupDc.setAttribute('stroke', '#10b981'); // emerald-500
                    backupPad.setAttribute('stroke', '#10b981');
                    backupPad.setAttribute('fill', '#022c22');
                    backupPadText.textContent = "ACTIVE";
                    backupPadText.setAttribute('fill', '#10b981');
                    
                    if (legendDot) {
                        legendDot.classList.remove('bg-slate-300');
                        legendDot.classList.add('bg-emerald-500', 'animate-pulse');
                    }
                } else {
                    cableBackupDc.classList.add('opacity-0');
                    cableBackupDc.classList.remove('opacity-100', 'backup-flow-animate');
                    backupPad.setAttribute('stroke', '#475569');
                    backupPad.setAttribute('fill', '#0f172a');
                    backupPadText.textContent = "OFFLINE";
                    backupPadText.setAttribute('fill', '#64748b');
                    
                    if (legendDot) {
                        legendDot.classList.remove('bg-emerald-500', 'animate-pulse');
                        legendDot.classList.add('bg-slate-300');
                    }
                }
            }

            // Update Text Description of Curtailment status
            if (activeCurtailment) {
                statusTitle.textContent = "ACTIVE SHEDDING";
                statusTitle.className = "text-lg font-black text-emerald-400 leading-snug";
                statusDesc.textContent = `The facility has completely disconnected its load from the utility grid. Modern low-noise backup generators and batteries are powering servers locally. Grid capacity is restored.`;
            } else if (stressPercent >= 85) {
                statusTitle.textContent = "GRID EMERGENCY WARNING";
                statusTitle.className = "text-lg font-black text-red-500 leading-snug";
                statusDesc.textContent = `The local grid is under critical load strain due to extreme weather demand. Households risk load rolling blackouts unless emergency curtailment shedding is activated.`;
            } else {
                statusTitle.textContent = "INACTIVE";
                statusTitle.className = "text-lg font-black text-slate-400 leading-snug";
                statusDesc.textContent = `The regional grid has plenty of spare capacity. The facility is drawing electrical load cleanly from standard lines.`;
            }
        }

        // Init
        calculate();
    });
</script>
