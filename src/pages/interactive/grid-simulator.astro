---
import BaseLayout from '../../components/BaseLayout.astro';
---

<BaseLayout 
    title="ERCOT Grid Load-Balancing & Sankey Flow Simulator | TomorrowBeginsHere.com"
    description="Simulate real-time grid load balancing and demand-response using our interactive Sankey flow diagram. See how Texas SB 6 safeguards protect local communities during extreme weather events."
>
    <!-- Navigation Back Link -->
    <div class="bg-slate-950 pt-8 pb-4 border-b border-slate-800">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <a href="/interactive" class="inline-flex items-center text-sm font-semibold text-slate-400 hover:text-white transition-colors">
                <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                </svg>
                Back to Simulators Hub
            </a>
        </div>
    </div>

    <!-- Page Header -->
    <div class="bg-slate-950 border-b border-slate-800 relative overflow-hidden py-16 lg:py-20">
        <div class="absolute inset-0 bg-gradient-to-br from-blue-950/40 via-slate-950 to-indigo-950/40 z-0"></div>
        <div class="absolute inset-0 bg-[url('/images/texas-data-centers-network.png')] bg-cover bg-center z-0 opacity-5 mix-blend-overlay"></div>
        <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <span class="inline-block px-4 py-1.5 rounded-full bg-blue-500/10 text-blue-400 font-extrabold tracking-widest uppercase text-xs mb-4 border border-blue-500/20 backdrop-blur-sm">Pillar 05 • Interactive Simulation</span>
            <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-white mb-6 tracking-tight leading-tight">
                ERCOT Sankey Energy Flow &<br><span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-indigo-400">Curtailment Simulator</span>
            </h1>
            <p class="text-lg text-slate-400 max-w-3xl mx-auto font-light leading-relaxed">
                Texas data centers act as virtual shock-absorbers for our electrical grid. Drag the slider to simulate extreme weather demand, toggle curtailment protections, and visualize the energy redirection in real-time.
            </p>
        </div>
    </div>

    <!-- Simulator Section -->
    <section class="py-12 bg-slate-950 text-slate-100 relative">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch">
                
                <!-- Controls Column (5 cols) -->
                <div class="lg:col-span-5 flex flex-col justify-between">
                    <div class="bg-slate-900 border border-slate-800 rounded-3xl p-6 sm:p-8 shadow-2xl space-y-6 flex-grow flex flex-col justify-between">
                        <div>
                            <h3 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
                                <svg class="w-5 h-5 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
                                </svg>
                                Simulator Controls
                            </h3>
                            
                            <!-- Control 1: Grid Load / Stress -->
                            <div class="space-y-3 pb-6 border-b border-slate-800/60">
                                <div class="flex justify-between items-end">
                                    <label for="stress-slider" class="block text-xs font-bold text-slate-400 uppercase tracking-wider">Grid Demand Stress</label>
                                    <span class="text-lg font-black text-blue-400" id="stress-display">40%</span>
                                </div>
                                <input 
                                    type="range" 
                                    id="stress-slider" 
                                    min="10" 
                                    max="100" 
                                    value="40" 
                                    class="w-full h-2 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-blue-500 hover:accent-blue-400 transition-all"
                                >
                                <div class="flex justify-between text-[10px] font-bold text-slate-500">
                                    <span>Spring Day (10%)</span>
                                    <span>Moderate Alert (70%)</span>
                                    <span>Peak Grid Stress (100%)</span>
                                </div>
                            </div>

                            <!-- Control 2: Curtailment Toggle -->
                            <div class="py-6 border-b border-slate-800/60 flex justify-between items-center">
                                <div class="max-w-[70%]">
                                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider">SB 6 Automated Curtailment</label>
                                    <p class="text-[11px] text-slate-500 leading-relaxed mt-1">
                                        Enable ERCOT to curtail the data center load to 5% instantly when grid stress exceeds 90%.
                                    </p>
                                </div>
                                <button 
                                    type="button" 
                                    id="curtail-toggle"
                                    class="w-14 h-8 flex items-center bg-emerald-500 rounded-full p-1 cursor-pointer transition-colors duration-300 relative focus:outline-none"
                                >
                                    <div class="bg-white w-6 h-6 rounded-full shadow-md transform translate-x-6 transition-transform duration-300" id="curtail-knob"></div>
                                </button>
                            </div>

                            <!-- Control 3: Solar Generation Slider -->
                            <div class="pt-6 space-y-3">
                                <div class="flex justify-between items-end">
                                    <label for="solar-slider" class="block text-xs font-bold text-slate-400 uppercase tracking-wider">Behind-the-Meter Solar</label>
                                    <span class="text-lg font-black text-amber-400" id="solar-display">0 MW</span>
                                </div>
                                <input 
                                    type="range" 
                                    id="solar-slider" 
                                    min="0" 
                                    max="100" 
                                    step="10" 
                                    value="0" 
                                    class="w-full h-2 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-amber-500 hover:accent-amber-400 transition-all"
                                >
                                <div class="flex justify-between text-[10px] font-bold text-slate-500">
                                    <span>Off (0 MW)</span>
                                    <span>Hybrid Solar Power (100 MW)</span>
                                </div>
                                <p class="text-[11px] text-slate-500 leading-relaxed pt-1">
                                    On-site solar arrays feed direct energy bypassing the public grid, insulating the data center and reducing net grid demand.
                                </p>
                            </div>
                        </div>

                        <!-- Technical Footnote Inside Panel -->
                        <div class="mt-8 p-4 bg-slate-950/50 border border-slate-800 rounded-2xl">
                            <h4 class="text-xs font-bold text-white mb-1 uppercase tracking-wider">How to test:</h4>
                            <p class="text-[11px] text-slate-400 leading-relaxed">
                                1. Drag **Grid Demand Stress** to 100%.<br>
                                2. Turn SB 6 Curtailment **OFF**. Notice the blackouts in homes and hospitals as the deficit spikes.<br>
                                3. Turn SB 6 Curtailment **ON**. Notice the data center automatically drops its draw, stabilizing the grid immediately.
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Outputs and Visualizations Column (7 cols) -->
                <div class="lg:col-span-7 flex flex-col justify-between">
                    
                    <!-- Grand Total Banner -->
                    <div class="bg-gradient-to-br from-slate-900 via-slate-900 to-indigo-950/30 border border-slate-800 rounded-3xl p-6 sm:p-8 shadow-xl relative overflow-hidden transition-all duration-500" id="status-card">
                        <div class="absolute -top-24 -right-24 w-48 h-48 bg-emerald-500/10 rounded-full blur-3xl pointer-events-none transition-all duration-500" id="glow-panel"></div>
                        <div class="relative z-10 flex flex-col md:flex-row md:items-center justify-between gap-6">
                            <div>
                                <span class="inline-block px-2.5 py-1 rounded bg-emerald-500/10 text-emerald-400 font-extrabold uppercase text-[10px] tracking-wider mb-3 border border-emerald-500/20" id="status-badge">Grid Stabilized</span>
                                <div class="text-3xl sm:text-4xl font-black text-white tracking-tight" id="reserve-val">
                                    Reserve Margin: +15,000 MW
                                </div>
                                <p class="text-slate-400 text-xs mt-2 max-w-md leading-relaxed" id="status-desc">
                                    Generous power reserves are available. Local transmission grids are fully stable.
                                </p>
                            </div>
                            <div class="bg-slate-950/60 border border-slate-800 rounded-2xl p-4 text-center flex-shrink-0 min-w-[140px]">
                                <div class="text-2xl font-black text-emerald-400" id="curtail-amount">0 MW</div>
                                <div class="text-[9px] font-bold text-slate-500 uppercase tracking-widest mt-1">Shed Load (Saves Grid)</div>
                            </div>
                        </div>
                    </div>

                    <!-- Schematic Diagram Card -->
                    <div class="bg-slate-900 border border-slate-800 rounded-3xl p-6 sm:p-8 shadow-xl flex flex-col items-center flex-grow mt-6">
                        <div class="flex justify-between items-center w-full mb-6">
                            <h4 class="font-extrabold text-slate-400 text-xs uppercase tracking-wider">Live Sankey Flow Pipeline</h4>
                            <span class="text-[10px] font-bold text-indigo-400 bg-indigo-500/10 border border-indigo-500/20 px-2 py-0.5 rounded">ERCOT Demand-Response Scheme</span>
                        </div>
                        
                        <!-- Visual Schematic Container -->
                        <div class="relative w-full aspect-[4/3] border border-slate-800/80 bg-slate-950/80 rounded-2xl overflow-hidden p-4">
                            <svg viewBox="0 0 600 400" class="w-full h-full">
                                <!-- Gradients definitions -->
                                <defs>
                                    <linearGradient id="grad-solar" x1="0%" y1="0%" x2="100%" y2="0%">
                                        <stop offset="0%" stop-color="#fbbf24" stop-opacity="0.8"/>
                                        <stop offset="100%" stop-color="#f59e0b" stop-opacity="0.8"/>
                                    </linearGradient>
                                    <linearGradient id="grad-wind" x1="0%" y1="0%" x2="100%" y2="0%">
                                        <stop offset="0%" stop-color="#38bdf8" stop-opacity="0.8"/>
                                        <stop offset="100%" stop-color="#0284c7" stop-opacity="0.8"/>
                                    </linearGradient>
                                    <linearGradient id="grad-grid" x1="0%" y1="0%" x2="100%" y2="0%">
                                        <stop offset="0%" stop-color="#6366f1" stop-opacity="0.8"/>
                                        <stop offset="100%" stop-color="#4f46e5" stop-opacity="0.8"/>
                                    </linearGradient>
                                    
                                    <linearGradient id="grad-out-dc" x1="0%" y1="0%" x2="100%" y2="0%">
                                        <stop offset="0%" stop-color="#818cf8" stop-opacity="0.8"/>
                                        <stop offset="100%" stop-color="#a78bfa" stop-opacity="0.8"/>
                                    </linearGradient>
                                    <linearGradient id="grad-out-homes" x1="0%" y1="0%" x2="100%" y2="0%">
                                        <stop offset="0%" stop-color="#10b981" stop-opacity="0.8"/>
                                        <stop offset="100%" stop-color="#34d399" stop-opacity="0.8"/>
                                    </linearGradient>
                                    <linearGradient id="grad-out-hospital" x1="0%" y1="0%" x2="100%" y2="0%">
                                        <stop offset="0%" stop-color="#f43f5e" stop-opacity="0.8"/>
                                        <stop offset="100%" stop-color="#fb7185" stop-opacity="0.8"/>
                                    </linearGradient>
                                </defs>

                                <!-- FLOW PATHS (Generation to Hub) -->
                                <!-- Solar Flow (from Solar (40,80) to Hub (280,180)) -->
                                <path id="path-solar" d="M 90 80 C 180 80, 180 180, 260 180" fill="none" stroke="url(#grad-solar)" stroke-width="12" class="flow-path transition-all duration-500" />
                                
                                <!-- Wind Flow (from Wind (40,180) to Hub (280,180)) -->
                                <path id="path-wind" d="M 90 180 L 260 180" fill="none" stroke="url(#grad-wind)" stroke-width="18" class="flow-path transition-all duration-500" />
                                
                                <!-- traditional Grid Flow (from Grid (40,280) to Hub (280,180)) -->
                                <path id="path-grid" d="M 90 280 C 180 280, 180 180, 260 180" fill="none" stroke="url(#grad-grid)" stroke-width="25" class="flow-path transition-all duration-500" />

                                <!-- FLOW PATHS (Behind-the-Meter direct Solar to Data Center) -->
                                <path id="path-solar-direct" d="M 90 80 C 240 20, 320 20, 510 80" fill="none" stroke="url(#grad-solar)" stroke-width="0" class="flow-path transition-all duration-500" stroke-dasharray="8 6" style="opacity: 0;" />

                                <!-- FLOW PATHS (Hub to Consumers) -->
                                <!-- Hub to Data Center (from Hub (300,180) to DC (510,80)) -->
                                <path id="path-hub-dc" d="M 300 180 C 380 180, 380 80, 510 80" fill="none" stroke="url(#grad-out-dc)" stroke-width="22" class="flow-path transition-all duration-500" />
                                
                                <!-- Hub to Homes (from Hub (300,180) to Homes (510,180)) -->
                                <path id="path-hub-homes" d="M 300 180 L 510 180" fill="none" stroke="url(#grad-out-homes)" stroke-width="15" class="flow-path transition-all duration-500" />
                                
                                <!-- Hub to Hospital (from Hub (300,180) to Hospital (510,280)) -->
                                <path id="path-hub-hospital" d="M 300 180 C 380 180, 380 280, 510 280" fill="none" stroke="url(#grad-out-hospital)" stroke-width="10" class="flow-path transition-all duration-500" />

                                <!-- NODES (Overlaid on flows) -->
                                <!-- Node 1: Solar Gen -->
                                <g id="node-solar" class="cursor-pointer">
                                    <circle cx="50" cy="80" r="30" fill="#1e293b" stroke="#fbbf24" stroke-width="2" class="transition-colors duration-500" />
                                    <!-- Sun Icon -->
                                    <circle cx="50" cy="80" r="8" fill="#fbbf24" />
                                    <path d="M 50 64 L 50 68 M 50 92 L 50 96 M 34 80 L 38 80 M 62 80 L 66 80 M 39 69 L 42 72 M 58 88 L 61 91 M 39 91 L 42 88 M 58 72 L 61 69" stroke="#fbbf24" stroke-width="2" stroke-linecap="round" />
                                    <text x="50" y="125" text-anchor="middle" font-size="10" font-weight="extrabold" fill="#fbbf24" letter-spacing="1">SOLAR</text>
                                </g>

                                <!-- Node 2: Wind Gen -->
                                <g id="node-wind">
                                    <circle cx="50" cy="180" r="30" fill="#1e293b" stroke="#38bdf8" stroke-width="2" />
                                    <!-- Wind Turbine lines -->
                                    <path d="M 50 180 L 50 198 M 50 180 L 38 172 M 50 180 L 62 172 M 50 180 L 50 162" stroke="#38bdf8" stroke-width="2" stroke-linecap="round" />
                                    <text x="50" y="225" text-anchor="middle" font-size="10" font-weight="extrabold" fill="#38bdf8" letter-spacing="1">WIND</text>
                                </g>

                                <!-- Node 3: Traditional Grid -->
                                <g id="node-grid">
                                    <circle cx="50" cy="280" r="30" fill="#1e293b" stroke="#6366f1" stroke-width="2" />
                                    <!-- Lightning Icon -->
                                    <path d="M 50 262 L 40 280 L 48 280 L 46 298 L 60 276 L 50 276 Z" fill="#6366f1" />
                                    <text x="50" y="325" text-anchor="middle" font-size="10" font-weight="extrabold" fill="#6366f1" letter-spacing="1">GRID</text>
                                </g>

                                <!-- Node 4: ERCOT Hub (Center Core) -->
                                <g id="node-ercot">
                                    <circle cx="280" cy="180" r="32" fill="#0f172a" stroke="#4f46e5" stroke-width="3" id="hub-circle" class="transition-all duration-500" />
                                    <text x="280" y="180" text-anchor="middle" font-size="8" font-weight="black" fill="#a78bfa" letter-spacing="1">ERCOT</text>
                                    <text x="280" y="191" text-anchor="middle" font-size="7" font-weight="bold" fill="#64748b" id="hub-load-text">HUB</text>
                                </g>

                                <!-- Node 5: Data Center -->
                                <g id="node-dc">
                                    <rect x="510" y="45" width="70" height="70" rx="12" fill="#1e293b" stroke="#818cf8" stroke-width="2" id="dc-box" class="transition-colors duration-500" />
                                    <!-- Server Stack Icon -->
                                    <rect x="525" y="60" width="40" height="8" rx="2" fill="#475569" id="dc-rack-1" class="transition-colors duration-500" />
                                    <circle cx="533" cy="64" r="2" fill="#10b981" id="dc-dot-1" />
                                    <rect x="525" y="74" width="40" height="8" rx="2" fill="#475569" id="dc-rack-2" class="transition-colors duration-500" />
                                    <circle cx="533" cy="78" r="2" fill="#10b981" id="dc-dot-2" />
                                    <rect x="525" y="88" width="40" height="8" rx="2" fill="#475569" id="dc-rack-3" class="transition-colors duration-500" />
                                    <circle cx="533" cy="92" r="2" fill="#10b981" id="dc-dot-3" />
                                    
                                    <text x="545" y="130" text-anchor="middle" font-size="9" font-weight="extrabold" fill="#818cf8" letter-spacing="1">DATA CENTER</text>
                                    <text x="545" y="141" text-anchor="middle" font-size="8" font-weight="black" fill="#c7d2fe" id="dc-load-txt">100 MW</text>
                                </g>

                                <!-- Node 6: County Homes -->
                                <g id="node-homes">
                                    <rect x="510" y="145" width="70" height="70" rx="12" fill="#1e293b" stroke="#10b981" stroke-width="2" id="homes-box" class="transition-colors duration-500" />
                                    <!-- House Icon -->
                                    <path d="M 545 158 L 525 174 L 530 174 L 530 196 L 560 196 L 560 174 L 565 174 Z" fill="#10b981" id="homes-icon" class="transition-colors duration-500" />
                                    <rect x="540" y="180" width="10" height="16" fill="#1e293b" id="homes-door" />
                                    
                                    <text x="545" y="230" text-anchor="middle" font-size="9" font-weight="extrabold" fill="#10b981" letter-spacing="1">HOMES</text>
                                    <text x="545" y="241" text-anchor="middle" font-size="8" font-weight="black" fill="#a7f3d0" id="homes-load-txt">50 MW</text>
                                </g>

                                <!-- Node 7: Hospitals / Critical Infrastructure -->
                                <g id="node-hospital">
                                    <rect x="510" y="245" width="70" height="70" rx="12" fill="#1e293b" stroke="#f43f5e" stroke-width="2" id="hospital-box" class="transition-colors duration-500" />
                                    <!-- Red Cross Shield -->
                                    <path d="M 545 255 L 530 262 L 530 282 Q 545 296, 560 282 L 560 262 Z" fill="#f43f5e" id="hospital-icon" class="transition-colors duration-500" />
                                    <path d="M 541 273 L 549 273 M 545 269 L 545 277" stroke="#1e293b" stroke-width="2.5" stroke-linecap="round" />
                                    
                                    <text x="545" y="330" text-anchor="middle" font-size="9" font-weight="extrabold" fill="#f43f5e" letter-spacing="1">HOSPITALS</text>
                                    <text x="545" y="341" text-anchor="middle" font-size="8" font-weight="black" fill="#fecdd3" id="hospital-load-txt">20 MW</text>
                                </g>
                            </svg>
                        </div>
                    </div>
                </div>

            </div>

        </div>
    </section>

    <!-- Detailed Explanation Section -->
    <section class="py-16 bg-slate-900 border-t border-slate-800 text-slate-300">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="prose prose-invert prose-lg max-w-none">
                <h2 class="text-white text-2xl font-bold mb-6">How Data Centers Support Grid Stability</h2>
                <p>
                    A common concern regarding large-scale data centers is their constant demand for electrical power. However, modern infrastructure operates far differently than standard consumers. 
                </p>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 my-10">
                    <div class="bg-slate-950/60 p-6 rounded-2xl border border-slate-800">
                        <h4 class="text-white font-bold mb-2 flex items-center gap-2">
                            <span class="w-2.5 h-2.5 rounded-full bg-emerald-500"></span>
                            SB 6: The Curtailment Safeguard
                        </h4>
                        <p class="text-sm text-slate-400">
                            Passed by the Texas Legislature, Senate Bill 6 gives ERCOT explicit authority to order large industrial flexible loads, including data centers, to dial down their consumption to near-zero within minutes during supply deficits.
                        </p>
                    </div>
                    
                    <div class="bg-slate-950/60 p-6 rounded-2xl border border-slate-800">
                        <h4 class="text-white font-bold mb-2 flex items-center gap-2">
                            <span class="w-2.5 h-2.5 rounded-full bg-amber-500"></span>
                            Behind-the-Meter Hybrid Power
                        </h4>
                        <p class="text-sm text-slate-400">
                            By deploying dedicated solar farms and batteries directly connected to the facility, data centers decrease their reliance on transmission grid infrastructure, generating their own green energy when the grid is most stressed.
                        </p>
                    </div>
                </div>

                <p>
                    In this simulation, you can see that when grid stress spikes to **90% or above** (simulating a winter freeze or summer heatwave) and curtailment is active, the data center drops its draw to a baseline of just 5 MW. This immediately returns massive capacity to the ERCOT balancing pool, ensuring county homes, critical businesses, and hospitals remain fully lit and powered.
                </p>
            </div>
        </div>
    </section>
</BaseLayout>

<style>
    /* Animated flow along the Sankey curves */
    .flow-path {
        stroke-dasharray: 20 10;
        animation: flow-dash 1.5s linear infinite;
        opacity: 0.85;
    }
    
    @keyframes flow-dash {
        to {
            stroke-dashoffset: -90;
        }
    }

    /* Slider styling adjustments */
    input[type="range"]::-webkit-slider-thumb {
        border-radius: 9999px;
        box-shadow: 0 0 15px currentColor;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const stressSlider = document.getElementById('stress-slider') as HTMLInputElement;
        const solarSlider = document.getElementById('solar-slider') as HTMLInputElement;
        const curtailToggle = document.getElementById('curtail-toggle');
        const curtailKnob = document.getElementById('curtail-knob');

        const stressDisplay = document.getElementById('stress-display');
        const solarDisplay = document.getElementById('solar-display');
        
        // Status banner displays
        const statusCard = document.getElementById('status-card');
        const glowPanel = document.getElementById('glow-panel');
        const statusBadge = document.getElementById('status-badge');
        const reserveVal = document.getElementById('reserve-val');
        const statusDesc = document.getElementById('status-desc');
        const curtailAmount = document.getElementById('curtail-amount');

        // SVG Flow Paths
        const pathSolar = document.getElementById('path-solar');
        const pathWind = document.getElementById('path-wind');
        const pathGrid = document.getElementById('path-grid');
        const pathSolarDirect = document.getElementById('path-solar-direct');
        const pathHubDC = document.getElementById('path-hub-dc');
        const pathHubHomes = document.getElementById('path-hub-homes');
        const pathHubHospital = document.getElementById('path-hub-hospital');

        // SVG Nodes & Contents
        const hubCircle = document.getElementById('hub-circle');
        const hubLoadText = document.getElementById('hub-load-text');
        
        const dcBox = document.getElementById('dc-box');
        const dcRack1 = document.getElementById('dc-rack-1');
        const dcRack2 = document.getElementById('dc-rack-2');
        const dcRack3 = document.getElementById('dc-rack-3');
        const dcDot1 = document.getElementById('dc-dot-1');
        const dcDot2 = document.getElementById('dc-dot-2');
        const dcDot3 = document.getElementById('dc-dot-3');
        const dcLoadTxt = document.getElementById('dc-load-txt');

        const homesBox = document.getElementById('homes-box');
        const homesIcon = document.getElementById('homes-icon');
        const homesLoadTxt = document.getElementById('homes-load-txt');

        const hospitalBox = document.getElementById('hospital-box');
        const hospitalIcon = document.getElementById('hospital-icon');
        const hospitalLoadTxt = document.getElementById('hospital-load-txt');

        let curtailmentActive = true;

        function updateCurtailmentToggle() {
            if (curtailmentActive) {
                curtailToggle?.classList.add('bg-emerald-500');
                curtailToggle?.classList.remove('bg-slate-700');
                curtailKnob?.classList.add('translate-x-6');
            } else {
                curtailToggle?.classList.remove('bg-emerald-500');
                curtailToggle?.classList.add('bg-slate-700');
                curtailKnob?.classList.remove('translate-x-6');
            }
        }

        function calculate() {
            if (!stressSlider || !solarSlider) return;

            const stress = parseInt(stressSlider.value);
            const solar = parseInt(solarSlider.value);

            if (stressDisplay) stressDisplay.textContent = stress + "%";
            if (solarDisplay) solarDisplay.textContent = solar + " MW";

            // Determine data center load based on curtailment and stress
            let dcDemand = 100; // base DC draw in MW
            let isCurtailed = false;

            if (stress >= 90 && curtailmentActive) {
                dcDemand = 5; // drop to 5 MW baseline under curtailment
                isCurtailed = true;
            }

            // Calculate direct solar behind-the-meter contribution
            let solarToHubFlow = solar;
            let solarToDCFlow = 0;
            let netDCGridDraw = dcDemand;

            if (solar > 0) {
                // If solar co-generation is active, it directly fuels the DC first
                solarToDCFlow = Math.min(solar, dcDemand);
                netDCGridDraw = dcDemand - solarToDCFlow;
                solarToHubFlow = solar - solarToDCFlow; // excess solar feeds the grid
            }

            // Determine home and hospital demand based on grid stress
            const homesDemand = Math.round(50 + (stress * 1.5)); // increases as stress rises
            const hospitalDemand = 20; // critical infrastructure remains flat

            // ERCOT reserve calculation
            let reserveMargin = 15000 - (stress * 155);
            if (isCurtailed) {
                reserveMargin += 95 * 25; // stabilized by shed load
            } else if (stress >= 90) {
                reserveMargin -= 2500; // severe deficit if curtailment is OFF
            }

            // Update UI/Visual values
            if (curtailAmount) {
                curtailAmount.textContent = isCurtailed ? "95 MW" : "0 MW";
                curtailAmount.className = isCurtailed ? "text-2xl font-black text-emerald-400" : "text-2xl font-black text-slate-600";
            }
            if (dcLoadTxt) dcLoadTxt.textContent = dcDemand + " MW";
            if (homesLoadTxt) homesLoadTxt.textContent = homesDemand + " MW";
            if (hospitalLoadTxt) hospitalLoadTxt.textContent = hospitalDemand + " MW";

            // Grid Status States (Normal, Alert, emergency-safe, emergency-blackout)
            let status = 'normal';
            if (stress >= 90) {
                status = curtailmentActive ? 'emergency-safe' : 'emergency-blackout';
            } else if (stress >= 70) {
                status = 'alert';
            }

            // Adjust flow path stroke-widths (Sankey bands)
            if (pathSolar) pathSolar.setAttribute('stroke-width', (solarToHubFlow * 0.25).toString());
            if (pathWind) pathWind.setAttribute('stroke-width', (18 - (stress * 0.05)).toString());
            
            // Grid flow changes with stress
            const gridFlowWidth = Math.max(10, 25 - (stress * 0.1));
            if (pathGrid) pathGrid.setAttribute('stroke-width', gridFlowWidth.toString());

            // Behind-the-meter direct solar line
            if (pathSolarDirect) {
                if (solarToDCFlow > 0) {
                    pathSolarDirect.setAttribute('stroke-width', (solarToDCFlow * 0.2).toString());
                    pathSolarDirect.style.opacity = "1";
                } else {
                    pathSolarDirect.setAttribute('stroke-width', "0");
                    pathSolarDirect.style.opacity = "0";
                }
            }

            // Consumer flow paths
            if (pathHubDC) pathHubDC.setAttribute('stroke-width', (netDCGridDraw * 0.25).toString());
            if (pathHubHomes) pathHubHomes.setAttribute('stroke-width', (homesDemand * 0.3).toString());
            if (pathHubHospital) pathHubHospital.setAttribute('stroke-width', (hospitalDemand * 0.5).toString());

            // Apply specific status behaviors (Color/Glow transitions)
            if (status === 'normal') {
                // Stabilized Green state
                if (statusCard) statusCard.className = "bg-gradient-to-br from-slate-900 via-slate-900 to-indigo-950/30 border border-slate-800 rounded-3xl p-6 sm:p-8 shadow-xl relative overflow-hidden transition-all duration-500";
                if (glowPanel) glowPanel.className = "absolute -top-24 -right-24 w-48 h-48 bg-emerald-500/10 rounded-full blur-3xl pointer-events-none transition-all duration-500";
                if (statusBadge) {
                    statusBadge.textContent = "Grid Stabilized";
                    statusBadge.className = "inline-block px-2.5 py-1 rounded bg-emerald-500/10 text-emerald-400 font-extrabold uppercase text-[10px] tracking-wider mb-3 border border-emerald-500/20";
                }
                if (reserveVal) {
                    reserveVal.textContent = `Reserve Margin: +${reserveMargin.toLocaleString()} MW`;
                    reserveVal.className = "text-3xl sm:text-4xl font-black text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-teal-300 tracking-tight transition-all duration-500";
                }
                if (statusDesc) statusDesc.textContent = "Generous power reserves are available. Local transmission grids are fully stable.";

                // Path colors normal
                pathHubDC?.setAttribute('stroke', 'url(#grad-out-dc)');
                pathHubHomes?.setAttribute('stroke', 'url(#grad-out-homes)');
                pathHubHospital?.setAttribute('stroke', 'url(#grad-out-hospital)');

                // Hub text
                if (hubCircle) hubCircle.setAttribute('stroke', '#4f46e5');
                if (hubLoadText) hubLoadText.textContent = "HUB";

                // Nodes active
                homesBox?.setAttribute('stroke', '#10b981');
                homesIcon?.setAttribute('fill', '#10b981');
                if (homesBox) homesBox.style.fill = '#1e293b';

                hospitalBox?.setAttribute('stroke', '#f43f5e');
                hospitalIcon?.setAttribute('fill', '#f43f5e');
                if (hospitalBox) hospitalBox.style.fill = '#1e293b';

                dcBox?.setAttribute('stroke', '#818cf8');
                if (dcBox) dcBox.style.fill = '#1e293b';
                [dcRack1, dcRack2, dcRack3].forEach(r => r?.setAttribute('fill', '#475569'));
                [dcDot1, dcDot2, dcDot3].forEach(d => d?.setAttribute('fill', '#10b981'));

            } else if (status === 'alert') {
                // Warning Yellow alert
                if (statusCard) statusCard.className = "bg-gradient-to-br from-slate-900 via-slate-900 to-indigo-950/30 border border-slate-800 rounded-3xl p-6 sm:p-8 shadow-xl relative overflow-hidden transition-all duration-500";
                if (glowPanel) glowPanel.className = "absolute -top-24 -right-24 w-48 h-48 bg-amber-500/10 rounded-full blur-3xl pointer-events-none transition-all duration-500";
                if (statusBadge) {
                    statusBadge.textContent = "Grid Alert";
                    statusBadge.className = "inline-block px-2.5 py-1 rounded bg-amber-500/10 text-amber-400 font-extrabold uppercase text-[10px] tracking-wider mb-3 border border-amber-500/20";
                }
                if (reserveVal) {
                    reserveVal.textContent = `Reserve Margin: +${reserveMargin.toLocaleString()} MW`;
                    reserveVal.className = "text-3xl sm:text-4xl font-black text-transparent bg-clip-text bg-gradient-to-r from-amber-400 to-yellow-300 tracking-tight transition-all duration-500";
                }
                if (statusDesc) statusDesc.textContent = "High summer loads are shrinking reserve capacity. ERCOT monitoring flexible loads.";

                // Path colors normal alert
                pathHubDC?.setAttribute('stroke', 'url(#grad-out-dc)');
                pathHubHomes?.setAttribute('stroke', 'url(#grad-out-homes)');
                pathHubHospital?.setAttribute('stroke', 'url(#grad-out-hospital)');

                // Hub text alert
                if (hubCircle) hubCircle.setAttribute('stroke', '#fbbf24');
                if (hubLoadText) hubLoadText.textContent = "ALERT";

                // Nodes active
                homesBox?.setAttribute('stroke', '#10b981');
                homesIcon?.setAttribute('fill', '#10b981');
                if (homesBox) homesBox.style.fill = '#1e293b';

                hospitalBox?.setAttribute('stroke', '#f43f5e');
                hospitalIcon?.setAttribute('fill', '#f43f5e');
                if (hospitalBox) hospitalBox.style.fill = '#1e293b';

                dcBox?.setAttribute('stroke', '#818cf8');
                if (dcBox) dcBox.style.fill = '#1e293b';
                [dcRack1, dcRack2, dcRack3].forEach(r => r?.setAttribute('fill', '#475569'));
                [dcDot1, dcDot2, dcDot3].forEach(d => d?.setAttribute('fill', '#fbbf24'));

            } else if (status === 'emergency-safe') {
                // Emergency stabilized under curtailment
                if (statusCard) statusCard.className = "bg-gradient-to-br from-slate-900 via-slate-900 to-indigo-950/30 border border-emerald-800/40 rounded-3xl p-6 sm:p-8 shadow-xl relative overflow-hidden transition-all duration-500";
                if (glowPanel) glowPanel.className = "absolute -top-24 -right-24 w-48 h-48 bg-emerald-500/20 rounded-full blur-3xl pointer-events-none transition-all duration-500";
                if (statusBadge) {
                    statusBadge.textContent = "Grid Saved (SB 6 Curtailment Active)";
                    statusBadge.className = "inline-block px-2.5 py-1 rounded bg-emerald-500/20 text-emerald-400 font-extrabold uppercase text-[10px] tracking-wider mb-3 border border-emerald-500/30";
                }
                if (reserveVal) {
                    reserveVal.textContent = `Reserve Margin: +${reserveMargin.toLocaleString()} MW`;
                    reserveVal.className = "text-3xl sm:text-4xl font-black text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-teal-300 tracking-tight transition-all duration-500";
                }
                if (statusDesc) statusDesc.textContent = "Data Center automatically shed 95% of its load within seconds. Energy successfully redirected to keep residences online.";

                // Path colors - DC path drops, Homes path bright safe green
                pathHubDC?.setAttribute('stroke', '#334155'); // Greyed out/minimal
                pathHubHomes?.setAttribute('stroke', 'url(#grad-out-homes)');
                pathHubHospital?.setAttribute('stroke', 'url(#grad-out-hospital)');

                // Hub text
                if (hubCircle) hubCircle.setAttribute('stroke', '#10b981');
                if (hubLoadText) hubLoadText.textContent = "STABLE";

                // Homes & Hospital remain powered
                homesBox?.setAttribute('stroke', '#10b981');
                homesIcon?.setAttribute('fill', '#10b981');
                if (homesBox) homesBox.style.fill = '#1e293b';

                hospitalBox?.setAttribute('stroke', '#f43f5e');
                hospitalIcon?.setAttribute('fill', '#f43f5e');
                if (hospitalBox) hospitalBox.style.fill = '#1e293b';

                // Data Center Node shows curtailed (grey/offline look)
                dcBox?.setAttribute('stroke', '#334155');
                if (dcBox) dcBox.style.fill = '#0f172a';
                [dcRack1, dcRack2, dcRack3].forEach(r => r?.setAttribute('fill', '#1e293b'));
                [dcDot1, dcDot2, dcDot3].forEach(d => d?.setAttribute('fill', '#475569')); // warning status markers offline

            } else if (status === 'emergency-blackout') {
                // Blackout / Failure state (Curtailment disabled during Emergency)
                if (statusCard) statusCard.className = "bg-gradient-to-br from-red-950 via-slate-900 to-slate-900 border border-red-900/40 rounded-3xl p-6 sm:p-8 shadow-xl relative overflow-hidden transition-all duration-500";
                if (glowPanel) glowPanel.className = "absolute -top-24 -right-24 w-48 h-48 bg-red-500/20 rounded-full blur-3xl pointer-events-none transition-all duration-500";
                if (statusBadge) {
                    statusBadge.textContent = "CRITICAL OVERLOAD (BLACKOUT)";
                    statusBadge.className = "inline-block px-2.5 py-1 rounded bg-red-500/20 text-red-400 font-extrabold uppercase text-[10px] tracking-wider mb-3 border border-red-500/30 animate-pulse";
                }
                if (reserveVal) {
                    reserveVal.textContent = `Power Deficit: ${reserveMargin.toLocaleString()} MW`;
                    reserveVal.className = "text-3xl sm:text-4xl font-black text-transparent bg-clip-text bg-gradient-to-r from-red-500 to-orange-400 tracking-tight transition-all duration-500";
                }
                if (statusDesc) statusDesc.textContent = "Data Center failed to shed load. Peak grid demand triggered protective relays, causing regional brownouts and residential blackouts.";

                // Path colors - Consumer paths go dark red or dead grey
                pathHubDC?.setAttribute('stroke', '#ef4444'); // Thick drawing red
                pathHubHomes?.setAttribute('stroke', '#1e293b'); // Dead grey line
                pathHubHospital?.setAttribute('stroke', '#1e293b'); // Dead grey line

                // Hub text
                if (hubCircle) hubCircle.setAttribute('stroke', '#ef4444');
                if (hubLoadText) hubLoadText.textContent = "CRITICAL";

                // Homes & Hospital turn dark (blacked out)
                homesBox?.setAttribute('stroke', '#334155');
                homesIcon?.setAttribute('fill', '#334155');
                if (homesBox) homesBox.style.fill = '#0f172a';

                hospitalBox?.setAttribute('stroke', '#334155');
                hospitalIcon?.setAttribute('fill', '#334155');
                if (hospitalBox) hospitalBox.style.fill = '#0f172a';

                // Data center drawing high red load
                dcBox?.setAttribute('stroke', '#ef4444');
                if (dcBox) dcBox.style.fill = '#450a0a';
                [dcRack1, dcRack2, dcRack3].forEach(r => r?.setAttribute('fill', '#ef4444'));
                [dcDot1, dcDot2, dcDot3].forEach(d => d?.setAttribute('fill', '#ef4444'));
            }
        }

        // Toggles
        curtailToggle?.addEventListener('click', () => {
            curtailmentActive = !curtailmentActive;
            updateCurtailmentToggle();
            calculate();
        });

        // Sliders
        stressSlider?.addEventListener('input', calculate);
        solarSlider?.addEventListener('input', calculate);

        // Initial setup
        updateCurtailmentToggle();
        calculate();
    });
</script>
